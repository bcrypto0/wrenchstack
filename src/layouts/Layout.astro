              <li><a href="/agencies/" class="hover:text-slate-900">Marketing agencies</a></li>
              <li><a href="/ai-tools/" class="hover:text-slate-900">AI tools</a></li>
              <li><a href="/payments/" class="hover:text-slate-900">Payment processing</a></li>
