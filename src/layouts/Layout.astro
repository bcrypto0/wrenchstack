    <script>
      // Sitewide search — fetches /search-index.json on first focus, then
      // filters client-side on each keypress. Detects "X vs Y" queries
      // and constructs the comparison URL on the fly.
      (() => {
        const input = document.getElementById('site-search') as HTMLInputElement | null;
        const resultsBox = document.getElementById('site-search-results') as HTMLDivElement | null;
        if (!input || !resultsBox) return;

        type SearchItem = {
          type: string;
          name: string;
          slug?: string;
          url: string;
          tagline?: string;
          bestFor?: string;
          features?: string[];
          verticals?: string[];
        };

        let index: SearchItem[] | null = null;
        let loading = false;
        let activeIdx = -1;
        let lastResults: SearchItem[] = [];

        const TYPE_LABELS: Record<string, { label: string; color: string }> = {
          tool: { label: 'Tool', color: 'bg-orange-100 text-orange-800' },
          vertical: { label: 'Trade', color: 'bg-blue-100 text-blue-800' },
          feature: { label: 'Feature', color: 'bg-purple-100 text-purple-800' },
          migration: { label: 'Migration', color: 'bg-emerald-100 text-emerald-800' },
          page: { label: 'Page', color: 'bg-slate-100 text-slate-700' },
          comparison: { label: 'Compare', color: 'bg-amber-100 text-amber-800' },
          leadgen: { label: 'Lead-gen', color: 'bg-pink-100 text-pink-800' },
          insurance: { label: 'Insurance', color: 'bg-cyan-100 text-cyan-800' },
          payroll: { label: 'Payroll', color: 'bg-violet-100 text-violet-800' },
          agency: { label: 'Agency', color: 'bg-rose-100 text-rose-800' },
          ai: { label: 'AI', color: 'bg-indigo-100 text-indigo-800' },
          payment: { label: 'Payments', color: 'bg-teal-100 text-teal-800' },
          financing: { label: 'Financing', color: 'bg-amber-100 text-amber-800' },
          accounting: { label: 'Accounting', color: 'bg-sky-100 text-sky-800' },
          banking: { label: 'Banking', color: 'bg-emerald-100 text-emerald-800' },
        };

        async function ensureIndex() {
          if (index || loading) return;
          loading = true;
          try {
            const res = await fetch('/search-index.json');
            const data = await res.json();
            index = data.items as SearchItem[];
          } catch (err) {
            console.error('Search index load failed', err);
          } finally {
            loading = false;
          }
        }

        function findToolBySlug(slug: string): SearchItem | undefined {
          return index?.find((i) => i.type === 'tool' && i.slug === slug);
        }

        function findToolByName(name: string): SearchItem | undefined {
          if (!index) return undefined;
          const lower = name.toLowerCase().trim();
          // Exact match first
          let m = index.find((i) => i.type === 'tool' && i.name.toLowerCase() === lower);
          if (m) return m;
          // Prefix match
          m = index.find((i) => i.type === 'tool' && i.name.toLowerCase().startsWith(lower));
          if (m) return m;
          // Substring match
          m = index.find((i) => i.type === 'tool' && i.name.toLowerCase().includes(lower));
          return m;
        }

        function detectVsComparison(query: string): SearchItem | null {
          // Detect "X vs Y" or "X versus Y" patterns
          const match = query.match(/^(.+?)\s+(?:vs|versus|v\.?)\s+(.+)$/i);
          if (!match) return null;
          const toolA = findToolByName(match[1].trim());
          const toolB = findToolByName(match[2].trim());
          if (!toolA || !toolB || !toolA.slug || !toolB.slug) return null;
          // Build the alphabetical URL since both directions now exist
          const [first, second] = [toolA.slug, toolB.slug].sort();
          return {
            type: 'comparison',
            name: `${toolA.name} vs ${toolB.name}`,
            url: `/compare/${first}-vs-${second}/`,
            tagline: `Side-by-side comparison of ${toolA.name} and ${toolB.name}`,
          };
        }

        function scoreItem(item: SearchItem, q: string): number {
          const qLower = q.toLowerCase();
          const name = item.name.toLowerCase();
          // Highest: exact name match
          if (name === qLower) return 100;
          // High: name starts with query
          if (name.startsWith(qLower)) return 80;
          // Medium-high: word in name starts with query
          if (name.split(/\s+/).some((w) => w.startsWith(qLower))) return 60;
          // Medium: substring in name
          if (name.includes(qLower)) return 40;
          // Lower: substring in tagline
          if (item.tagline?.toLowerCase().includes(qLower)) return 20;
          // Lower: substring in bestFor
          if (item.bestFor?.toLowerCase().includes(qLower)) return 15;
          // Lowest: matches a feature or vertical
          if (item.features?.some((f) => f.toLowerCase().includes(qLower))) return 10;
          if (item.verticals?.some((v) => v.toLowerCase().includes(qLower))) return 10;
          return 0;
        }

        function runSearch(query: string): SearchItem[] {
          if (!index || query.length < 1) return [];
          const results: Array<{ item: SearchItem; score: number }> = [];

          // Check for "X vs Y" pattern first; if detected, add it as the top result
          const vsResult = detectVsComparison(query);
          if (vsResult) {
            results.push({ item: vsResult, score: 200 });
          }

          for (const item of index) {
            const score = scoreItem(item, query);
            if (score > 0) {
              results.push({ item, score });
            }
          }

          results.sort((a, b) => b.score - a.score);
          return results.slice(0, 8).map((r) => r.item);
        }

        function renderResults(results: SearchItem[]) {
          lastResults = results;
          activeIdx = -1;
          if (results.length === 0) {
            resultsBox!.innerHTML = '<div class="px-4 py-3 text-sm text-slate-500">No matches. Try a tool name, trade, or "X vs Y".</div>';
            resultsBox!.classList.remove('hidden');
            return;
          }
          const html = results
            .map((r, i) => {
              const typeInfo = TYPE_LABELS[r.type] || TYPE_LABELS.page;
              return `
              <a
                href="${r.url}"
                data-idx="${i}"
                class="block px-3 py-2.5 text-sm transition hover:bg-orange-50 focus:bg-orange-50 focus:outline-none"
              >
                <div class="flex items-center gap-2">
                  <span class="shrink-0 rounded px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider ${typeInfo.color}">${typeInfo.label}</span>
                  <span class="font-medium text-slate-900">${escapeHtml(r.name)}</span>
                </div>
                ${r.tagline ? `<div class="ml-[36px] mt-0.5 text-xs text-slate-500 line-clamp-1">${escapeHtml(r.tagline)}</div>` : ''}
              </a>
            `;
            })
            .join('');
          resultsBox!.innerHTML = html;
          resultsBox!.classList.remove('hidden');
        }

        function escapeHtml(s: string): string {
          return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        function hideResults() {
          resultsBox!.classList.add('hidden');
          activeIdx = -1;
        }

        function setActive(idx: number) {
          const items = resultsBox!.querySelectorAll('[data-idx]');
          items.forEach((el) => el.classList.remove('bg-orange-50'));
          if (idx >= 0 && idx < items.length) {
            const target = items[idx] as HTMLElement;
            target.classList.add('bg-orange-50');
            target.scrollIntoView({ block: 'nearest' });
            activeIdx = idx;
          }
        }

        let debounceTimer: number | null = null;

        input.addEventListener('focus', async () => {
          await ensureIndex();
          if (input.value) {
            renderResults(runSearch(input.value));
          }
        });

        input.addEventListener('input', () => {
          if (debounceTimer) window.clearTimeout(debounceTimer);
          debounceTimer = window.setTimeout(async () => {
            const q = input.value.trim();
            if (q.length === 0) {
              hideResults();
              return;
            }
            // Ensure index is loaded before running search; user may have
            // started typing before the focus handler's fetch completed.
            if (!index) {
              resultsBox!.innerHTML = '<div class="px-4 py-3 text-sm text-slate-500">Loading…</div>';
              resultsBox!.classList.remove('hidden');
              await ensureIndex();
            }
            renderResults(runSearch(q));
          }, 100);
        });

        input.addEventListener('keydown', (e) => {
          if (resultsBox!.classList.contains('hidden')) return;
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            setActive(Math.min(activeIdx + 1, lastResults.length - 1));
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            setActive(Math.max(activeIdx - 1, 0));
          } else if (e.key === 'Enter') {
            e.preventDefault();
            if (activeIdx >= 0 && activeIdx < lastResults.length) {
              window.location.href = lastResults[activeIdx].url;
            } else if (lastResults.length > 0) {
              window.location.href = lastResults[0].url;
            }
          } else if (e.key === 'Escape') {
            hideResults();
            input.blur();
          }
        });

        // Close when clicking outside
        document.addEventListener('click', (e) => {
          if (!input.contains(e.target as Node) && !resultsBox!.contains(e.target as Node)) {
            hideResults();
          }
        });
      })();
    </script>
  </body>
</html>
