---
import '../styles/global.css';
import { tools, verticals } from '../lib/data';

export interface BreadcrumbItem {
  name: string;
  url: string;
}

const toolCount = tools.length;
const verticalCount = verticals.length;

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  breadcrumbs?: BreadcrumbItem[];
}

const { title, description, canonical, ogImage, noindex = false, breadcrumbs } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = ogImage ?? new URL('/og-default.svg', Astro.site).toString();
const fullTitle = title.endsWith('WrenchStack') ? title : `${title} | WrenchStack`;
const isHomepage = Astro.url.pathname === '/';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'WrenchStack',
  url: 'https://wrenchstack.com',
  logo: 'https://wrenchstack.com/logo.png',
  description: 'Independent software comparison directory for trades and field-service businesses.',
  founder: {
    '@type': 'Person',
    name: 'Bilal Elhomsi',
  },
  contactPoint: [
    {
      '@type': 'ContactPoint',
      contactType: 'editorial',
      email: 'hello@wrenchstack.com',
    },
    {
      '@type': 'ContactPoint',
      contactType: 'sales',
      email: 'partners@wrenchstack.com',
    },
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'WrenchStack',
  url: 'https://wrenchstack.com',
  description: 'Independent software comparisons for HVAC, plumbing, electrical, roofing, contractors, landscaping, and other trades.',
  publisher: {
    '@type': 'Organization',
    name: 'WrenchStack',
  },
};

const breadcrumbSchema = breadcrumbs && breadcrumbs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((b, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: b.name,
    item: b.url.startsWith('http') ? b.url : new URL(b.url, Astro.site).toString(),
  })),
} : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="WrenchStack" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {isHomepage && <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />}
    {isHomepage && <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />}
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}

    <link rel="preconnect" href="https://plausible.io" />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
