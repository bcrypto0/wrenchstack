---
import '../styles/global.css';

export interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  breadcrumbs?: BreadcrumbItem[];
}

const { title, description, canonical, ogImage, noindex = false, breadcrumbs } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = ogImage ?? new URL('/og-default.svg', Astro.site).toString();
const fullTitle = title.endsWith('WrenchStack') ? title : `${title} | WrenchStack`;
const isHomepage = Astro.url.pathname === '/';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'WrenchStack',
  url: 'https://wrenchstack.com',
  logo: 'https://wrenchstack.com/logo.svg',
  description: 'Independent software comparison directory for trades and field-service businesses.',
  founder: {
    '@type': 'Person',
    name: 'Bilal Elhomsi',
  },
  contactPoint: [
    {
      '@type': 'ContactPoint',
      contactType: 'editorial',
      email: 'hello@wrenchstack.com',
    },
    {
      '@type': 'ContactPoint',
      contactType: 'sales',
      email: 'partners@wrenchstack.com',
    },
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'WrenchStack',
  url: 'https://wrenchstack.com',
  description: 'Independent software comparisons for HVAC, plumbing, electrical, roofing, contractors, landscaping, and other trades.',
  publisher: {
    '@type': 'Organization',
    name: 'WrenchStack',
  },
};

const breadcrumbSchema = breadcrumbs && breadcrumbs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((b, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: b.name,
    item: b.url.startsWith('http') ? b.url : new URL(b.url, Astro.site).toString(),
  })),
} : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="WrenchStack" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {isHomepage && <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />}
    {isHomepage && <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />}
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}

    <link rel="preconnect" href="https://plausible.io" />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
        <a href="/" class="flex items-center" aria-label="WrenchStack home">
          <img src="/logo.svg" alt="WrenchStack" width="180" height="36" />
        </a>
        <nav class="hidden gap-6 text-sm font-medium text-slate-600 md:flex">
          <a href="/tools/" class="hover:text-slate-900">Tools</a>
          <a href="/compare/" class="hover:text-slate-900">Compare</a>
          <a href="/best-software-for/" class="hover:text-slate-900">Guides</a>
          <a href="/pricing/" class="hover:text-slate-900">Pricing</a>
          <a href="/quiz/" class="font-semibold text-orange-600 hover:text-orange-700">Quiz</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-24 border-t border-slate-200 bg-white">
      <div class="mx-auto max-w-6xl px-4 py-10 text-sm text-slate-600">
        <div class="grid gap-8 md:grid-cols-4">
          <div>
            <div class="mb-2 font-semibold text-slate-900">WrenchStack</div>
            <p class="text-slate-600">
              The trades software directory. 40+ field service platforms compared across 13 verticals, with verified pricing, head-to-head matchups, and buyer guides by team size.
            </p>
          </div>
          <div>
            <div class="mb-2 font-semibold text-slate-900">By trade</div>
            <ul class="space-y-1">
              <li><a href="/hvac/" class="hover:text-slate-900">HVAC</a></li>
              <li><a href="/plumbing/" class="hover:text-slate-900">Plumbing</a></li>
              <li><a href="/electrical/" class="hover:text-slate-900">Electrical</a></li>
              <li><a href="/roofing/" class="hover:text-slate-900">Roofing</a></li>
              <li><a href="/landscaping/" class="hover:text-slate-900">Landscaping</a></li>
              <li><a href="/cleaning/" class="hover:text-slate-900">Cleaning</a></li>
              <li><a href="/pest-control/" class="hover:text-slate-900">Pest control</a></li>
            </ul>
          </div>
          <div>
            <div class="mb-2 font-semibold text-slate-900">Browse</div>
            <ul class="space-y-1">
              <li><a href="/tools/" class="hover:text-slate-900">All tools</a></li>
              <li><a href="/compare/" class="hover:text-slate-900">Compare two tools</a></li>
              <li><a href="/best-software-for/" class="hover:text-slate-900">Buyer guides</a></li>
              <li><a href="/pricing/" class="hover:text-slate-900">Pricing comparison</a></li>
              <li><a href="/quiz/" class="hover:text-slate-900">Matching quiz</a></li>
              <li><a href="/roi-calculator/" class="hover:text-slate-900">ROI calculator</a></li>
            </ul>
          </div>
          <div>
            <div class="mb-2 font-semibold text-slate-900">About</div>
            <ul class="space-y-1">
              <li><a href="/about/" class="hover:text-slate-900">About WrenchStack</a></li>
              <li><a href="/methodology/" class="hover:text-slate-900">How we rank</a></li>
              <li><a href="/disclosure/" class="hover:text-slate-900">Affiliate disclosure</a></li>
              <li><a href="/contact/" class="hover:text-slate-900">Contact</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-8 border-t border-slate-200 pt-4 text-xs text-slate-500">
          © {new Date().getFullYear()} WrenchStack.
        </div>
      </div>
    </footer>
  </body>
</html>
