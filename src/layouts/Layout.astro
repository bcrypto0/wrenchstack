---
import '../styles/global.css';
import { tools, verticals } from '../lib/data';

export interface BreadcrumbItem {
  name: string;
  url: string;
}

const toolCount = tools.length;
const verticalCount = verticals.length;

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  breadcrumbs?: BreadcrumbItem[];
  lang?: string;
  dir?: 'ltr' | 'rtl';
  alternateUrls?: { hreflang: string; href: string }[];
}

const { title, description, canonical, ogImage, noindex = false, breadcrumbs, lang = 'en', dir = 'ltr', alternateUrls = [] } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
// PNG, not SVG: LinkedIn/X/Facebook do not render SVG og:images (the card shows blank).
const ogImageUrl = ogImage ?? new URL('/og-default.png', Astro.site).toString();
const fullTitle = title.endsWith('WrenchStack') ? title : `${title} | WrenchStack`;
const isHomepage = Astro.url.pathname === '/';

// Country/region switcher — detect the active market from the URL path.
const COUNTRIES = [
  { code: 'us', flag: '🇺🇸', label: 'United States', href: '/' },
  { code: 'uk', flag: '🇬🇧', label: 'United Kingdom', href: '/uk/' },
  { code: 'ca', flag: '🇨🇦', label: 'Canada', href: '/ca/' },
  { code: 'au', flag: '🇦🇺', label: 'Australia', href: '/au/' },
  { code: 'nz', flag: '🇳🇿', label: 'New Zealand', href: '/nz/' },
  { code: 'ie', flag: '🇮🇪', label: 'Ireland', href: '/ie/' },
  { code: 'sa', flag: '🇸🇦', label: 'Saudi Arabia', href: '/sa/' },
  { code: 'ae', flag: '🇦🇪', label: 'United Arab Emirates', href: '/ae/' },
  { code: 'qa', flag: '🇶🇦', label: 'Qatar', href: '/qa/' },
  { code: 'kw', flag: '🇰🇼', label: 'Kuwait', href: '/kw/' },
  { code: 'ba', flag: '🇧🇭', label: 'Bahrain', href: '/ba/' },
  { code: 'om', flag: '🇴🇲', label: 'Oman', href: '/om/' },
  { code: 'za', flag: '🇿🇦', label: 'South Africa', href: '/za/' },
  { code: 'fr', flag: '🇫🇷', label: 'France', href: '/fr/' },
  { code: 'ma', flag: '🇲🇦', label: 'Morocco', href: '/ma/' },
  { code: 'jo', flag: '🇯🇴', label: 'Jordan', href: '/jo/' },
  { code: 'eg', flag: '🇪🇬', label: 'Egypt', href: '/eg/' },
];
const intlMatch = Astro.url.pathname.match(/^\/(uk|ca|au|nz|ie|sa|ae|qa|kw|ba|om|za|fr|ma|jo|eg)(?:\/|$)/);
const currentCountryCode = intlMatch ? intlMatch[1] : 'us';
const currentCountry = COUNTRIES.find((c) => c.code === currentCountryCode) ?? COUNTRIES[0];

// Analytics. Both read from build env vars and stay completely inert until set,
// so this is safe to ship before the IDs exist. Cloudflare Web Analytics is
// cookieless (loads unconditionally). GA4 sets cookies, so it loads ONLY after
// the visitor accepts the consent banner (GDPR/UK-GDPR — we now serve UK/IE/FR).
// To activate: set PUBLIC_GA_ID (e.g. 'G-XXXXXXXXXX') and PUBLIC_CF_BEACON in the
// Cloudflare build env, or hardcode the values here.
const GA_MEASUREMENT_ID = import.meta.env.PUBLIC_GA_ID || 'G-S7V98KD153';
const CF_BEACON_TOKEN = import.meta.env.PUBLIC_CF_BEACON || '';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'WrenchStack',
  url: 'https://wrenchstack.com',
  logo: 'https://wrenchstack.com/logo.png',
  description: 'Independent software comparison directory for trades and field-service businesses.',
  contactPoint: [
    {
      '@type': 'ContactPoint',
      contactType: 'editorial',
      email: 'hello@wrenchstack.com',
    },
    {
      '@type': 'ContactPoint',
      contactType: 'sales',
      email: 'partners@wrenchstack.com',
    },
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'WrenchStack',
  url: 'https://wrenchstack.com',
  description: 'Independent software comparisons for HVAC, plumbing, electrical, roofing, contractors, landscaping, and other trades.',
  publisher: {
    '@type': 'Organization',
    name: 'WrenchStack',
  },
};

const breadcrumbSchema = breadcrumbs && breadcrumbs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((b, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: b.name,
    item: b.url.startsWith('http') ? b.url : new URL(b.url, Astro.site).toString(),
  })),
} : null;
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {alternateUrls.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="WrenchStack" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {isHomepage && <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />}
    {isHomepage && <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />}
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}

    {CF_BEACON_TOKEN && (
      <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={`{"token": "${CF_BEACON_TOKEN}"}`}></script>
    )}
