---
import type { Tool } from '../lib/data';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;

// Web3Forms access key. This is a PUBLIC key by design (Web3Forms docs:
// "This is a public key. You can use it in client side code.") so committing
// it is intentional. Form submissions arrive at bilal@wrenchstack.com — the
// email registered with Web3Forms. Honeypot spam-trap (botcheck field below)
// blocks the common bot pattern; abuse can be handled by rotating the key
// in the Web3Forms dashboard.
// Override via PUBLIC_WEB3FORMS_KEY env var if needed (e.g., test vs prod).
const WEB3FORMS_ACCESS_KEY =
  (import.meta.env.PUBLIC_WEB3FORMS_KEY as string | undefined) ??
  'b5170603-ae15-4e9d-b2a3-10e0bef38253';
---

<section id="submit-review" class="mb-10 scroll-mt-8">
  <div class="rounded-lg border-2 border-orange-200 bg-gradient-to-br from-orange-50 to-white p-6">
    <h2 class="mb-2 text-2xl font-bold text-slate-900">Write a review of {tool.name}</h2>
    <p class="mb-6 text-sm text-slate-600 leading-relaxed">
      We hand-moderate every review and verify the reviewer when possible. Your review appears within 1-3 business days of submission (we email you if we need to verify). Reviews help other contractors make better decisions — and they're the one thing G2/Capterra optimize for that WrenchStack hasn't matched yet. Your input changes that.
    </p>

    <form
      id={`review-form-${tool.slug}`}
      action="https://api.web3forms.com/submit"
      method="POST"
      class="space-y-5"
    >
      <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
      <input type="hidden" name="subject" value={`New review submission: ${tool.name}`} />
      <input type="hidden" name="from_name" value="WrenchStack Review Form" />
      <input type="hidden" name="tool_name" value={tool.name} />
      <input type="hidden" name="tool_slug" value={tool.slug} />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for={`rating-${tool.slug}`} class="block text-sm font-semibold text-slate-900">
            Your rating <span class="text-rose-600">*</span>
          </label>
          <select
            id={`rating-${tool.slug}`}
            name="rating"
            required
            class="mt-1 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm focus:border-orange-500 focus:outline-none focus:ring-1 focus:ring-orange-500"
          >
            <option value="">— Select —</option>
            <option value="5">★★★★★ Excellent (5)</option>
            <option value="4">★★★★☆ Good (4)</option>
            <option value="3">★★★☆☆ Average (3)</option>
            <option value="2">★★☆☆☆ Poor (2)</option>
            <option value="1">★☆☆☆☆ Terrible (1)</option>
          </select>
        </div>

        <div>
          <label for={`role-${tool.slug}`} class="block text-sm font-semibold text-slate-900">
            Your role <span class="text-rose-600">*</span>
          </label>
          <select
            id={`role-${tool.slug}`}
            name="reviewer_role"
            required
            class="mt-1 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm focus:border-orange-500 focus:outline-none focus:ring-1 focus:ring-orange-500"
          >
            <option value="">— Select —</option>
            <option value="owner">Owner / Operator</option>
            <option value="manager">Manager / Office Lead</option>
            <option value="tech">Field Tech</option>
            <option value="admin">Office Admin / Dispatcher</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div>
          <label for={`team-${tool.slug}`} class="block text-sm font-semibold text-slate-900">
            Team size <span class="text-rose-600">*</span>
          </label>
          <select
            id={`team-${tool.slug}`}
            name="team_size"
            required
            class="mt-1 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm focus:border-orange-500 focus:outline-none focus:ring-1 focus:ring-orange-500"
          >
            <option value="">— Select —</option>
            <option value="1-3">1-3 users</option>
            <option value="4-10">4-10 users</option>
            <option value="11-25">11-25 users</option>
            <option value="26-50">26-50 users</option>
            <option value="50+">50+ users</option>
          </select>
        </div>

        <div>
          <label for={`vertical-${tool.slug}`} class="block text-sm font-semibold text-slate-900">
            Your trade <span class="text-rose-600">*</span>
          </label>
          <select
            id={`vertical-${tool.slug}`}
            name="vertical"
            required
            class="mt-1 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm focus:border-orange-500 focus:outline-none focus:ring-1 focus:ring-orange-500"
          >
            <option value="">— Select —</option>
            <option value="HVAC">HVAC</option>
            <option value="Plumbing">Plumbing</option>
            <option value="Electrical">Electrical</option>
            <option value="Roofing">Roofing</option>
            <option value="General Contractor">General Contractor</option>
            <option value="Landscaping">Landscaping</option>
            <option value="Cleaning">Cleaning</option>
            <option value="Pest Control">Pest Control</option>
            <option value="Pool Service">Pool Service</option>
            <option value="Locksmith">Locksmith</option>
            <option value="Garage Door">Garage Door</option>
            <option value="Appliance Repair">Appliance Repair</option>
            <option value="Handyman">Handyman</option>
            <option value="Other">Other</option>
          </select>
        </div>
      </div>

      <div>
        <label for={`pros-${tool.slug}`} class="block text-sm font-semibold text-slate-900">
          Pros — what works well <span class="text-rose-600">*</span>
        </label>
        <textarea
          id={`pros-${tool.slug}`}
          name="pros"
          required
          rows="3"
          minlength="40"
          maxlength="600"
          placeholder={`What does ${tool.name} do well? 40-600 characters.`}
          class="mt-1 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm focus:border-orange-500 focus:outline-none focus:ring-1 focus:ring-orange-500"
        ></textarea>
      </div>

      <div>
        <label for={`cons-${tool.slug}`} class="block text-sm font-semibold text-slate-900">
          Cons — what doesn't work <span class="text-rose-600">*</span>
        </label>
        <textarea
          id={`cons-${tool.slug}`}
          name="cons"
          required
          rows="3"
          minlength="40"
          maxlength="600"
          placeholder={`What frustrates you about ${tool.name}? Be specific — that's what makes reviews useful. 40-600 characters.`}
          class="mt-1 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm focus:border-orange-500 focus:outline-none focus:ring-1 focus:ring-orange-500"
        ></textarea>
      </div>

      <div>
        <fieldset>
          <legend class="text-sm font-semibold text-slate-900">Would you recommend {tool.name} to another contractor? <span class="text-rose-600">*</span></legend>
          <div class="mt-2 flex gap-4">
            <label class="inline-flex items-center gap-2">
              <input type="radio" name="would_recommend" value="yes" required class="text-orange-600 focus:ring-orange-500" />
              <span class="text-sm text-slate-700">Yes</span>
            </label>
            <label class="inline-flex items-center gap-2">
              <input type="radio" name="would_recommend" value="no" required class="text-orange-600 focus:ring-orange-500" />
              <span class="text-sm text-slate-700">No</span>
            </label>
          </div>
        </fieldset>
      </div>

      <div>
        <label for={`email-${tool.slug}`} class="block text-sm font-semibold text-slate-900">
          Your email (verification only — never published)
        </label>
        <input
          type="email"
          id={`email-${tool.slug}`}
          name="email"
          placeholder="you@yourcompany.com"
          class="mt-1 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm focus:border-orange-500 focus:outline-none focus:ring-1 focus:ring-orange-500"
        />
        <p class="mt-1 text-xs text-slate-500">
          Optional but recommended. Using your company email helps us mark you as a verified buyer.
        </p>
      </div>

      <div>
        <label for={`name-${tool.slug}`} class="block text-sm font-semibold text-slate-900">
          Your name or company (optional — shown publicly if provided)
        </label>
        <input
          type="text"
          id={`name-${tool.slug}`}
          name="display_name"
          maxlength="60"
          placeholder="e.g. Mike S., Owner at Acme HVAC"
          class="mt-1 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm focus:border-orange-500 focus:outline-none focus:ring-1 focus:ring-orange-500"
        />
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <button
          type="submit"
          class="rounded-md bg-orange-500 px-6 py-3 text-sm font-semibold text-white hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2"
        >
          Submit review →
        </button>
        <p class="text-xs text-slate-500">
          We moderate within 1-3 business days. By submitting you confirm this is your honest experience.
        </p>
      </div>

      <div id={`review-status-${tool.slug}`} class="hidden rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-900">
        Thanks — your review was submitted. We'll moderate it and publish within 1-3 business days. If we need to verify, we'll email you at the address above.
      </div>
    </form>

    <script define:vars={{ slug: tool.slug }}>
      // Intercept the form submission to show inline success message instead of
      // redirecting to Web3Forms' success page. This keeps users on the tool review.
      const form = document.getElementById('review-form-' + slug);
      const status = document.getElementById('review-status-' + slug);
      if (form && status) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const fd = new FormData(form);
          // Spam-trap check
          if (fd.get('botcheck')) return;
          try {
            const res = await fetch(form.action, {
              method: 'POST',
              body: fd,
              headers: { Accept: 'application/json' },
            });
            const data = await res.json();
            if (data.success) {
              form.reset();
              form.style.display = 'none';
              status.classList.remove('hidden');
            } else {
              alert('Submission failed: ' + (data.message || 'unknown error'));
            }
          } catch (err) {
            alert('Submission failed — please email hello@wrenchstack.com instead.');
          }
        });
      }
    </script>
  </div>
</section>
