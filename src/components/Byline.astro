---
interface Props {
  updatedDate?: string;
  readingMinutes?: number;
}

const { updatedDate, readingMinutes } = Astro.props;
const formattedDate = updatedDate
  ? new Date(updatedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
const showSeparator = formattedDate && readingMinutes;
---

<div class="mb-6 flex flex-wrap items-center gap-x-2 gap-y-1 border-y border-slate-200 py-3 text-sm text-slate-500">
  {formattedDate && (
    <span>Last updated <time>{formattedDate}</time></span>
  )}
  {showSeparator && <span aria-hidden="true">·</span>}
  {readingMinutes && (
    <span>{readingMinutes} min read</span>
  )}
</div>
