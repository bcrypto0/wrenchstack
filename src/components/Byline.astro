---
interface Props {
  updatedDate?: string;
  nextReviewDate?: string;
  readingMinutes?: number;
}

const { updatedDate, nextReviewDate, readingMinutes } = Astro.props;
const fmt = (d: string) => new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<div class="mb-6 border-y border-slate-200 py-3 text-sm text-slate-500">
  <div class="font-medium text-slate-700">
    By the <a href="/about/" class="underline decoration-slate-300 underline-offset-2 hover:text-orange-600 hover:decoration-orange-400">WrenchStack editorial desk</a>
    <span aria-hidden="true" class="text-slate-300">·</span>
    <a href="/methodology/" class="underline decoration-slate-300 underline-offset-2 hover:text-orange-600 hover:decoration-orange-400">Independent — no vendor pays for placement</a>
  </div>
  <div class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-1">
    {updatedDate && (
      <span>Last updated <time>{fmt(updatedDate)}</time></span>
    )}
    {nextReviewDate && (
      <>{updatedDate && <span aria-hidden="true">·</span>}<span>Next review <time>{fmt(nextReviewDate)}</time></span></>
    )}
    {readingMinutes && (
      <>{(updatedDate || nextReviewDate) && <span aria-hidden="true">·</span>}<span>{readingMinutes} min read</span></>
    )}
  </div>
</div>
