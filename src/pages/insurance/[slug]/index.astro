---
import Layout from '../../../layouts/Layout.astro';
import {
  insuranceProviders,
  insuranceTier,
  type InsuranceProvider,
  verticals,
  verticalToUrl,
} from '../../../lib/data';

export async function getStaticPaths() {
  return insuranceProviders.map((p) => ({
    params: { slug: p.slug },
    props: { provider: p },
  }));
}

interface Props {
  provider: InsuranceProvider;
}

const { provider } = Astro.props;
const tier = insuranceTier(provider);

const providerVerticals = provider.verticals
  .map((v) => verticals.find((x) => x.slug === v))
  .filter((v): v is NonNullable<typeof v> => !!v);

const siblings = insuranceProviders.filter((p) => p.slug !== provider.slug).slice(0, 6);

const pageTitle = `${provider.name} Review (2026): Coverage, Pricing, Pros & Cons`;
const pageDescription = `${provider.name} review for trades contractors. ${provider.tagline}. ${provider.reputation_flag ? 'Includes documented reputation context. ' : ''}Updated ${new Date().getFullYear()}.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Insurance', url: '/insurance/' },
  { name: provider.name, url: `/insurance/${provider.slug}/` },
];

const tierMeta = {
  S: { label: 'Tier S', color: 'bg-emerald-100 text-emerald-900 ring-emerald-300' },
  A: { label: 'Tier A', color: 'bg-blue-100 text-blue-900 ring-blue-300' },
  F: { label: 'Tier F — reputation warning applies', color: 'bg-rose-100 text-rose-900 ring-rose-300' },
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'InsuranceAgency',
  name: provider.name,
  description: provider.tagline,
  url: provider.vendor_url,
  areaServed: { '@type': 'Country', name: 'United States' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: provider.provider_faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <article class="mx-auto max-w-4xl px-4 py-12">
    <header class="mb-8">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-orange-600">
        Insurance · {tier === 'S' ? 'Recommended' : tier === 'A' ? 'Workable depending on profile' : 'Reputation warning applies'}
      </p>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">{provider.name} Review</h1>
      <p class="mt-3 text-lg italic text-slate-600">{provider.tagline}</p>

      <div class="mt-5 flex flex-wrap items-center gap-2">
        <span class={`inline-block rounded-full px-3 py-1 text-xs font-bold ring-1 ${tierMeta[tier].color}`}>{tierMeta[tier].label}</span>
        <span class="inline-block rounded-full bg-slate-100 px-3 py-1 text-xs font-bold uppercase tracking-wider text-slate-700">{provider.provider_type.replace(/-/g, ' ')}</span>
        <span class="inline-block rounded-full bg-slate-100 px-3 py-1 text-xs font-bold uppercase tracking-wider text-slate-700">{provider.distribution_model.replace(/-/g, ' ')}</span>
      </div>

      <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm text-slate-600">
        <span>Founded {provider.founded}</span>
        <span>HQ {provider.headquartered}</span>
        <span>Quote speed: {provider.quote_speed}</span>
        <span>Verified: {provider.verified_date}</span>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href={provider.affiliate_url.startsWith('http') ? provider.affiliate_url : provider.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">Visit {provider.name} →</a>
        <a href="/insurance/" class="rounded-md border border-slate-300 bg-white px-4 py-3 text-sm font-medium text-slate-700 hover:bg-slate-50">See all providers</a>
      </div>
    </header>

    {provider.reputation_flag && (
      <section class="mb-10 rounded-lg border-2 border-rose-300 bg-rose-50 p-6">
        <div class="mb-2 flex items-center gap-2">
          <span class="text-xl">⚠</span>
          <h2 class="text-lg font-bold text-rose-900">Reputation warning</h2>
        </div>
        <p class="text-sm text-rose-900 leading-relaxed">{provider.reputation_flag}</p>
      </section>
    )}

    <nav class="mb-8 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 md:sticky md:top-2 md:z-30 md:bg-white/95 md:backdrop-blur">
      <div class="text-xs font-semibold uppercase tracking-wider text-slate-700">Jump to</div>
      <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-sm">
        <a href="#how-it-works" class="text-orange-600 hover:underline">How it works</a>
        <span class="text-slate-300">·</span>
        <a href="#pros-cons" class="text-orange-600 hover:underline">Pros & Cons</a>
        <span class="text-slate-300">·</span>
        <a href="#coverage" class="text-orange-600 hover:underline">Coverage</a>
        <span class="text-slate-300">·</span>
        <a href="#ratings" class="text-orange-600 hover:underline">Ratings</a>
        <span class="text-slate-300">·</span>
        <a href="#faqs" class="text-orange-600 hover:underline">FAQs</a>
      </div>
    </nav>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-lg font-bold text-slate-900">Quick verdict</h2>
      <p class="text-slate-700 leading-relaxed">
        <strong class="text-slate-900">{provider.name}</strong> is best for {provider.best_for}. Quote speed: {provider.quote_speed}. Pricing: {provider.typical_premium_range}. {provider.weaknesses}.
      </p>
    </section>

    <section class="mb-10 prose prose-slate max-w-none">
      <h2>About {provider.name}</h2>
      {provider.long_description.split('\n\n').map((p) => <p>{p}</p>)}
    </section>

    <section id="how-it-works" class="mb-10 scroll-mt-8">
      <h2 class="mb-3 text-2xl font-bold text-slate-900">How it works</h2>
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <p class="text-slate-700 leading-relaxed">{provider.how_it_works}</p>
      </div>
    </section>

    <section id="pros-cons" class="mb-10 scroll-mt-8">
      <h2 class="mb-5 text-2xl font-bold text-slate-900">Pros & cons</h2>

      <div class="mb-6">
        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-emerald-700">What works</h3>
        <ul class="space-y-3">
          {provider.pros_detail.map((p) => (
            <li class="rounded-lg border-l-4 border-emerald-400 bg-emerald-50 px-4 py-3">
              <p class="font-semibold text-emerald-900">{p.title}</p>
              <p class="mt-1 text-sm text-emerald-900 leading-relaxed">{p.explanation}</p>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-rose-700">What doesn't</h3>
        <ul class="space-y-3">
          {provider.cons_detail.map((c) => (
            <li class="rounded-lg border-l-4 border-rose-400 bg-rose-50 px-4 py-3">
              <p class="font-semibold text-rose-900">{c.title}</p>
              <p class="mt-1 text-sm text-rose-900 leading-relaxed">{c.explanation}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section id="coverage" class="mb-10 scroll-mt-8">
      <h2 class="mb-3 text-2xl font-bold text-slate-900">Coverage</h2>
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <dl class="grid grid-cols-1 gap-3 text-sm sm:grid-cols-2">
          <div>
            <dt class="text-xs uppercase tracking-wider text-slate-500">Insurance lines</dt>
            <dd class="mt-1 flex flex-wrap gap-1">
              {provider.insurance_lines.map((line) => (
                <span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs">{line.replace(/_/g, ' ')}</span>
              ))}
            </dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-wider text-slate-500">Geographic coverage</dt>
            <dd class="mt-1 text-slate-700">{provider.states_note}</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-wider text-slate-500">Typical premium range</dt>
            <dd class="mt-1 text-slate-700">{provider.typical_premium_range}</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-wider text-slate-500">Quote speed</dt>
            <dd class="mt-1 text-slate-700">{provider.quote_speed}</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-wider text-slate-500">Trade coverage</dt>
            <dd class="mt-1 flex flex-wrap gap-1">
              {providerVerticals.map((v) => (
                <a href={`/${verticalToUrl(v.slug)}/`} class="rounded-md bg-slate-100 px-2 py-0.5 text-xs hover:bg-orange-100 hover:text-orange-700">{v.name}</a>
              ))}
            </dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-wider text-slate-500">Affiliate program</dt>
            <dd class="mt-1 text-slate-700">
              <strong class="text-slate-900">{provider.affiliate_program === 'none' ? 'None' : provider.affiliate_program === 'unknown' ? 'Unknown' : provider.affiliate_program}.</strong>
              {' '}{provider.affiliate_payout_note}.
            </dd>
          </div>
        </dl>
      </div>
    </section>

    <section id="ratings" class="mb-10 scroll-mt-8">
      <h2 class="mb-3 text-2xl font-bold text-slate-900">External ratings & sentiment</h2>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-4">
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <p class="text-xs uppercase tracking-wider text-slate-500">Trustpilot</p>
          <p class="mt-1 text-2xl font-bold text-slate-900">{provider.ratings.trustpilot !== null ? `${provider.ratings.trustpilot.toFixed(1)} / 5` : '—'}</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <p class="text-xs uppercase tracking-wider text-slate-500">BBB</p>
          <p class="mt-1 text-base font-semibold text-slate-900">{provider.ratings.bbb ?? '—'}</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <p class="text-xs uppercase tracking-wider text-slate-500">A.M. Best</p>
          <p class="mt-1 text-base font-semibold text-slate-900">{provider.ratings.am_best ?? '—'}</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <p class="text-xs uppercase tracking-wider text-slate-500">Reddit</p>
          <p class="mt-1 text-xs font-semibold text-slate-900">{provider.ratings.reddit_sentiment}</p>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-10 scroll-mt-8">
      <h2 class="mb-5 text-2xl font-bold text-slate-900">Frequently asked</h2>
      <div class="space-y-3">
        {provider.provider_faqs.map((f) => (
          <details class="rounded-lg border border-slate-200 bg-white p-4">
            <summary class="cursor-pointer font-semibold text-slate-900">{f.q}</summary>
            <p class="mt-3 text-slate-700 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="mb-10">
      <h2 class="mb-5 text-2xl font-bold text-slate-900">Other insurance providers</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {siblings.map((s) => {
          const sTier = insuranceTier(s);
          const sBadge = sTier === 'S' ? 'bg-emerald-50 text-emerald-700' : sTier === 'F' ? 'bg-rose-50 text-rose-700' : 'bg-blue-50 text-blue-700';
          return (
            <a href={`/insurance/${s.slug}/`} class="block rounded-lg border border-slate-200 bg-white p-4 no-underline transition hover:border-orange-300 hover:bg-orange-50">
              <div class="mb-1 flex items-center justify-between">
                <p class="font-semibold text-slate-900">{s.name}</p>
                <span class={`rounded px-1.5 py-0.5 text-[10px] font-bold uppercase ${sBadge}`}>Tier {sTier}</span>
              </div>
              <p class="text-xs text-slate-500 line-clamp-2">{s.tagline}</p>
            </a>
          );
        })}
      </div>
    </section>

    <section class="rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Browse more</h2>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/insurance/" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">All insurance providers</a>
        <a href="/lead-gen/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">Lead-gen platforms</a>
        <a href="/tools/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Software directory</a>
      </div>
    </section>
  </article>
</Layout>
