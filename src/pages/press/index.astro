---
import Layout from '../../layouts/Layout.astro';
import { tools, verticals, leadGenPlatforms, insuranceProviders, payrollServices, marketingAgencies } from '../../lib/data';

const totalVendorCount = tools.length + leadGenPlatforms.length + insuranceProviders.length + payrollServices.length + marketingAgencies.length;
const categoryCount = 5;
const verticalCount = verticals.length;
const reputationFlagCount = [...leadGenPlatforms, ...insuranceProviders, ...marketingAgencies].filter(v => 'reputation_flag' in v && v.reputation_flag !== null).length;

const pageTitle = 'Press & Media Room — WrenchStack';
const pageDescription = 'Press kit, media assets, fact sheet, and editorial contacts for journalists covering trades-contractor vendors, trades software, and the trades-industry research market.';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Press', url: '/press/' },
];

// Recent citation log — empty until we land first citations. Structure ready.
const citations: Array<{ outlet: string; title: string; date: string; url: string }> = [];
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <article class="mx-auto max-w-4xl px-4 py-12">

    <header class="mb-10">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-orange-600">Press & Media</p>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">
        Press Room
      </h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        Resources for journalists, industry analysts, and trade publication editors covering WrenchStack — and the trades-contractor vendor landscape we research.
      </p>
    </header>

    <section class="mb-12 rounded-lg border-2 border-slate-200 bg-slate-50 p-6">
      <h2 class="mb-4 text-lg font-bold text-slate-900">Press contact</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        For interviews, expert commentary, data licensing, embargo arrangements, and media inquiries:
      </p>
      <p class="mt-3 text-base">
        <a href="mailto:press@wrenchstack.com" class="font-semibold text-orange-600 hover:underline">press@wrenchstack.com</a>
      </p>
      <p class="mt-2 text-xs text-slate-500">
        We respond to press inquiries within 1 business day. Tight deadlines accommodated when possible.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">About WrenchStack — boilerplate</h2>
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <p class="text-slate-700 leading-relaxed">
          WrenchStack is an independent research desk covering trades-contractor vendors across {categoryCount} categories: field service software, lead-generation platforms, business insurance, payroll services, and marketing agencies. The platform publishes the WrenchStack Fit Score™ methodology and per-vendor affiliate disclosure for every recommendation, evaluating {totalVendorCount}+ vendors across {verticalCount} trade verticals. Headquartered in the United States with international expansion to UK, Canada, Australia, New Zealand, and Ireland markets.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <button onclick="navigator.clipboard.writeText(document.querySelector('.boilerplate-text').textContent.trim()); this.textContent = 'Copied!'; setTimeout(() => this.textContent = 'Copy boilerplate', 2000)" class="rounded-md bg-orange-500 px-3 py-1.5 text-xs font-semibold text-white hover:bg-orange-600">Copy boilerplate</button>
        </div>
        <span class="boilerplate-text hidden">WrenchStack is an independent research desk covering trades-contractor vendors across {categoryCount} categories: field service software, lead-generation platforms, business insurance, payroll services, and marketing agencies. The platform publishes the WrenchStack Fit Score™ methodology and per-vendor affiliate disclosure for every recommendation, evaluating {totalVendorCount}+ vendors across {verticalCount} trade verticals. Headquartered in the United States with international expansion to UK, Canada, Australia, New Zealand, and Ireland markets.</span>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">Fact sheet</h2>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <p class="text-xs uppercase tracking-wider text-slate-500">Founded</p>
          <p class="mt-1 font-semibold text-slate-900">2026</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <p class="text-xs uppercase tracking-wider text-slate-500">Coverage</p>
          <p class="mt-1 font-semibold text-slate-900">{totalVendorCount}+ vendors · {categoryCount} categories · {verticalCount} trade verticals</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <p class="text-xs uppercase tracking-wider text-slate-500">Methodology</p>
          <p class="mt-1 font-semibold text-slate-900">WrenchStack Fit Score™ v1.0 (effective 2026-05-29)</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <p class="text-xs uppercase tracking-wider text-slate-500">Reputation flags issued</p>
          <p class="mt-1 font-semibold text-slate-900">{reputationFlagCount} vendors with documented concerns</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <p class="text-xs uppercase tracking-wider text-slate-500">Categories</p>
          <p class="mt-1 text-sm text-slate-700">Software · Lead-gen · Insurance · Payroll · Marketing agencies</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <p class="text-xs uppercase tracking-wider text-slate-500">Geographic markets</p>
          <p class="mt-1 text-sm text-slate-700">US (live) · UK, CA, AU, NZ, IE (in expansion)</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <p class="text-xs uppercase tracking-wider text-slate-500">Editorial pages</p>
          <p class="mt-1 font-semibold text-slate-900">2,800+</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <p class="text-xs uppercase tracking-wider text-slate-500">Update cadence</p>
          <p class="mt-1 text-sm text-slate-700">Pricing quarterly · features semi-annually · ratings each refresh</p>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">Citation guidance</h2>
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <p class="mb-3 text-sm text-slate-700 leading-relaxed">
          When citing WrenchStack research, please use this format:
        </p>
        <div class="rounded-md bg-slate-50 px-4 py-3 font-mono text-sm text-slate-800">
          WrenchStack 2026 [Topic] Index. WrenchStack Research. https://wrenchstack.com/research/[slug]/
        </div>
        <p class="mt-4 text-sm text-slate-700 leading-relaxed">
          For methodology citations, please reference: <em>WrenchStack Fit Score™ Methodology v1.0, effective May 29, 2026. WrenchStack Research. <a href="/methodology/" class="text-orange-600 hover:underline">https://wrenchstack.com/methodology/</a></em>
        </p>
        <p class="mt-3 text-xs text-slate-500">
          For interview quotes or exclusive data, please email <a href="mailto:press@wrenchstack.com" class="underline">press@wrenchstack.com</a> in advance of publication so we can verify accuracy and provide context.
        </p>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">Brand assets</h2>
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <h3 class="mb-3 text-base font-bold text-slate-900">Logo</h3>
        <div class="flex flex-wrap items-center gap-6 rounded-md bg-slate-50 px-6 py-4">
          <img src="/logo.png" alt="WrenchStack logo" class="h-11 w-auto" />
        </div>
        <p class="mt-3 text-sm text-slate-700">
          For high-resolution logo files (SVG, PNG light/dark), email <a href="mailto:press@wrenchstack.com" class="text-orange-600 hover:underline">press@wrenchstack.com</a>.
        </p>

        <h3 class="mt-6 mb-3 text-base font-bold text-slate-900">Brand colors</h3>
        <div class="flex flex-wrap gap-3">
          <div class="flex items-center gap-2 rounded-md border border-slate-200 px-3 py-2">
            <span class="inline-block h-5 w-5 rounded bg-orange-500"></span>
            <span class="font-mono text-xs">#F97316 — Orange</span>
          </div>
          <div class="flex items-center gap-2 rounded-md border border-slate-200 px-3 py-2">
            <span class="inline-block h-5 w-5 rounded bg-slate-900"></span>
            <span class="font-mono text-xs">#0F172A — Slate</span>
          </div>
          <div class="flex items-center gap-2 rounded-md border border-slate-200 px-3 py-2">
            <span class="inline-block h-5 w-5 rounded bg-emerald-500"></span>
            <span class="font-mono text-xs">#10B981 — Emerald</span>
          </div>
        </div>

        <h3 class="mt-6 mb-3 text-base font-bold text-slate-900">Typography</h3>
        <p class="text-sm text-slate-700">System sans-serif stack (Inter / SF Pro / Segoe UI / Roboto)</p>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">Research products</h2>
      <p class="mb-4 text-sm text-slate-600 leading-relaxed">
        Recent research publications available for journalist reference and citation:
      </p>
      <div class="space-y-3">
        <a href="/trends-2026/" class="block rounded-lg border border-slate-200 bg-white p-4 no-underline hover:border-orange-300 hover:bg-orange-50">
          <p class="font-semibold text-slate-900">Trades Software Market Report 2026</p>
          <p class="mt-1 text-sm text-slate-600">15 data findings from analysis of {tools.length} platforms — pricing distribution, integration prevalence, founded-year cohorts, vertical density.</p>
        </a>
        <a href="/awards/2026/" class="block rounded-lg border border-slate-200 bg-white p-4 no-underline hover:border-orange-300 hover:bg-orange-50">
          <p class="font-semibold text-slate-900">WrenchStack Awards 2026</p>
          <p class="mt-1 text-sm text-slate-600">18 editorial categories of recognition across software, with full methodology and per-category winner rationale.</p>
        </a>
        <a href="/methodology/" class="block rounded-lg border border-slate-200 bg-white p-4 no-underline hover:border-orange-300 hover:bg-orange-50">
          <p class="font-semibold text-slate-900">WrenchStack Fit Score™ Methodology v1.0</p>
          <p class="mt-1 text-sm text-slate-600">Published methodology documenting scoring rubric, evaluation timeline, weights, and independence statement.</p>
        </a>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">In the news</h2>
      {citations.length > 0 ? (
        <div class="space-y-3">
          {citations.map(c => (
            <a href={c.url} target="_blank" rel="noopener" class="block rounded-lg border border-slate-200 bg-white p-4 no-underline hover:border-orange-300 hover:bg-orange-50">
              <p class="font-semibold text-slate-900">{c.title}</p>
              <p class="mt-1 text-sm text-slate-600">{c.outlet} · {c.date}</p>
            </a>
          ))}
        </div>
      ) : (
        <div class="rounded-lg border border-dashed border-slate-300 bg-slate-50 p-6 text-center">
          <p class="text-sm text-slate-600">
            Citations and media coverage will be published here as they occur.
          </p>
          <p class="mt-2 text-xs text-slate-500">
            Cited WrenchStack in your publication? Email <a href="mailto:press@wrenchstack.com" class="underline">press@wrenchstack.com</a> with the link.
          </p>
        </div>
      )}
    </section>

    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">Expert commentary available on</h2>
      <p class="mb-4 text-sm text-slate-600 leading-relaxed">
        Journalists can reach out for expert commentary, exclusive data, or background interviews on the following topics:
      </p>
      <ul class="grid gap-2 sm:grid-cols-2 text-sm text-slate-700">
        <li class="rounded-md bg-slate-50 px-3 py-2">Trades-contractor software market trends</li>
        <li class="rounded-md bg-slate-50 px-3 py-2">Lead-generation platform reputation patterns</li>
        <li class="rounded-md bg-slate-50 px-3 py-2">Contractor insurance market structure</li>
        <li class="rounded-md bg-slate-50 px-3 py-2">FSM platform pricing trends and benchmarks</li>
        <li class="rounded-md bg-slate-50 px-3 py-2">Payroll and HR for trades businesses</li>
        <li class="rounded-md bg-slate-50 px-3 py-2">Marketing agency landscape for home services</li>
        <li class="rounded-md bg-slate-50 px-3 py-2">FTC actions affecting trades-industry vendors</li>
        <li class="rounded-md bg-slate-50 px-3 py-2">International trades-industry differences (UK/CA/AU/NZ)</li>
      </ul>
    </section>

    <section class="rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Request data or interview</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">
        WrenchStack has proprietary data on vendor pricing, ratings, and trade-vertical adoption that's not published on the public site. For exclusive data, custom segments, or interview availability, reach the press desk directly.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="mailto:press@wrenchstack.com" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">Email press desk →</a>
        <a href="/methodology/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">Read methodology</a>
        <a href="/trends-2026/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Latest research</a>
      </div>
    </section>
  </article>
</Layout>
