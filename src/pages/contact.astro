---
import Layout from '../layouts/Layout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Contact', url: '/contact/' },
];
---

<Layout
  title="Contact WrenchStack"
  description="Get in touch with WrenchStack. Email addresses for general inquiries, partnerships, and press."
  breadcrumbs={breadcrumbs}
>
  <article class="mx-auto max-w-2xl px-4 py-16">
    <h1 class="text-4xl font-bold tracking-tight text-slate-900">Contact</h1>

    <div class="mt-8 space-y-3 text-lg text-slate-700">
      <p>
        <a href="mailto:hello@wrenchstack.com" class="font-semibold text-orange-600 hover:underline">hello@wrenchstack.com</a>
      </p>
      <p>
        <a href="mailto:partners@wrenchstack.com" class="font-semibold text-orange-600 hover:underline">partners@wrenchstack.com</a>
        <span class="text-sm text-slate-500"> · affiliate program inquiries</span>
      </p>
      <p>
        <a href="mailto:press@wrenchstack.com" class="font-semibold text-orange-600 hover:underline">press@wrenchstack.com</a>
        <span class="text-sm text-slate-500"> · media</span>
      </p>
    </div>
  </article>
</Layout>
