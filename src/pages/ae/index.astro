---
import Layout from '../../layouts/Layout.astro';
import aeData from '../../data/international/ae.json';

interface AeVendor {
  slug: string; name: string; category: string; vendor_url: string;
  tagline: string; market_position: string; ae_specific_note?: string | null;
  tier: 'S' | 'A' | 'F'; reputation_flag: string | null;
  pros: string[]; cons: string[]; typical_pricing: string;
  is_cross_market: boolean; cross_market_link: string | null;
}

const vendors = (aeData as { vendors: AeVendor[] }).vendors;
const categories = ['software', 'certification'];
const categoryMeta: Record<string, { label: string; description: string }> = {
  'software': { label: 'Construction & trades software', description: 'Giga-project platforms (Oracle Aconex, Primavera, Autodesk — central to Dubai’s BIM mandate), strong global PM (Procore, Bentley, PlanRadar), UAE-VAT-ready ERPs (First Bit, Focus Softnet, PACT, Sage), affordable SMB stacks (Zoho), and CAFM/field-service tools (Horizon FMS, FSM Grid).' },
  'certification': { label: 'Licensing & compliance', description: 'Dubai Municipality contractor classification (now reshaped by Dubai Law No. 7 of 2025), federal MOEI registration, the 5% VAT (FTA), the upcoming Peppol e-invoicing mandate, Emiratisation (MOHRE/Nafis), Abu Dhabi’s Estidama, and the Dubai BIM mandate.' },
};
const vendorsByCategory: Record<string, AeVendor[]> = {};
categories.forEach(c => { vendorsByCategory[c] = vendors.filter(v => v.category === c); });

const pageTitle = 'UAE Construction & Trades Software — WrenchStack';
const pageDescription = `Independent directory of ${vendors.length} construction & trades vendors for the UAE: BIM/PM platforms, UAE-VAT-ready ERPs, and field-service tools — plus Dubai Municipality classification, the FTA 5% VAT, Peppol e-invoicing, Emiratisation and Estidama compliance.`;
const breadcrumbs = [ { name: 'Home', url: '/' }, { name: 'UAE', url: '/ae/' } ];
---
<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <article class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-10">
      <div class="mb-3 flex items-center gap-2">
        <span class="text-2xl" aria-hidden="true">🇦🇪</span>
        <p class="text-sm font-semibold uppercase tracking-wider text-orange-600">United Arab Emirates · الإمارات العربية المتحدة</p>
      </div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">UAE Construction & Trades Software Directory</h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        Independent reviews of {vendors.length} UAE-relevant vendors across Dubai and Abu Dhabi — BIM and project platforms (Oracle Aconex, Autodesk, Procore), UAE-VAT-ready ERPs (First Bit, Focus Softnet, Sage, Zoho Books) and field-service tools — with the local compliance context (Dubai Municipality classification, the FTA 5% VAT, the coming Peppol e-invoicing mandate, Emiratisation, Estidama and Dubai’s BIM mandate) that off-the-shelf US software ignores.
      </p>
    </header>
    <section class="mb-10 grid gap-3 grid-cols-2 sm:grid-cols-4">
      {categories.map(c => (
        <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
          <div class="text-2xl font-bold text-slate-900">{vendorsByCategory[c].length}</div>
          <div class="mt-1 text-xs text-slate-600 capitalize">{c}</div>
        </div>
      ))}
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center"><div class="text-2xl font-bold text-slate-900">5%</div><div class="mt-1 text-xs text-slate-600">VAT (FTA)</div></div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center"><div class="text-2xl font-bold text-slate-900">2</div><div class="mt-1 text-xs text-slate-600">emirate regulators</div></div>
    </section>
    <section class="mb-10 flex flex-wrap items-center justify-between gap-4 rounded-lg border border-orange-200 bg-orange-50 p-5">
      <div>
        <h2 class="text-base font-bold text-slate-900">Deciding between two options?</h2>
        <p class="mt-1 text-sm text-slate-700">See UAE vendors compared side by side — verdict, pros and cons, UAE-specific notes, and pricing, head to head.</p>
      </div>
      <a href="/ae/compare/" class="shrink-0 rounded-md bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-700">Compare UAE vendors →</a>
    </section>
    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-base font-bold text-slate-900">What’s different about choosing software in the UAE</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        The UAE differs from both the US and Saudi. <strong>VAT is 5%, not 15%</strong> — a Saudi-tuned product will mis-rate every invoice, so pick FTA-correct software. <strong>E-invoicing isn’t mandatory yet</strong>, and the model is a decentralised <strong>Peppol</strong> approach (large taxpayers from Jan 2027) — not Saudi’s live ZATCA clearance; buy "Peppol-ready," don’t gate on it. Labour rules run on <strong>Emiratisation</strong> (MOHRE quotas + Nafis subsidies), not Nitaqat. And compliance splits by emirate: <strong>Dubai Municipality</strong> (reshaped by Dubai Law No. 7 of 2025) vs <strong>Abu Dhabi DMT</strong> with its mandatory <strong>Estidama Pearl</strong> rating — so workflows often need per-emirate configuration. Dubai’s <strong>BIM mandate</strong> (since Jan 2024) is driving BIM down the supply chain.
      </p>
    </section>
    {categories.map(c => {
      const cat = categoryMeta[c];
      const cv = vendorsByCategory[c];
      if (cv.length === 0) return null;
      return (
        <section class="mb-12">
          <div class="mb-5">
            <h2 class="text-2xl font-bold text-slate-900">{cat.label}</h2>
            <p class="mt-1 text-sm text-slate-600 leading-relaxed">{cat.description}</p>
          </div>
          <div class="space-y-4">
            {cv.map(v => {
              const isCert = v.category === 'certification';
              const tierColor = v.tier === 'S' ? 'border-emerald-300' : v.tier === 'F' ? 'border-rose-300' : 'border-blue-300';
              const tierLabel = isCert ? 'Official body' : v.tier === 'S' ? 'Recommended' : v.tier === 'F' ? 'Reputation warning' : 'Workable';
              const tierBadge = v.tier === 'S' ? 'bg-emerald-100 text-emerald-900' : v.tier === 'F' ? 'bg-rose-100 text-rose-900' : 'bg-blue-100 text-blue-900';
              return (
                <article class={`rounded-lg border-2 ${tierColor} bg-white p-5`}>
                  <div class="mb-3 flex items-start justify-between gap-3">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center gap-2 mb-1 flex-wrap">
                        <h3 class="text-xl font-bold text-slate-900">{v.name}</h3>
                        <span class={`rounded-full px-2 py-0.5 text-xs font-bold ${tierBadge}`}>{isCert ? tierLabel : `Tier ${v.tier} · ${tierLabel}`}</span>
                        {v.is_cross_market && (<span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">Cross-market</span>)}
                      </div>
                      <p class="text-sm italic text-slate-500">{v.tagline}</p>
                    </div>
                  </div>
                  <p class="mb-3 text-sm text-slate-700 leading-relaxed">{v.market_position}</p>
                  {v.ae_specific_note && (
                    <div class="mb-3 rounded-md bg-slate-50 px-4 py-3">
                      <p class="text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">UAE-specific note</p>
                      <p class="text-sm text-slate-700 leading-relaxed">{v.ae_specific_note}</p>
                    </div>
                  )}
                  <div class="mb-3 grid gap-3 sm:grid-cols-2">
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider text-emerald-700 mb-1">{isCert ? 'What it covers' : 'Pros'}</p>
                      <ul class="space-y-1 text-sm text-slate-700">{v.pros.slice(0, 4).map(p => <li class="leading-snug">+ {p}</li>)}</ul>
                    </div>
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider text-rose-700 mb-1">{isCert ? 'Watch out for' : 'Cons'}</p>
                      <ul class="space-y-1 text-sm text-slate-700">{v.cons.slice(0, 4).map(con => <li class="leading-snug">− {con}</li>)}</ul>
                    </div>
                  </div>
                  <div class="mb-3 text-xs text-slate-600"><strong class="text-slate-900">{isCert ? 'Cost / access:' : 'Typical UAE pricing:'}</strong> {v.typical_pricing}</div>
                  <div class="flex flex-wrap gap-2">
                    <a href={`/ae/${v.slug}/`} class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700">Full UAE review →</a>
                    <a href={v.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md bg-orange-500 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600">{isCert ? 'Official site' : `Visit ${v.name}`} →</a>
                    {v.cross_market_link && (<a href={v.cross_market_link} class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Full review (US market context)</a>)}
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      );
    })}
    <section class="mt-12 rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Are you a UAE software vendor?</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">If you build construction, ERP, accounting or field-service software for the UAE/Gulf market and want to be reviewed or featured, get in touch through our <a href="/for-vendors/" class="underline">vendor program</a>.</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/for-vendors/" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">Work with us →</a>
        <a href="/sa/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">🇸🇦 Saudi directory</a>
        <a href="/methodology/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Methodology</a>
      </div>
    </section>
  </article>
</Layout>
