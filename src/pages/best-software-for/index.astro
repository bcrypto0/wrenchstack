---
import Layout from '../../layouts/Layout.astro';
import useCasesData from '../../data/use_cases.json';

interface UseCase {
  slug: string;
  h1: string;
  meta_description: string;
  buyer_profile: string;
}

const useCases: UseCase[] = useCasesData.use_cases as UseCase[];
---

<Layout
  title="Best Software For — WrenchStack buyer guides"
  description={`${useCases.length} buyer-specific software guides for trades and field-service businesses. Find the right pick for your exact situation.`}
>
  <section class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-8">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900">Buyer guides</h1>
      <p class="mt-3 max-w-2xl text-lg text-slate-600">
        Software picks for specific buyer situations — by team size, vertical, and use case.
        Each guide ranks 5 tools that actually fit the profile, with the rationale for why.
      </p>
    </header>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {useCases.map((uc) => (
        <a
          href={`/best-software-for/${uc.slug}/`}
          class="group rounded-lg border border-slate-200 bg-white p-5 transition hover:border-slate-400 hover:shadow-sm"
        >
          <h3 class="text-lg font-semibold text-slate-900 group-hover:text-orange-600">
            {uc.h1}
          </h3>
          <p class="mt-1 text-sm text-slate-500">{uc.buyer_profile}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
