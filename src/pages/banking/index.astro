---
import Layout from '../../layouts/Layout.astro';
import VendorLogo from '../../components/VendorLogo.astro';
import { bankingProviders, bankingByFocus, BANKING_FOCUS_META } from '../../lib/data';

const grouped = bankingByFocus();

const pageTitle = `Best Business Banking for Contractors & Trades (2026)`;
const pageDescription = `Independent comparison of business banking for contractors — Found, Novo, Relay, Bluevine — by focus (self-employed vs business checking vs banking + credit). Real fees, APYs, and the cash-deposit and account-freeze caveats most reviews skip.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Banking', url: '/banking/' },
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Business Banking Providers for Contractors',
  numberOfItems: bankingProviders.length,
  itemListElement: bankingProviders.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'FinancialProduct',
      name: p.name,
      description: p.tagline,
      url: `https://wrenchstack.com/banking/${p.slug}/`,
    },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <article class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-10">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-emerald-600">Banking</p>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">
        Best Business Banking for Contractors & Trades (2026)
      </h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        The right business account separates your money from your taxes, earns interest on reserves, and — for some — comes with a credit line. We compare the fintech banking platforms trades use, by what they're built for, with the caveats most reviews skip: cash deposits and account freezes.
      </p>
    </header>

    <section class="mb-10 rounded-lg border-l-4 border-orange-500 bg-orange-50/40 p-5">
      <p class="text-xs font-bold uppercase tracking-wider text-orange-600">The short answer</p>
      <p class="mt-2 text-slate-800 leading-relaxed">
        Fintech business accounts like <a href="/banking/mercury/" class="font-semibold text-orange-700 hover:underline">Mercury</a> and <a href="/banking/relay/" class="font-semibold text-orange-700 hover:underline">Relay</a> separate your money from your taxes and earn interest on reserves — but two honest caveats decide this category: most fintechs <strong>don't handle cash deposits</strong> well (if your trade still takes cash, keep a traditional bank too), and they can <strong>freeze accounts</strong> for risk review, so never run your <em>only</em> operating account on one. Pick by what you actually need — multiple sub-accounts for job costing, a built-in credit line, or the highest yield — and always keep a backup account and a cash buffer. No vendor pays for placement.
      </p>
    </section>

    <section class="mb-10 rounded-lg border-2 border-amber-200 bg-amber-50 p-6">
      <h2 class="mb-2 text-base font-bold text-amber-900">Two things to know before you switch</h2>
      <p class="text-sm text-amber-900 leading-relaxed">
        <strong>1. Cash deposits:</strong> these are fintechs (FDIC-insured via partner banks), and most do <em>not</em> handle cash deposits well. If your trade still takes cash, you'll likely need a traditional bank too. <strong>2. Account freezes:</strong> fintech-banking platforms periodically freeze accounts for risk review (Bluevine's pattern is especially well-documented). Funds stay FDIC-insured, but never run your <em>only</em> operating account on one of these — keep a backup and a cash buffer.
      </p>
    </section>

    {grouped.map(({ focus, providers }) => {
      const meta = BANKING_FOCUS_META[focus];
      return (
        <section class="mb-12">
          <div class="mb-5">
            <span class="inline-block rounded-full bg-emerald-100 px-3 py-1 text-xs font-bold uppercase tracking-wider text-emerald-900 ring-1 ring-emerald-300">{meta.label}</span>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">{meta.blurb}</p>
          </div>

          <div class="space-y-4">
            {providers.map((p) => (
              <article class="rounded-lg border-2 border-emerald-200 bg-white p-5">
                <div class="mb-3 flex items-start justify-between gap-3">
                  <div class="flex min-w-0 flex-1 items-center gap-3">
                    <VendorLogo name={p.name} url={p.vendor_url} size={40} />
                    <div class="min-w-0">
                      <h3 class="text-xl font-bold text-slate-900">
                        <a href={`/banking/${p.slug}/`} class="hover:text-emerald-600">{p.name}</a>
                      </h3>
                      <p class="text-sm italic text-slate-500">{p.tagline}</p>
                    </div>
                  </div>
                  <div class="shrink-0 text-right text-xs">
                    <p class="font-bold text-slate-900">{p.monthly_fee.split(';')[0]}</p>
                    <p class="text-slate-500">monthly</p>
                  </div>
                </div>

                {p.reputation_flag && (
                  <div class="mb-3 rounded-md border-l-4 border-rose-500 bg-rose-50 px-4 py-3 text-sm text-rose-900">
                    <p class="font-bold uppercase tracking-wider text-xs text-rose-700 mb-1">⚠ Account-freeze warning</p>
                    <p class="leading-relaxed">{p.reputation_flag.split('.')[0]}.</p>
                  </div>
                )}

                <p class="mb-3 rounded-md bg-slate-50 px-4 py-2 text-sm text-slate-700 leading-snug">
                  <strong class="text-slate-900">APY / yield:</strong> {p.apy}
                </p>

                <dl class="mb-3 grid grid-cols-2 gap-2 text-xs sm:grid-cols-3">
                  <div>
                    <dt class="text-slate-500 uppercase tracking-wider">Focus</dt>
                    <dd class="font-semibold text-slate-900 capitalize">{p.banking_focus.replace(/-/g, ' ')}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500 uppercase tracking-wider">Founded</dt>
                    <dd class="font-semibold text-slate-900">{p.founded ?? '—'}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500 uppercase tracking-wider">Trustpilot</dt>
                    <dd class="font-semibold text-slate-900">{p.ratings.trustpilot !== null ? `${p.ratings.trustpilot.toFixed(1)} / 5` : '—'}</dd>
                  </div>
                </dl>

                <p class="mb-3 text-sm text-slate-700 leading-relaxed">
                  <strong class="text-slate-900">Best for:</strong> {p.best_for}
                </p>

                <div class="flex flex-wrap gap-2">
                  <a href={`/banking/${p.slug}/`} class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800">Read full review →</a>
                  <a href={p.affiliate_url.startsWith('http') ? p.affiliate_url : p.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md border border-emerald-300 bg-white px-4 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50">Visit {p.name}</a>
                </div>
              </article>
            ))}
          </div>
        </section>
      );
    })}

    <section class="mt-12 rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Where to start</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">
        Solo/1099 operator who dreads taxes? <strong>Found</strong> (auto tax set-aside + bookkeeping). Want disciplined cash management (Profit First)? <strong>Relay</strong> (up to 20 accounts). Want the simplest free checking? <strong>Novo</strong>. Want real APY plus a credit line? <strong>Bluevine</strong> — but keep a backup given its freeze pattern. And if you take meaningful cash, pair any of these with a traditional bank.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/banking/relay/" class="rounded-md bg-emerald-500 px-5 py-3 text-sm font-semibold text-white hover:bg-emerald-600">See Relay →</a>
        <a href="/payments/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">Payments</a>
        <a href="/accounting/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Accounting</a>
      </div>
    </section>
  </article>
</Layout>
