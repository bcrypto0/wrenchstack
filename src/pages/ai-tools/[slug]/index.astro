---
import Layout from '../../../layouts/Layout.astro';
import { aiTools, AI_CATEGORY_META, type AiTool } from '../../../lib/data';

export async function getStaticPaths() {
  return aiTools.map((t) => ({
    params: { slug: t.slug },
    props: { tool: t },
  }));
}

interface Props { tool: AiTool; }
const { tool } = Astro.props;
const catLabel = AI_CATEGORY_META[tool.ai_category].label;

const siblings = aiTools.filter((t) => t.slug !== tool.slug).slice(0, 6);

const pageTitle = `${tool.name} Review (2026): Pricing, Features, Pros & Cons`;
const pageDescription = `${tool.name} review for trades contractors. ${tool.tagline}. ${tool.reputation_flag ? 'Includes documented reputation context. ' : ''}Independent, affiliate-transparent. Updated ${new Date().getFullYear()}.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'AI Tools', url: '/ai-tools/' },
  { name: tool.name, url: `/ai-tools/${tool.slug}/` },
];

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: tool.name,
  description: tool.tagline,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: tool.starting_price_usd !== null ? { '@type': 'Offer', price: tool.starting_price_usd, priceCurrency: 'USD' } : undefined,
  ...(tool.ratings.g2 !== null && {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: tool.ratings.g2.toFixed(1),
      bestRating: '5',
      reviewCount: 50,
    },
  }),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: tool.ai_faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <article class="mx-auto max-w-4xl px-4 py-12">
    <header class="mb-8">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-indigo-600">AI Tools · {catLabel}</p>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">{tool.name} Review</h1>
      <p class="mt-3 text-lg italic text-slate-600">{tool.tagline}</p>

      <div class="mt-5 flex flex-wrap items-center gap-2">
        <span class="inline-block rounded-full bg-indigo-100 px-3 py-1 text-xs font-bold uppercase tracking-wider text-indigo-900 ring-1 ring-indigo-300">{catLabel}</span>
      </div>

      <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm text-slate-600">
        {tool.founded !== null && <span>Founded {tool.founded}</span>}
        {tool.headquartered && <span>HQ {tool.headquartered}</span>}
        <span>Verified: {tool.verified_date}</span>
        {tool.free_trial_days > 0 && <span>{tool.free_trial_days}-day free trial</span>}
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href={tool.affiliate_url.startsWith('http') ? tool.affiliate_url : tool.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md bg-indigo-500 px-5 py-3 text-sm font-semibold text-white hover:bg-indigo-600">Visit {tool.name} →</a>
        <a href="/ai-tools/" class="rounded-md border border-slate-300 bg-white px-4 py-3 text-sm font-medium text-slate-700 hover:bg-slate-50">See all AI tools</a>
      </div>
    </header>

    {tool.reputation_flag && (
      <section class="mb-10 rounded-lg border-2 border-rose-300 bg-rose-50 p-6">
        <div class="mb-2 flex items-center gap-2">
          <span class="text-xl">⚠</span>
          <h2 class="text-lg font-bold text-rose-900">Reputation warning</h2>
        </div>
        <p class="text-sm text-rose-900 leading-relaxed">{tool.reputation_flag}</p>
      </section>
    )}

    <nav class="mb-8 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 md:sticky md:top-2 md:z-30 md:bg-white/95 md:backdrop-blur">
      <div class="text-xs font-semibold uppercase tracking-wider text-slate-700">Jump to</div>
      <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-sm">
        <a href="#how-it-works" class="text-indigo-600 hover:underline">How it works</a>
        <span class="text-slate-300">·</span>
        <a href="#pros-cons" class="text-indigo-600 hover:underline">Pros & Cons</a>
        <span class="text-slate-300">·</span>
        <a href="#pricing" class="text-indigo-600 hover:underline">Pricing</a>
        <span class="text-slate-300">·</span>
        <a href="#integrations" class="text-indigo-600 hover:underline">Integrations</a>
        <span class="text-slate-300">·</span>
        <a href="#faqs" class="text-indigo-600 hover:underline">FAQs</a>
      </div>
    </nav>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-lg font-bold text-slate-900">Quick verdict</h2>
      <p class="text-slate-700 leading-relaxed">
        <strong class="text-slate-900">{tool.name}</strong> is best for {tool.best_for}. Pricing: {tool.pricing_summary}. {tool.weaknesses}.
      </p>
    </section>

    <section class="mb-10 prose prose-slate max-w-none">
      <h2>About {tool.name}</h2>
      {tool.long_description.split('\n\n').map((p) => <p>{p}</p>)}
    </section>

    <section id="how-it-works" class="mb-10 scroll-mt-8">
      <h2 class="mb-3 text-2xl font-bold text-slate-900">How it works</h2>
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <p class="text-slate-700 leading-relaxed">{tool.how_it_works}</p>
      </div>
    </section>

    <section id="pros-cons" class="mb-10 scroll-mt-8">
      <h2 class="mb-5 text-2xl font-bold text-slate-900">Pros & cons</h2>
      <div class="mb-6">
        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-emerald-700">What works</h3>
        <ul class="space-y-3">
          {tool.pros_detail.map((p) => (
            <li class="rounded-lg border-l-4 border-emerald-400 bg-emerald-50 px-4 py-3">
              <p class="font-semibold text-emerald-900">{p.title}</p>
              <p class="mt-1 text-sm text-emerald-900 leading-relaxed">{p.explanation}</p>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-rose-700">What doesn't</h3>
        <ul class="space-y-3">
          {tool.cons_detail.map((c) => (
            <li class="rounded-lg border-l-4 border-rose-400 bg-rose-50 px-4 py-3">
              <p class="font-semibold text-rose-900">{c.title}</p>
              <p class="mt-1 text-sm text-rose-900 leading-relaxed">{c.explanation}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section id="pricing" class="mb-10 scroll-mt-8">
      <h2 class="mb-3 text-2xl font-bold text-slate-900">Pricing</h2>
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <p class="font-semibold text-slate-900">{tool.pricing_summary}.</p>
        {tool.starting_price_usd !== null && (
          <p class="mt-2 text-sm text-slate-600">Starting at ${tool.starting_price_usd}/mo{tool.free_trial_days > 0 && ` · ${tool.free_trial_days}-day free trial`}</p>
        )}
        <p class="mt-3 text-sm text-slate-700"><strong class="text-slate-900">Affiliate disclosure:</strong> {tool.affiliate_payout_note}.</p>
      </div>
    </section>

    <section id="integrations" class="mb-10 scroll-mt-8">
      <h2 class="mb-3 text-2xl font-bold text-slate-900">Integrations & key features</h2>
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <div class="mb-3">
          <p class="mb-1 text-xs font-bold uppercase tracking-wider text-slate-500">Integrations</p>
          <div class="flex flex-wrap gap-1">
            {tool.integrations.map((i) => (
              <span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs">{i.replace(/_/g, ' ')}</span>
            ))}
          </div>
        </div>
        <div>
          <p class="mb-1 text-xs font-bold uppercase tracking-wider text-slate-500">Key features</p>
          <div class="flex flex-wrap gap-1">
            {tool.key_features.map((f) => (
              <span class="rounded-md bg-indigo-50 px-2 py-0.5 text-xs text-indigo-800">{f.replace(/_/g, ' ')}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-10 scroll-mt-8">
      <h2 class="mb-5 text-2xl font-bold text-slate-900">Frequently asked</h2>
      <div class="space-y-3">
        {tool.ai_faqs.map((f) => (
          <details class="rounded-lg border border-slate-200 bg-white p-4">
            <summary class="cursor-pointer font-semibold text-slate-900">{f.q}</summary>
            <p class="mt-3 text-slate-700 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="mb-10">
      <h2 class="mb-5 text-2xl font-bold text-slate-900">Other AI tools</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {siblings.map((s) => (
          <a href={`/ai-tools/${s.slug}/`} class="block rounded-lg border border-slate-200 bg-white p-4 no-underline transition hover:border-indigo-300 hover:bg-indigo-50">
            <p class="mb-1 font-semibold text-slate-900">{s.name}</p>
            <p class="text-xs text-slate-500 line-clamp-2">{s.tagline}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Browse more</h2>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/ai-tools/" class="rounded-md bg-indigo-500 px-5 py-3 text-sm font-semibold text-white hover:bg-indigo-600">All AI tools</a>
        <a href="/tools/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">Software directory</a>
        <a href="/payroll/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Payroll</a>
      </div>
    </section>
  </article>
</Layout>
