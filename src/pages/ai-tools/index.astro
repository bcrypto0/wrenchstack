---
import Layout from '../../layouts/Layout.astro';
import { aiTools, aiToolsByCategory, AI_CATEGORY_META } from '../../lib/data';
import VendorLogo from '../../components/VendorLogo.astro';

const grouped = aiToolsByCategory();

const pageTitle = `Best AI Tools for Contractors & Home-Service Trades (2026)`;
const pageDescription = `Independent reviews of AI tools for trades businesses — AI receptionists and call-answering agents (Avoca, Rosie, Goodcall, Smith.ai) that capture missed calls and book jobs 24/7. Honest, affiliate-transparent coverage built for HVAC, plumbing, electrical, and other contractors.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'AI Tools', url: '/ai-tools/' },
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'AI Tools for Trades Contractors',
  numberOfItems: aiTools.length,
  itemListElement: aiTools.map((t, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'SoftwareApplication',
      name: t.name,
      description: t.tagline,
      url: `https://wrenchstack.com/ai-tools/${t.slug}/`,
    },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <article class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-10">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-indigo-600">AI Tools</p>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">
        Best AI Tools for Contractors & Home-Service Trades (2026)
      </h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        AI is reshaping how trades businesses handle the phone, the quote, and the follow-up. We review the AI tools that actually move the needle for contractors — independently, with honest pricing and clear affiliate disclosure. We start where the ROI is clearest: AI receptionists that stop missed-call revenue leakage.
      </p>
    </header>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-base font-bold text-slate-900">Why AI receptionists are the highest-ROI AI for trades</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        Field-based contractors miss a large share of inbound calls — they're on a roof, under a sink, or driving between jobs. Every missed call that goes to voicemail is a caller who dials the next contractor on the list. An AI receptionist answers 24/7, qualifies the caller, and books the job, turning missed calls into booked revenue. That's why it's the first AI category we cover in depth, spanning the budget end (Rosie, Goodcall) through hybrid (Smith.ai) to the enterprise front office (Avoca) and trades-native sales agents (Sameday). Beyond the phone, we also cover AI estimating and measurement, route-optimization scheduling, and AI review and reputation marketing.
      </p>
    </section>

    {grouped.filter(({ tools }) => tools.length > 0).map(({ category, tools }) => {
      const meta = AI_CATEGORY_META[category];
      return (
        <section class="mb-12">
          <div class="mb-5">
            <span class="inline-block rounded-full bg-indigo-100 px-3 py-1 text-xs font-bold uppercase tracking-wider text-indigo-900 ring-1 ring-indigo-300">{meta.label}</span>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">{meta.blurb}</p>
          </div>

          <div class="space-y-4">
            {tools.map((t) => (
              <article class="rounded-lg border-2 border-indigo-200 bg-white p-5">
                <div class="mb-3 flex items-start justify-between gap-3">
                  <div class="flex min-w-0 flex-1 items-center gap-3">
                    <VendorLogo name={t.name} url={t.vendor_url} size={40} />
                    <div class="min-w-0">
                      <h3 class="text-xl font-bold text-slate-900">
                        <a href={`/ai-tools/${t.slug}/`} class="hover:text-indigo-600">{t.name}</a>
                      </h3>
                      <p class="text-sm italic text-slate-500">{t.tagline}</p>
                    </div>
                  </div>
                  <div class="shrink-0 text-right text-xs">
                    <p class="font-bold text-slate-900">{t.starting_price_usd === null ? 'Custom quote' : t.starting_price_usd === 0 ? 'Free tier' : `From $${t.starting_price_usd}/mo`}</p>
                    {t.free_trial_days > 0 && <p class="text-slate-500">{t.free_trial_days}-day trial</p>}
                  </div>
                </div>

                {t.reputation_flag && (
                  <div class="mb-3 rounded-md border-l-4 border-rose-500 bg-rose-50 px-4 py-3 text-sm text-rose-900">
                    <p class="font-bold uppercase tracking-wider text-xs text-rose-700 mb-1">⚠ Reputation warning</p>
                    <p class="leading-relaxed">{t.reputation_flag.split('.')[0]}.</p>
                  </div>
                )}

                <dl class="mb-3 grid grid-cols-2 gap-2 text-xs sm:grid-cols-4">
                  <div>
                    <dt class="text-slate-500 uppercase tracking-wider">Best team size</dt>
                    <dd class="font-semibold text-slate-900">{t.best_team_size}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500 uppercase tracking-wider">Free trial</dt>
                    <dd class="font-semibold text-slate-900">{t.free_trial_days > 0 ? `${t.free_trial_days} days` : 'No'}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500 uppercase tracking-wider">Founded</dt>
                    <dd class="font-semibold text-slate-900">{t.founded ?? '—'}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500 uppercase tracking-wider">Affiliate</dt>
                    <dd class="font-semibold text-slate-900">{t.affiliate_program === 'none' || t.affiliate_program === 'unknown' ? 'None' : t.affiliate_program}</dd>
                  </div>
                </dl>

                <p class="mb-3 text-sm text-slate-700 leading-relaxed">
                  <strong class="text-slate-900">Best for:</strong> {t.best_for}
                </p>

                <div class="flex flex-wrap gap-2">
                  <a href={`/ai-tools/${t.slug}/`} class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800">Read full review →</a>
                  <a href={t.affiliate_url.startsWith('http') ? t.affiliate_url : t.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md border border-indigo-300 bg-white px-4 py-2 text-sm font-semibold text-indigo-700 hover:bg-indigo-50">Visit {t.name}</a>
                </div>
              </article>
            ))}
          </div>
        </section>
      );
    })}

    <section class="mt-12 rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Where to start</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">
        For a solo or small shop that just wants to stop missing calls, start with <strong>Rosie</strong> ($49/mo, trades-native) or <strong>Goodcall</strong> ($79/mo, unlimited minutes). If you want the reassurance of human backup on complex calls, <strong>Smith.ai</strong>'s hybrid model fits. For a high-call-volume operation that wants a full AI front office — inbound, outbound follow-up, and CSR coaching — <strong>Avoca</strong> is the funded category leader (enterprise, sales-quoted).
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/ai-tools/rosie/" class="rounded-md bg-indigo-500 px-5 py-3 text-sm font-semibold text-white hover:bg-indigo-600">Start with Rosie →</a>
        <a href="/tools/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">Software directory</a>
        <a href="/payroll/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Payroll</a>
      </div>
    </section>
  </article>
</Layout>
