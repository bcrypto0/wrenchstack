---
import Layout from '../../layouts/Layout.astro';
import { tools, aggregateRating, type Tool } from '../../lib/data';

interface Pair {
  a: Tool;
  b: Tool;
}

const pairs: Pair[] = [];
for (let i = 0; i < tools.length; i++) {
  for (let j = i + 1; j < tools.length; j++) {
    const a = tools[i];
    const b = tools[j];
    if (!a.verticals.some((v) => b.verticals.includes(v))) continue;
    const [first, second] = [a, b].sort((x, y) => x.slug.localeCompare(y.slug));
    pairs.push({ a: first, b: second });
  }
}

const popularPairs = pairs.sort((p, q) => {
  const scoreP = (aggregateRating(p.a) ?? 0) + (aggregateRating(p.b) ?? 0);
  const scoreQ = (aggregateRating(q.a) ?? 0) + (aggregateRating(q.b) ?? 0);
  return scoreQ - scoreP;
});
---

<Layout
  title="Compare trades software side-by-side — WrenchStack"
  description={`${pairs.length} head-to-head comparisons of trades software. Pricing, features, integrations, ratings.`}
>
  <section class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-8">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900">
        Compare trades software
      </h1>
      <p class="mt-3 max-w-2xl text-lg text-slate-600">
        {pairs.length} head-to-head comparisons. Pricing, features, integrations, and ratings
        side-by-side. Pick any two tools to start.
      </p>
    </header>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {popularPairs.map(({ a, b }) => (
        <a
          href={`/compare/${a.slug}-vs-${b.slug}/`}
          class="group rounded-lg border border-slate-200 bg-white p-4 transition hover:border-slate-400 hover:shadow-sm"
        >
          <div class="font-semibold text-slate-900 group-hover:text-orange-600">
            {a.name} vs {b.name}
          </div>
          <div class="mt-1 text-xs text-slate-500">
            Compare pricing, features, integrations
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
