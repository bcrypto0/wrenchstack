---
import Layout from '../../layouts/Layout.astro';
import { tools, verticals, aggregateRating, verticalToUrl, type Tool } from '../../lib/data';

interface Pair {
  a: Tool;
  b: Tool;
}

// Build all pairs that share at least one vertical (matches the comparison-page generator).
const pairs: Pair[] = [];
for (let i = 0; i < tools.length; i++) {
  for (let j = i + 1; j < tools.length; j++) {
    const a = tools[i];
    const b = tools[j];
    if (!a.verticals.some((v) => b.verticals.includes(v))) continue;
    const [first, second] = [a, b].sort((x, y) => x.slug.localeCompare(y.slug));
    pairs.push({ a: first, b: second });
  }
}

// Featured comparisons — curated list of highest-search-volume pairs.
const featuredSlugPairs: [string, string][] = [
  ['jobber', 'housecall-pro'],
  ['jobber', 'servicetitan'],
  ['housecall-pro', 'servicetitan'],
  ['fieldedge', 'servicetitan'],
  ['buildops', 'servicetitan'],
  ['buildertrend', 'procore'],
  ['acculynx', 'jobnimbus'],
  ['jobber', 'workiz'],
  ['servicefusion', 'jobber'],
  ['housecall-pro', 'workiz'],
  ['buildops', 'procore'],
  ['knowify', 'buildertrend'],
];
const featuredPairs = featuredSlugPairs
  .map(([slugA, slugB]) => {
    const a = tools.find((t) => t.slug === slugA);
    const b = tools.find((t) => t.slug === slugB);
    if (!a || !b) return null;
    const [first, second] = [a, b].sort((x, y) => x.slug.localeCompare(y.slug));
    return { a: first, b: second };
  })
  .filter((p): p is Pair => p !== null);

// Comparisons grouped by vertical. Each pair appears in every shared-vertical section.
const pairsByVertical = verticals.map((v) => ({
  vertical: v,
  pairs: pairs
    .filter((p) => p.a.verticals.includes(v.slug) && p.b.verticals.includes(v.slug))
    .sort((p, q) => {
      const scoreP = (aggregateRating(p.a) ?? 0) + (aggregateRating(p.b) ?? 0);
      const scoreQ = (aggregateRating(q.a) ?? 0) + (aggregateRating(q.b) ?? 0);
      return scoreQ - scoreP;
    }),
}));

// All pairs alphabetical (for the full browse list)
const allPairsAlphabetical = [...pairs].sort((p, q) => {
  const labelP = `${p.a.name} vs ${p.b.name}`;
  const labelQ = `${q.a.name} vs ${q.b.name}`;
  return labelP.localeCompare(labelQ);
});

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Compare', url: '/compare/' },
];
---

<Layout
  title={`Compare trades software side-by-side — ${pairs.length} head-to-head comparisons`}
  description={`${pairs.length} head-to-head comparisons of trades software. Decision matrix, pricing side-by-side, pros and cons, implementation timelines. Updated 2026.`}
  breadcrumbs={breadcrumbs}
>
  <section class="mx-auto max-w-6xl px-4 py-12">
    <header class="mb-10">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        Compare trades software, side-by-side
      </h1>
      <p class="mt-4 max-w-3xl text-lg text-slate-600">
        {pairs.length} head-to-head comparisons across {verticals.length} trades. Each comparison includes a decision matrix ("pick A if…" / "pick B if…"), side-by-side pricing, detailed pros and cons, implementation timelines, and {pairs.length > 100 ? '8+' : 'multiple'} FAQs.
      </p>
      <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm text-slate-500">
        <span><span class="font-bold text-slate-900">{pairs.length}</span> comparisons</span>
        <span class="text-slate-300">·</span>
        <span><span class="font-bold text-slate-900">{tools.length}</span> tools</span>
        <span class="text-slate-300">·</span>
        <span><span class="font-bold text-slate-900">{verticals.length}</span> trades</span>
      </div>
    </header>

    <nav class="mb-12 rounded-lg border border-slate-200 bg-slate-50 p-4">
      <div class="text-sm font-semibold text-slate-700">Jump to:</div>
      <div class="mt-2 flex flex-wrap gap-x-4 gap-y-2 text-sm">
        <a href="#featured" class="text-orange-600 hover:underline">Most popular ({featuredPairs.length})</a>
        <span class="text-slate-300">·</span>
        <a href="#by-trade" class="text-orange-600 hover:underline">Browse by trade</a>
        <span class="text-slate-300">·</span>
        <a href="#all-pairs" class="text-orange-600 hover:underline">All {pairs.length} comparisons</a>
      </div>
    </nav>

    <section id="featured" class="mb-16 scroll-mt-8">
      <h2 class="mb-2 text-2xl font-bold tracking-tight text-slate-900">Most popular comparisons</h2>
      <p class="mb-6 text-slate-600">
        The most-searched matchups in trades software — the comparisons buyers actually look up when deciding.
      </p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {featuredPairs.map(({ a, b }) => {
          const rA = aggregateRating(a);
          const rB = aggregateRating(b);
          return (
            <a
              href={`/compare/${a.slug}-vs-${b.slug}/`}
              class="group rounded-lg border border-slate-200 bg-white p-5 transition hover:border-orange-400 hover:shadow-sm"
            >
              <h3 class="text-base font-semibold text-slate-900 group-hover:text-orange-600">
                {a.name} vs {b.name}
              </h3>
              <p class="mt-1 text-xs text-slate-500">
                {rA !== null && rB !== null
                  ? `${rA.toFixed(1)} vs ${rB.toFixed(1)} user rating`
                  : 'Decision matrix · pricing · pros and cons'}
              </p>
            </a>
          );
        })}
      </div>
    </section>

    <section id="by-trade" class="mb-16 scroll-mt-8">
      <h2 class="mb-2 text-2xl font-bold tracking-tight text-slate-900">Browse by trade</h2>
      <p class="mb-6 text-slate-600">
        Top-rated comparisons within each trade — the head-to-head matchups most relevant when both tools serve the same vertical.
      </p>
      <div class="space-y-10">
        {pairsByVertical.map(({ vertical, pairs: verticalPairs }) => (
          <div>
            <div class="mb-4 flex items-baseline justify-between border-b border-slate-200 pb-2">
              <h3 class="text-xl font-bold text-slate-900">
                <a href={`/${verticalToUrl(vertical.slug)}/`} class="hover:text-orange-600">
                  {vertical.name} comparisons
                </a>
              </h3>
              <span class="text-sm text-slate-500">{verticalPairs.length} pairs</span>
            </div>
            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {verticalPairs.slice(0, 9).map(({ a, b }) => (
                <a
                  href={`/compare/${a.slug}-vs-${b.slug}/`}
                  class="group rounded-lg border border-slate-200 bg-white p-3 transition hover:border-slate-400"
                >
                  <div class="font-semibold text-slate-900 group-hover:text-orange-600 text-sm">
                    {a.name} vs {b.name}
                  </div>
                </a>
              ))}
            </div>
            {verticalPairs.length > 9 && (
              <div class="mt-3 text-sm text-slate-500">
                + {verticalPairs.length - 9} more {vertical.name.toLowerCase()} comparisons in the full list below
              </div>
            )}
          </div>
        ))}
      </div>
    </section>

    <section id="all-pairs" class="mb-12 scroll-mt-8">
      <h2 class="mb-2 text-2xl font-bold tracking-tight text-slate-900">All comparisons (alphabetical)</h2>
      <p class="mb-6 text-slate-600">
        Every comparison in the directory, alphabetical by first tool. Use ⌘F / Ctrl+F to find a specific matchup.
      </p>
      <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {allPairsAlphabetical.map(({ a, b }) => (
          <a
            href={`/compare/${a.slug}-vs-${b.slug}/`}
            class="rounded border border-slate-200 bg-white p-2 text-xs text-slate-700 transition hover:border-slate-400 hover:text-orange-600"
          >
            {a.name} vs {b.name}
          </a>
        ))}
      </div>
    </section>
  </section>
</Layout>
