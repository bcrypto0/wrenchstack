---
import Layout from '../layouts/Layout.astro';
import { tools, verticals, leadGenPlatforms, insuranceProviders, payrollServices, marketingAgencies } from '../lib/data';

const toolCount = tools.length;
const verticalCount = verticals.length;
const phase2Count = tools.filter((t) => (t as { long_description?: string }).long_description).length;

// Cross-category coverage stats (multi-category positioning)
const leadGenCount = leadGenPlatforms.length;
const insuranceCount = insuranceProviders.length;
const payrollCount = payrollServices.length;
const agencyCount = marketingAgencies.length;
const totalVendorCount = toolCount + leadGenCount + insuranceCount + payrollCount + agencyCount;
const categoryCount = 5;
const reputationFlagCount = [
  ...leadGenPlatforms,
  ...insuranceProviders,
  ...marketingAgencies,
].filter((v) => 'reputation_flag' in v && v.reputation_flag !== null).length;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'About', url: '/about/' },
];

// Organization schema (not Person — repositioning as research firm)
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'WrenchStack',
  url: 'https://wrenchstack.com',
  description: `WrenchStack is an independent research desk covering trades-contractor vendors across ${categoryCount} categories — software, lead-generation, insurance, payroll, and marketing agencies. We publish the WrenchStack Fit Score™ methodology and per-vendor affiliate disclosure for every recommendation.`,
  foundingDate: '2026',
  knowsAbout: [
    'Field service management software',
    'Trades contractor lead generation',
    'Business insurance for contractors',
    'SMB payroll services',
    'Home-services marketing agencies',
  ],
  email: 'hello@wrenchstack.com',
  sameAs: [],
  contactPoint: [
    { '@type': 'ContactPoint', contactType: 'editorial', email: 'hello@wrenchstack.com' },
    { '@type': 'ContactPoint', contactType: 'press', email: 'press@wrenchstack.com' },
    { '@type': 'ContactPoint', contactType: 'partnerships', email: 'partners@wrenchstack.com' },
  ],
};
---

<Layout
  title="About WrenchStack — independent trades vendor research desk"
  description={`WrenchStack is an independent research desk covering ${totalVendorCount}+ trades-contractor vendors across software, lead-gen, insurance, payroll, and marketing agencies. Published methodology, transparent affiliate disclosure, honest reputation flags.`}
  breadcrumbs={breadcrumbs}
>
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

  <article class="mx-auto max-w-3xl px-4 py-12">

    <header class="mb-12">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-orange-600">About WrenchStack</p>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">
        The independent research desk for trades vendors.
      </h1>
      <p class="mt-6 text-lg text-slate-700 leading-relaxed sm:text-xl">
        WrenchStack covers every vendor a trades contractor buys from — software, lead-generation, insurance, payroll, and marketing agencies — under a single published methodology and per-vendor affiliate ledger. {totalVendorCount}+ vendors evaluated. {reputationFlagCount} reputation flags issued. Zero pay-to-play.
      </p>
    </header>

    <section class="mb-12 grid gap-3 grid-cols-2 sm:grid-cols-4">
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">{totalVendorCount}+</div>
        <div class="mt-1 text-xs text-slate-600">Vendors evaluated</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">{categoryCount}</div>
        <div class="mt-1 text-xs text-slate-600">Categories covered</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">{verticalCount}</div>
        <div class="mt-1 text-xs text-slate-600">Trade verticals</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">2,800+</div>
        <div class="mt-1 text-xs text-slate-600">Pages of editorial</div>
      </div>
    </section>

    <section class="prose prose-slate max-w-none">

      <h2>What we do</h2>

      <p>
        We are an independent research desk publishing comparative analysis of the vendors trades contractors buy from. Across {categoryCount} categories — field service software, customer lead-generation platforms, business insurance providers, payroll services, and marketing agencies — we publish a unified <a href="/methodology/">WrenchStack Fit Score™</a> methodology, per-vendor affiliate disclosure, and reputation flags on the platforms whose track records earn them.
      </p>

      <p>
        Our editorial position is uncomplicated: contractors deserve evaluation that's not paid for by the vendors being evaluated. The methodology applies identically to every vendor in the directory — whether we have an active affiliate relationship, a pending application, or no commercial alignment at all. The reputation flags get attached based on documented patterns (FTC actions, BBB complaint volume, audit-pattern customer reports, Reddit sentiment) regardless of whether a flagged vendor pays us anything.
      </p>

      <h2>Why this exists</h2>

      <p>
        The trades-vendor evaluation market is fragmented between two structurally compromised models. Lead-generation directories (Capterra, G2, Software Advice, BeltStack, ContractorNerd) monetize by routing contractor inquiries to vendors who pay for placement — which means stale data, hidden pricing behind sales-call walls, and rankings that correlate with bid amount rather than product fit. Vendor-published comparisons (Housecall Pro vs Jobber pages, Workyard's "best HVAC software" rankings) put the publishing vendor at #1 by definition.
      </p>

      <p>
        Neither model produces evaluation a contractor researching software at 11pm after a 10-hour install day can actually trust. WrenchStack is what the third option looks like — independent research with published methodology, transparent monetization, and honest reputation flags on vendors with documented patterns of contractor-hostile behavior.
      </p>

      <h2>Editorial structure</h2>

      <p>
        WrenchStack operates as a research desk with clear editorial roles, even where roles consolidate in early operations:
      </p>

      <ul class="not-prose space-y-3">
        <li class="rounded-lg border border-slate-200 bg-white p-4">
          <div class="font-semibold text-slate-900">Editor-in-Chief</div>
          <div class="text-sm text-slate-600 mt-1">Editorial direction, methodology stewardship, vendor relationship boundaries. Reviews every reputation flag before publication.</div>
        </li>
        <li class="rounded-lg border border-slate-200 bg-white p-4">
          <div class="font-semibold text-slate-900">Methodology Lead</div>
          <div class="text-sm text-slate-600 mt-1">Owns the <a href="/methodology/" class="text-orange-600 hover:underline">WrenchStack Fit Score™</a> formula, weights, version history, scoring rubric. Documents every change to the methodology in the versioned changelog.</div>
        </li>
        <li class="rounded-lg border border-slate-200 bg-white p-4">
          <div class="font-semibold text-slate-900">Data Operations</div>
          <div class="text-sm text-slate-600 mt-1">Pricing verification (quarterly refresh), feature data sourcing, integration directory cross-referencing, reputation-pattern aggregation across Reddit/BBB/Trustpilot/forum sources.</div>
        </li>
        <li class="rounded-lg border border-slate-200 bg-white p-4">
          <div class="font-semibold text-slate-900">Vendor Relations</div>
          <div class="text-sm text-slate-600 mt-1">Manages vendor outreach, affiliate program applications, sponsored placement disclosures, and editorial correction requests. Operates separately from editorial decisions.</div>
        </li>
      </ul>

      <h2>What makes us structurally different</h2>

      <p>Four operational pillars, on every page, without exception:</p>

      <ol>
        <li>
          <strong>Multi-category coverage under one methodology.</strong> Software, lead-gen, insurance, payroll, marketing agencies — same WrenchStack Fit Score™ formula, same independence rules, same reputation-flag standards. Single-category competitors structurally cannot match the cross-category coverage; multi-category competitors don't exist.
        </li>
        <li>
          <strong>Verified pricing with visible dates.</strong> Every pricing tier shows a <code>verified_date</code> stamp. Pricing under 90 days old gets a green freshness pill; 91–180 days gets amber; over 180 gets red. The freshness signal is a UI element, not buried metadata.
        </li>
        <li>
          <strong>Buyer-side decision tools.</strong> <a href="/quiz/">Matching quiz</a>, <a href="/roi-calculator/">ROI calculator</a>, <a href="/cost-of-switch/">cost-of-switch calculator</a>, per-tool pricing widgets, interactive <a href="/compare-builder/">comparison builder</a>. Tools that make the decision real — competitor directories don't ship these because their business model depends on form-fills, not self-service.
        </li>
        <li>
          <strong>Honest reputation flags.</strong> {reputationFlagCount} vendors carry a reputation_flag warning citing specific documented concerns: FTC settlements (HomeAdvisor's $7.2M, Angi's multiple consent decrees), audit-pattern complaints (Pie Insurance), fake-lead complaint patterns (Bark), lock-in contract patterns (Townsquare Interactive's FrownSquare.com complaint site, Marketing 360), and renewal-rate-increase patterns (Hiscox 2025, ADP Run, Paychex Flex). Every flag includes citation to documented sources.
        </li>
      </ol>

      <h2>What we ship</h2>

      <ul>
        <li><strong>{toolCount} software platforms</strong> across {verticalCount} trade verticals with 100% deep-editorial coverage (1,200–2,500 words each)</li>
        <li><strong>{leadGenCount} lead-gen platforms</strong> with shared-vs-exclusive filter and FTC-cited reputation flags on documented bad actors</li>
        <li><strong>{insuranceCount} insurance providers</strong> with agent-vs-direct filter and per-trade buyer guides</li>
        <li><strong>{payrollCount} payroll services</strong> with company-size guides (1-5, 6-20, 20+ employees)</li>
        <li><strong>{agencyCount} marketing agencies</strong> with trade-specific specialists flagged and documented lock-in contract warnings</li>
        <li><strong>Methodology page</strong> with version number, effective date, scoring rubric, evaluation timeline, and per-vendor affiliate ledger</li>
        <li><strong>WrenchStack Awards 2026</strong> — 18 editorial designations, no paid placement, methodology-backed</li>
        <li><strong>State-level coverage</strong> across all 50 US states × top 5 trades with licensing context</li>
        <li><strong>2,800+ pages</strong> of editorial content covering individual reviews, comparison pages, per-trade buyer guides, state-level pages, and multi-tool comparisons</li>
      </ul>

      <h2>Geographic coverage</h2>

      <p>
        WrenchStack currently focuses on the United States market with all-state coverage. International expansion is in active progress for English-speaking trades markets: United Kingdom, Canada, Australia, New Zealand, and Ireland. Each market has its own vendor landscape (Checkatrade UK, Hipages AU, HomeStars CA, Fergus NZ, MyBuilder IE) and certification requirements (Gas Safe Register UK, Red Seal Program Canada, PGDB New Zealand) that warrant country-specific editorial coverage.
      </p>

      <h2>What we will never do</h2>

      <ul>
        <li>Accept payment for placement in a "best of" list or award category</li>
        <li>Accept payment to raise a vendor's WrenchStack Fit Score™</li>
        <li>Accept payment to omit or soften cons in a vendor review</li>
        <li>Accept payment to remove a reputation_flag warning</li>
        <li>Hide an affiliate relationship — every software vendor's status is on the <a href="/methodology/#affiliate-ledger">methodology page ledger</a>; lead-gen/insurance/payroll/agency vendors disclose per-page</li>
        <li>Recommend a vendor we wouldn't recommend if no commission existed</li>
        <li>Gate pricing data behind a sales call</li>
        <li>Publish "experts agree" content with no editorial accountability</li>
      </ul>

      <h2>For vendors interested in inclusion</h2>

      <p>
        We accept inbound submissions from vendors who believe they serve trades contractors well and want editorial review. Read the <a href="/methodology/">WrenchStack Fit Score™ methodology</a> first to understand how we evaluate. Then reach out via <a href="mailto:partners@wrenchstack.com">partners@wrenchstack.com</a> with: company name, website, primary trade verticals served, distinguishing characteristics vs comparable vendors, and current customer count (private, used only for context).
      </p>

      <p>
        Inclusion does not guarantee a positive review or absence of a reputation_flag. Editorial honesty applies identically to vendors who submit themselves and vendors we discover through other means.
      </p>

      <h2 id="contact">Contact</h2>

      <ul>
        <li><strong>General questions, corrections:</strong> <a href="mailto:hello@wrenchstack.com">hello@wrenchstack.com</a></li>
        <li><strong>Vendor partnerships, affiliate inquiries:</strong> <a href="mailto:partners@wrenchstack.com">partners@wrenchstack.com</a></li>
        <li><strong>Press, media, syndication:</strong> <a href="mailto:press@wrenchstack.com">press@wrenchstack.com</a></li>
      </ul>

      <p class="not-prose mt-8 rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
        <strong class="text-slate-900">Editorial integrity</strong> is the only product we ship. The minute readers stop trusting that the cons section is honest, the reputation flags are documented, and the pricing is verified — WrenchStack stops being useful to anyone. Every decision about content, scoring, partnerships, and methodology gets filtered through that test.
      </p>

    </section>
  </article>
</Layout>
