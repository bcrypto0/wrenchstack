---
import Layout from '../layouts/Layout.astro';
import { tools, verticals } from '../lib/data';
import useCasesData from '../data/use_cases.json';

const toolCount = tools.length;
const verticalCount = verticals.length;
const useCaseCount = (useCasesData.use_cases as unknown[]).length;
const verifiedDates = tools.map(t => t.pricing.verified_date).sort();
const oldestVerified = verifiedDates[0];
const newestVerified = verifiedDates[verifiedDates.length - 1];

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'About', url: '/about/' },
];
---

<Layout
  title="About WrenchStack"
  description="WrenchStack is the trades software directory — built specifically for HVAC, plumbing, electrical, roofing, and other field service businesses shopping for software."
  breadcrumbs={breadcrumbs}
>
  <article class="mx-auto max-w-3xl px-4 py-12">

    <header class="mb-12">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        The trades software directory built for buyers, not vendors.
      </h1>
      <p class="mt-6 text-xl text-slate-700 leading-relaxed">
        WrenchStack helps trades and field service businesses pick the right software — through deep product reviews, side-by-side comparisons, and buyer guides organized by team size and use case.
      </p>
    </header>

    <section class="mb-12 grid gap-4 sm:grid-cols-3">
      <div class="rounded-lg border border-slate-200 bg-white p-5 text-center">
        <div class="text-3xl font-bold text-slate-900">{toolCount}+</div>
        <div class="mt-1 text-sm text-slate-600">Software platforms tracked</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-5 text-center">
        <div class="text-3xl font-bold text-slate-900">{verticalCount}</div>
        <div class="mt-1 text-sm text-slate-600">Trades verticals covered</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-5 text-center">
        <div class="text-3xl font-bold text-slate-900">600+</div>
        <div class="mt-1 text-sm text-slate-600">Indexed comparison pages</div>
      </div>
    </section>

    <section class="prose prose-slate max-w-none">

      <h2>Why we built this</h2>

      <p>
        Picking field service software is a $5,000–$50,000+ annual decision for most trades businesses — and the existing research landscape doesn't serve contractors well. Horizontal SaaS directories list hundreds of generic products without team-size or vertical-specific guidance. Vendor blogs rank themselves first in every comparison. AI-generated content mills publish vague listicles with no real data.
      </p>

      <p>
        WrenchStack exists because contractors deserve a research resource built for them: <strong>trades-specific, structurally deep, and engineered around the questions buyers actually ask</strong> — by team size, by vertical, by integration needs, by use case.
      </p>

      <h2>What we publish</h2>

      <ul>
        <li><strong><a href="/tools/">{toolCount}+ tool reviews</a></strong> — every major field service platform with verified pricing, feature lists, integration depth, and honest weaknesses.</li>
        <li><strong><a href="/compare/">~480 head-to-head comparisons</a></strong> — side-by-side breakdowns for any two tools that share a vertical.</li>
        <li><strong>{verticalCount} vertical landing pages</strong> — ranked picks for HVAC, plumbing, electrical, roofing, landscaping, cleaning, pest control, contractors, and more.</li>
        <li><strong><a href="/best-software-for/">{useCaseCount} buyer guides</a></strong> — picks for solo contractors, growing teams, QuickBooks-heavy shops, insurance restoration roofers, snow-management landscapers, and other concrete buyer profiles.</li>
        <li><strong><a href="/pricing/">Pricing comparison pages</a></strong> for every vertical — sorted cheapest first, every tier visible.</li>
        <li><strong><a href="/quiz/">An interactive matching quiz</a></strong> — 5 questions, returns the 3 platforms that fit your business best.</li>
        <li><strong><a href="/roi-calculator/">An ROI calculator</a></strong> — plug in your team size and see realistic payback math.</li>
      </ul>

      <h2>How rankings work</h2>

      <p>
        Every tool in our directory carries a <strong>WrenchStack Score (0–10)</strong> calculated from four weighted factors:
      </p>

      <ul>
        <li><strong>Vertical fit (40%)</strong> — how well the tool is built for the specific trade you're searching</li>
        <li><strong>Aggregated user ratings (30%)</strong> — averaged G2 + Capterra scores</li>
        <li><strong>Pricing transparency (10%)</strong> — public tier pricing beats "contact sales" black boxes</li>
        <li><strong>Feature depth + integration coverage (20%)</strong> — does the tool actually do the work, and does it connect to the tools you already use</li>
      </ul>

      <p>
        Full breakdown on the <a href="/methodology/">methodology page</a>.
      </p>

      <h2>Who runs WrenchStack</h2>

      <p>
        WrenchStack is built and operated by <strong>Bilal Elhomsi</strong>, an entrepreneur with 15+ years of operating experience across hospitality, retail, and technology ventures. The site is a solo operation — every review, comparison, ranking, and buyer guide is written by one independent operator.
      </p>

      <p>
        Editorial focus is the North American field service software market — where the most competitive product ecosystem exists and where most readers buy.
      </p>

      <h2>How we make money</h2>

      <p>
        Affiliate commissions. When you sign up to a software platform through one of our tracked links, the vendor pays us a referral fee from their customer acquisition budget. <strong>You pay the same price as buying direct</strong> — there's no markup.
      </p>

      <p>
        Read the full breakdown on the <a href="/disclosure/">affiliate disclosure page</a>.
      </p>

      <h2 id="contact">Contact</h2>

      <ul>
        <li><strong>General / corrections:</strong> <a href="mailto:hello@wrenchstack.com">hello@wrenchstack.com</a></li>
        <li><strong>Affiliate program partnerships:</strong> <a href="mailto:partners@wrenchstack.com">partners@wrenchstack.com</a></li>
        <li><strong>Press / media:</strong> <a href="mailto:press@wrenchstack.com">press@wrenchstack.com</a></li>
      </ul>

      <p>
        See the <a href="/contact/">contact page</a> for the right inbox by topic.
      </p>

      <hr />

      <p class="text-sm text-slate-500">
        <strong>Site launched:</strong> May 2026 ·
        <strong>Pricing data verified:</strong> {oldestVerified} to {newestVerified} ·
        <strong>Last update:</strong> {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>

    </section>
  </article>
</Layout>
