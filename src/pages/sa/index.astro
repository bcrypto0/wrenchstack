---
import Layout from '../../layouts/Layout.astro';
import saData from '../../data/international/sa.json';

interface SaVendor {
  slug: string; name: string; category: string; vendor_url: string;
  tagline: string; market_position: string; sa_specific_note?: string | null;
  tier: 'S' | 'A' | 'F'; reputation_flag: string | null;
  pros: string[]; cons: string[]; typical_pricing: string;
  is_cross_market: boolean; cross_market_link: string | null;
}

const vendors = (saData as { vendors: SaVendor[] }).vendors;

const categories = ['software', 'certification'];
const categoryMeta: Record<string, { label: string; description: string }> = {
  'software': { label: 'Construction & trades software', description: 'From giga-project platforms (Oracle Aconex, Primavera, Autodesk) to Saudi-native construction ERPs (First Bit, PACT), ZATCA-certified accounting (Qoyod, Wafeq) and field-service tools (FSM Grid) for MEP and facilities contractors.' },
  'certification': { label: 'Licensing & compliance', description: 'The Saudi bodies every contractor deals with — Saudi Council of Engineers, MOMRAH contractor classification, Balady permits, the Saudi Building Code, ZATCA e-invoicing, Qiwa/Nitaqat Saudization, and Etimad government tendering.' },
};

const vendorsByCategory: Record<string, SaVendor[]> = {};
categories.forEach(c => { vendorsByCategory[c] = vendors.filter(v => v.category === c); });

const pageTitle = 'Saudi Arabia Construction & Trades Software — WrenchStack';
const pageDescription = `Independent directory of ${vendors.length} construction & trades vendors for Saudi Arabia: giga-project PM/BIM, Saudi-native ERPs, ZATCA-certified accounting, and field-service tools — plus the SCE, contractor-classification, Balady, SBC and ZATCA compliance you must handle.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Saudi Arabia', url: '/sa/' },
];
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <article class="mx-auto max-w-5xl px-4 py-12">

    <header class="mb-10">
      <div class="mb-3 flex items-center gap-2">
        <span class="text-2xl" aria-hidden="true">🇸🇦</span>
        <p class="text-sm font-semibold uppercase tracking-wider text-orange-600">Saudi Arabia · المملكة العربية السعودية</p>
      </div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">
        Saudi Construction & Trades Software Directory
      </h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        Independent reviews of {vendors.length} Saudi-relevant vendors — built for the Vision 2030 construction boom. Giga-project platforms (Oracle Aconex, Primavera, Autodesk), Saudi-native construction ERPs (First Bit, PACT), ZATCA-certified accounting (Qoyod, Wafeq), and field-service tools — with the local compliance context (SCE, contractor classification, Balady, Saudi Building Code, ZATCA e-invoicing, Nitaqat) that off-the-shelf US software ignores.
      </p>
    </header>

    <section class="mb-10 grid gap-3 grid-cols-2 sm:grid-cols-4">
      {categories.map(c => (
        <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
          <div class="text-2xl font-bold text-slate-900">{vendorsByCategory[c].length}</div>
          <div class="mt-1 text-xs text-slate-600 capitalize">{c}</div>
        </div>
      ))}
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">$100B+</div>
        <div class="mt-1 text-xs text-slate-600">construction market</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">2030</div>
        <div class="mt-1 text-xs text-slate-600">Vision giga-projects</div>
      </div>
    </section>

    <section class="mb-10 flex flex-wrap items-center justify-between gap-4 rounded-lg border border-orange-200 bg-orange-50 p-5">
      <div>
        <h2 class="text-base font-bold text-slate-900">Deciding between two options?</h2>
        <p class="mt-1 text-sm text-slate-700">See Saudi vendors compared side by side — a clear verdict, pros and cons, Saudi-specific notes, and pricing, head to head.</p>
      </div>
      <a href="/sa/compare/" class="shrink-0 rounded-md bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-700">Compare Saudi vendors →</a>
    </section>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-base font-bold text-slate-900">What's different about choosing software in Saudi Arabia</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        Saudi construction software selection has structural differences from the US. First, <strong>ZATCA e-invoicing (Fatoora) is mandatory</strong> — invoicing software must integrate with ZATCA's platform (UUID, cryptographic stamp, QR, real-time clearance), so freeform US tools simply can't comply; you need a Phase-2-certified system. Second, software must be <strong>Arabic / RTL and Saudi-Riyal native</strong>, with 15% VAT handling. Third, <strong>contractor classification (Grades 1–6) and Etimad registration</strong> gate public-sector work, while <strong>Nitaqat Saudization</strong> (via Qiwa) ties your labour mix to your ability to win tenders and renew visas — concepts with no US equivalent. And the demand engine is unique: <strong>Vision 2030 giga-projects</strong> (NEOM, Red Sea, Qiddiya, ROSHN) increasingly mandate BIM and digital workflows down the whole supply chain.
      </p>
    </section>

    {categories.map(c => {
      const cat = categoryMeta[c];
      const cv = vendorsByCategory[c];
      if (cv.length === 0) return null;
      return (
        <section class="mb-12">
          <div class="mb-5">
            <h2 class="text-2xl font-bold text-slate-900">{cat.label}</h2>
            <p class="mt-1 text-sm text-slate-600 leading-relaxed">{cat.description}</p>
          </div>
          <div class="space-y-4">
            {cv.map(v => {
              const isCert = v.category === 'certification';
              const tierColor = v.tier === 'S' ? 'border-emerald-300' : v.tier === 'F' ? 'border-rose-300' : 'border-blue-300';
              const tierLabel = isCert ? 'Official body' : v.tier === 'S' ? 'Recommended' : v.tier === 'F' ? 'Reputation warning' : 'Workable';
              const tierBadge = v.tier === 'S' ? 'bg-emerald-100 text-emerald-900' : v.tier === 'F' ? 'bg-rose-100 text-rose-900' : 'bg-blue-100 text-blue-900';
              return (
                <article class={`rounded-lg border-2 ${tierColor} bg-white p-5`}>
                  <div class="mb-3 flex items-start justify-between gap-3">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center gap-2 mb-1 flex-wrap">
                        <h3 class="text-xl font-bold text-slate-900">{v.name}</h3>
                        <span class={`rounded-full px-2 py-0.5 text-xs font-bold ${tierBadge}`}>{isCert ? tierLabel : `Tier ${v.tier} · ${tierLabel}`}</span>
                        {v.is_cross_market && (
                          <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">Cross-market</span>
                        )}
                      </div>
                      <p class="text-sm italic text-slate-500">{v.tagline}</p>
                    </div>
                  </div>

                  {v.reputation_flag && (
                    <div class="mb-3 rounded-md border-l-4 border-rose-500 bg-rose-50 px-4 py-3 text-sm text-rose-900">
                      <p class="font-bold uppercase tracking-wider text-xs text-rose-700 mb-1">⚠ Reputation warning</p>
                      <p class="leading-relaxed">{v.reputation_flag}</p>
                    </div>
                  )}

                  <p class="mb-3 text-sm text-slate-700 leading-relaxed">{v.market_position}</p>

                  {v.sa_specific_note && (
                    <div class="mb-3 rounded-md bg-slate-50 px-4 py-3">
                      <p class="text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">Saudi-specific note</p>
                      <p class="text-sm text-slate-700 leading-relaxed">{v.sa_specific_note}</p>
                    </div>
                  )}

                  <div class="mb-3 grid gap-3 sm:grid-cols-2">
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider text-emerald-700 mb-1">{isCert ? 'What it covers' : 'Pros'}</p>
                      <ul class="space-y-1 text-sm text-slate-700">
                        {v.pros.slice(0, 4).map(p => <li class="leading-snug">+ {p}</li>)}
                      </ul>
                    </div>
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider text-rose-700 mb-1">{isCert ? 'Watch out for' : 'Cons'}</p>
                      <ul class="space-y-1 text-sm text-slate-700">
                        {v.cons.slice(0, 4).map(con => <li class="leading-snug">− {con}</li>)}
                      </ul>
                    </div>
                  </div>

                  <div class="mb-3 text-xs text-slate-600">
                    <strong class="text-slate-900">{isCert ? 'Cost / access:' : 'Typical Saudi pricing:'}</strong> {v.typical_pricing}
                  </div>

                  <div class="flex flex-wrap gap-2">
                    <a href={`/sa/${v.slug}/`} class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700">Full Saudi review →</a>
                    <a href={v.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md bg-orange-500 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600">{isCert ? 'Official site' : `Visit ${v.name}`} →</a>
                    {v.cross_market_link && (
                      <a href={v.cross_market_link} class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Full review (US market context)</a>
                    )}
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      );
    })}

    <section class="mt-12 rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Are you a Saudi software vendor?</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">
        {vendors.length} Saudi vendors covered today, and we're expanding. If you build construction, ERP, accounting or field-service software for the Saudi/Gulf market and want to be reviewed or featured, get in touch through our <a href="/for-vendors/" class="underline">vendor program</a>.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/for-vendors/" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">Work with us →</a>
        <a href="/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">Back to US directory</a>
        <a href="/methodology/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Methodology</a>
      </div>
    </section>
  </article>
</Layout>
