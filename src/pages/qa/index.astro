---
import Layout from '../../layouts/Layout.astro';
import qaData from '../../data/international/qa.json';

interface QaVendor {
  slug: string; name: string; category: string; vendor_url: string;
  tagline: string; market_position: string; qa_specific_note?: string | null;
  tier: 'S' | 'A' | 'F'; reputation_flag: string | null;
  pros: string[]; cons: string[]; typical_pricing: string;
  is_cross_market: boolean; cross_market_link: string | null;
}

const vendors = (qaData as { vendors: QaVendor[] }).vendors;
const categories = ['software', 'certification'];
const categoryMeta: Record<string, { label: string; description: string }> = {
  'software': { label: 'Construction & trades software', description: 'The giga-project stack (Oracle Aconex & Primavera — Ashghal’s reference platform, Autodesk via Doha partners), regional ERPs with Qatar presence (Focus Softnet, PACT), Qatar-native SkyStruct, and CAFM tools (SWG, Insight) for facilities and labour-accommodation management.' },
  'certification': { label: 'Licensing & compliance', description: 'Monaqasat contractor classification, the GTA (no VAT yet) and a draft e-invoicing law, Qatarization (Law No. 12 of 2024), Baladiya building permits, Ashghal’s QCS 2014 construction code, and Kahramaa contractor accreditation.' },
};
const vendorsByCategory: Record<string, QaVendor[]> = {};
categories.forEach(c => { vendorsByCategory[c] = vendors.filter(v => v.category === c); });

const pageTitle = 'Qatar Construction & Trades Software — WrenchStack';
const pageDescription = `Independent directory of ${vendors.length} construction & trades vendors for Qatar: the giga-project PM/BIM stack, regional ERPs and CAFM, plus Monaqasat classification, QCS 2014, Qatarization and the (no-VAT-yet) tax landscape.`;
const breadcrumbs = [ { name: 'Home', url: '/' }, { name: 'Qatar', url: '/qa/' } ];
const enUrl = new URL('/qa/', Astro.site).toString();
const arUrl = new URL('/qa/ar/', Astro.site).toString();
---
<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs} alternateUrls={[{ hreflang: 'en', href: enUrl }, { hreflang: 'ar', href: arUrl }, { hreflang: 'x-default', href: enUrl }]}>
  <article class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-10">
      <div class="mb-3 flex items-center justify-between gap-3">
        <div class="flex items-center gap-2">
          <span class="text-2xl" aria-hidden="true">🇶🇦</span>
          <p class="text-sm font-semibold uppercase tracking-wider text-orange-600">Qatar · قطر</p>
        </div>
        <a href="/qa/ar/" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50">العربية</a>
      </div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">Qatar Construction & Trades Software Directory</h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        Independent reviews of {vendors.length} Qatar-relevant vendors — built around the post-World-Cup, LNG-funded pipeline. The giga-project platforms (Oracle Aconex & Primavera, the Ashghal standard), regional ERPs with real Doha presence (Focus Softnet, PACT), Qatar-native SkyStruct, and CAFM tools — with the local context (Monaqasat classification, Qatar Construction Specifications, Qatarization, and a tax regime with <em>no VAT yet</em>) that off-the-shelf software ignores.
      </p>
    </header>
    <section class="mb-10 grid gap-3 grid-cols-2 sm:grid-cols-4">
      {categories.map(c => (
        <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
          <div class="text-2xl font-bold text-slate-900">{vendorsByCategory[c].length}</div>
          <div class="mt-1 text-xs text-slate-600 capitalize">{c}</div>
        </div>
      ))}
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center"><div class="text-2xl font-bold text-slate-900">0%</div><div class="mt-1 text-xs text-slate-600">VAT (none yet)</div></div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center"><div class="text-2xl font-bold text-slate-900">QCS</div><div class="mt-1 text-xs text-slate-600">2014 code</div></div>
    </section>
    <section class="mb-10 flex flex-wrap items-center justify-between gap-4 rounded-lg border border-orange-200 bg-orange-50 p-5">
      <div>
        <h2 class="text-base font-bold text-slate-900">Deciding between two options?</h2>
        <p class="mt-1 text-sm text-slate-700">See Qatar vendors compared side by side — verdict, pros and cons, Qatar-specific notes, and pricing, head to head.</p>
      </div>
      <a href="/qa/compare/" class="shrink-0 rounded-md bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-700">Compare Qatar vendors →</a>
    </section>
    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-base font-bold text-slate-900">What’s different about choosing software in Qatar</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        Qatar’s biggest contrast with Saudi: <strong>there is no VAT yet</strong> — so construction billing software does <em>not</em> need a VAT/e-invoicing engine today (a GCC-framework ~5% VAT and a draft e-invoicing law are anticipated, but not in force). The tax that matters is corporate, not consumption. Labour runs on <strong>Qatarization</strong> (Law No. 12 of 2024), a different ruleset from Nitaqat/Emiratisation. Public work is gated by a <strong>Monaqasat classification</strong> certificate, the technical bible is <strong>QCS 2014</strong> (Ashghal-maintained, not an international code), and MEP/utility work needs <strong>Kahramaa</strong> accreditation. Pricing is in Qatari Riyal, and the local software ecosystem is thin — most options are regional/global with confirmed Doha delivery, plus the one Qatar-native product, SkyStruct.
      </p>
    </section>
    {categories.map(c => {
      const cat = categoryMeta[c];
      const cv = vendorsByCategory[c];
      if (cv.length === 0) return null;
      return (
        <section class="mb-12">
          <div class="mb-5">
            <h2 class="text-2xl font-bold text-slate-900">{cat.label}</h2>
            <p class="mt-1 text-sm text-slate-600 leading-relaxed">{cat.description}</p>
          </div>
          <div class="space-y-4">
            {cv.map(v => {
              const isCert = v.category === 'certification';
              const tierColor = v.tier === 'S' ? 'border-emerald-300' : v.tier === 'F' ? 'border-rose-300' : 'border-blue-300';
              const tierLabel = isCert ? 'Official body' : v.tier === 'S' ? 'Recommended' : v.tier === 'F' ? 'Reputation warning' : 'Workable';
              const tierBadge = v.tier === 'S' ? 'bg-emerald-100 text-emerald-900' : v.tier === 'F' ? 'bg-rose-100 text-rose-900' : 'bg-blue-100 text-blue-900';
              return (
                <article class={`rounded-lg border-2 ${tierColor} bg-white p-5`}>
                  <div class="mb-3 flex items-start justify-between gap-3">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center gap-2 mb-1 flex-wrap">
                        <h3 class="text-xl font-bold text-slate-900">{v.name}</h3>
                        <span class={`rounded-full px-2 py-0.5 text-xs font-bold ${tierBadge}`}>{isCert ? tierLabel : `Tier ${v.tier} · ${tierLabel}`}</span>
                        {v.is_cross_market && (<span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">Cross-market</span>)}
                      </div>
                      <p class="text-sm italic text-slate-500">{v.tagline}</p>
                    </div>
                  </div>
                  <p class="mb-3 text-sm text-slate-700 leading-relaxed">{v.market_position}</p>
                  {v.qa_specific_note && (
                    <div class="mb-3 rounded-md bg-slate-50 px-4 py-3">
                      <p class="text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">Qatar-specific note</p>
                      <p class="text-sm text-slate-700 leading-relaxed">{v.qa_specific_note}</p>
                    </div>
                  )}
                  <div class="mb-3 grid gap-3 sm:grid-cols-2">
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider text-emerald-700 mb-1">{isCert ? 'What it covers' : 'Pros'}</p>
                      <ul class="space-y-1 text-sm text-slate-700">{v.pros.slice(0, 4).map(p => <li class="leading-snug">+ {p}</li>)}</ul>
                    </div>
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider text-rose-700 mb-1">{isCert ? 'Watch out for' : 'Cons'}</p>
                      <ul class="space-y-1 text-sm text-slate-700">{v.cons.slice(0, 4).map(con => <li class="leading-snug">− {con}</li>)}</ul>
                    </div>
                  </div>
                  <div class="mb-3 text-xs text-slate-600"><strong class="text-slate-900">{isCert ? 'Cost / access:' : 'Typical Qatar pricing:'}</strong> {v.typical_pricing}</div>
                  <div class="flex flex-wrap gap-2">
                    <a href={`/qa/${v.slug}/`} class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700">Full Qatar review →</a>
                    <a href={v.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md bg-orange-500 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600">{isCert ? 'Official site' : `Visit ${v.name}`} →</a>
                    {v.cross_market_link && (<a href={v.cross_market_link} class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Full review (US market context)</a>)}
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      );
    })}
    <section class="mt-12 rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Are you a Qatar software vendor?</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">If you build construction, ERP, accounting or field-service software for the Qatar/Gulf market and want to be reviewed or featured, get in touch through our <a href="/for-vendors/" class="underline">vendor program</a>.</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/for-vendors/" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">Work with us →</a>
        <a href="/sa/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">🇸🇦 Saudi directory</a>
        <a href="/methodology/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Methodology</a>
      </div>
    </section>
  </article>
</Layout>
