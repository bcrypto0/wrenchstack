---
import Layout from '../../../layouts/Layout.astro';
import qaData from '../../../data/international/qa.json';

interface QaVendor {
  slug: string; name: string; category: string; vendor_url: string;
  tagline: string; tier: 'S' | 'A' | 'F';
  is_cross_market: boolean;
}
const vendors = (qaData as { vendors: QaVendor[] }).vendors;

// Concise Arabic positioning per vendor (detailed reviews remain in English for now).
const ar: Record<string, string> = {
  'oracle-aconex': 'معيار التحكم بالوثائق والتعاون على المشاريع العملاقة متعددة الأطراف.',
  'oracle-primavera-p6': 'أداة الجدولة ومراقبة المشاريع المعتمدة في الأعمال الحكومية والكبرى.',
  'autodesk-construction-cloud': 'العمود الفقري لنمذجة معلومات البناء (BIM) في المشاريع الكبرى.',
  'procore': 'منصة إدارة مشاريع إنشائية عالمية شاملة — قوية لكنها أمريكية المنشأ.',
  'planradar': 'أداة فحص الموقع وإدارة الملاحظات الأيسر للمقاولين المتوسطين، بدعم عربي.',
  'focus-softnet': 'نظام تخطيط موارد ومحاسبة مع تكاليف المشاريع، راسخ في المنطقة بمكاتب محلية.',
  'pact-erp': 'نظام تخطيط موارد للمقاولات — جداول كميات ومشتريات ورواتب.',
  'skystruct': 'منصة إدارة مشاريع إنشائية مبنية في قطر.',
  'swg-qatar': 'نظام إدارة مرافق (CAFM) وإدارة أداء مشاريع الشراكة بين القطاعين العام والخاص.',
  'insight-cafm': 'إدارة مرافق معسكرات العمال وسكن الموظفين.',
  'monaqasat': 'مناقصات — بوابة المشتريات الحكومية وتصنيف المقاولين.',
  'qatar-gta': 'الهيئة العامة للضرائب — ولا توجد ضريبة قيمة مضافة (حتى الآن).',
  'qatar-einvoicing': 'الفوترة الإلكترونية القطرية — مشروع قانون أُقرّ ولم يدخل حيز التنفيذ بعد.',
  'qatarization': 'التقطير (القانون رقم ١٢ لسنة ٢٠٢٤) — توطين وظائف القطاع الخاص.',
  'qatar-baladiya-permits': 'وزارة البلدية — نظام رخص البناء المدعوم بالذكاء الاصطناعي (بلدية).',
  'ashghal-qcs': 'أشغال ومواصفات البناء القطرية QCS 2014 — الكود الإنشائي الفعلي في قطر.',
  'kahramaa': 'كهرماء — اعتماد المقاولين لتوصيلات الكهرباء والماء.',
};

const tierAr: Record<string, string> = { S: 'موصى به', A: 'مقبول', F: 'تنبيه' };
const cats = [
  { key: 'software', label: 'برامج المقاولات والإنشاءات', desc: 'من منصات المشاريع العملاقة (أوراكل، أوتوديسك) وأداة قطرية المنشأ (سكاي ستركت) إلى أنظمة تخطيط الموارد وإدارة مرافق معسكرات العمال.' },
  { key: 'certification', label: 'التراخيص والامتثال', desc: 'الجهات القطرية التي يتعامل معها كل مقاول — مناقصات، الهيئة العامة للضرائب، الفوترة الإلكترونية (مشروع)، التقطير، رخص البناء البلدية، مواصفات QCS، وكهرماء.' },
];

const enUrl = new URL('/qa/', Astro.site).toString();
const arUrl = new URL('/qa/ar/', Astro.site).toString();
const pageTitle = 'دليل برامج المقاولات والإنشاءات في قطر';
const pageDescription = 'دليل مستقل لبرامج المقاولات والإنشاءات في قطر: منصات إدارة المشاريع وأنظمة تخطيط الموارد وإدارة المرافق — مع جهات الترخيص والامتثال المحلية (مناقصات، الضرائب، التقطير، مواصفات QCS، كهرماء).';
---

<Layout
  title={pageTitle}
  description={pageDescription}
  lang="ar"
  dir="rtl"
  alternateUrls={[{ hreflang: 'en', href: enUrl }, { hreflang: 'ar', href: arUrl }, { hreflang: 'x-default', href: enUrl }]}
>
  <article class="mx-auto max-w-5xl px-4 py-12">

    <div class="mb-6 flex items-center justify-between gap-3">
      <div class="flex items-center gap-2">
        <span class="text-2xl" aria-hidden="true">🇶🇦</span>
        <p class="text-sm font-semibold uppercase tracking-wider text-orange-600">دولة قطر</p>
      </div>
      <a href="/qa/" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50">English</a>
    </div>

    <header class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">دليل برامج المقاولات والإنشاءات في قطر</h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        مراجعات مستقلة لـ {vendors.length} منتجاً ذا صلة بالسوق القطري — منصات المشاريع العملاقة (أوراكل أكونكس، بريمافيرا، أوتوديسك)، وأداة قطرية المنشأ (سكاي ستركت)، وأنظمة تخطيط الموارد وإدارة المرافق — مع سياق الامتثال المحلي (مناقصات، التقطير، مواصفات QCS، كهرماء) الذي تتجاهله البرامج الأجنبية.
      </p>
    </header>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-base font-bold text-slate-900">ما الذي يميّز اختيار البرامج في قطر</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        يختلف اختيار برامج الإنشاءات في قطر عن الأسواق الغربية. أولاً، <strong>لا توجد ضريبة قيمة مضافة حتى الآن</strong>، و<strong>الفوترة الإلكترونية</strong> ما تزال مشروع قانون أُقرّ ولم يدخل حيز التنفيذ — لكنها قادمة، فاحرص على نظام قابل للتكيّف. ثانياً، يجب أن يدعم البرنامج <strong>العربية والريال القطري</strong>. ثالثاً، يتطلب العمل الحكومي التسجيل في <strong>مناقصات</strong> وتصنيف المقاولين، بينما يفرض <strong>التقطير (القانون ١٢ لسنة ٢٠٢٤)</strong> توطين الوظائف. والمعيار الفني الحاكم هو <strong>مواصفات البناء القطرية QCS 2014</strong>، مع اعتماد <strong>كهرماء</strong> لتوصيلات الكهرباء والماء. ومحرّك الطلب مشاريع ما بعد كأس العالم والبنية التحتية ضمن رؤية قطر ٢٠٣٠.
      </p>
    </section>

    {cats.map((cat) => {
      const cv = vendors.filter((v) => v.category === cat.key);
      if (cv.length === 0) return null;
      return (
        <section class="mb-12">
          <div class="mb-5">
            <h2 class="text-2xl font-bold text-slate-900">{cat.label}</h2>
            <p class="mt-1 text-sm text-slate-600 leading-relaxed">{cat.desc}</p>
          </div>
          <div class="grid gap-3 sm:grid-cols-2">
            {cv.map((v) => {
              const isCert = v.category === 'certification';
              const tierColor = v.tier === 'S' ? 'border-emerald-300' : v.tier === 'F' ? 'border-rose-300' : 'border-blue-300';
              const tierBadge = v.tier === 'S' ? 'bg-emerald-100 text-emerald-900' : v.tier === 'F' ? 'bg-rose-100 text-rose-900' : 'bg-blue-100 text-blue-900';
              const label = isCert ? 'جهة رسمية' : tierAr[v.tier];
              return (
                <article class={`rounded-lg border-2 ${tierColor} bg-white p-4`}>
                  <div class="mb-1 flex items-center gap-2 flex-wrap">
                    <h3 class="text-lg font-bold text-slate-900">{v.name}</h3>
                    <span class={`rounded-full px-2 py-0.5 text-xs font-bold ${tierBadge}`}>{label}</span>
                  </div>
                  <p class="text-sm text-slate-700 leading-relaxed">{ar[v.slug] ?? v.tagline}</p>
                  <div class="mt-3 flex flex-wrap gap-2">
                    <a href={`/qa/${v.slug}/`} class="rounded-md bg-slate-900 px-3 py-1.5 text-xs font-semibold text-white hover:bg-slate-700">التفاصيل (بالإنجليزية) ←</a>
                    <a href={v.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md bg-orange-500 px-3 py-1.5 text-xs font-semibold text-white hover:bg-orange-600">{isCert ? 'الموقع الرسمي' : 'زيارة الموقع'} ←</a>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      );
    })}

    <section class="mb-10 rounded-lg border border-slate-200 bg-white p-5 text-sm text-slate-600">
      <p>المراجعات التفصيلية لكل منتج متاحة حالياً <a href="/qa/" class="font-medium text-orange-600 hover:underline">بالإنجليزية</a>، ونعمل على توسيع المحتوى العربي تباعاً.</p>
    </section>

    <section class="rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">هل أنت مزوّد برامج قطري؟</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">إذا كنت تطوّر برامج للمقاولات أو تخطيط الموارد أو الخدمة الميدانية للسوق القطري/الخليجي وترغب في المراجعة أو الإدراج، تواصل معنا عبر <a href="/for-vendors/" class="underline">برنامج المزوّدين</a>.</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/for-vendors/" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">العمل معنا ←</a>
        <a href="/qa/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">English directory</a>
      </div>
    </section>
  </article>
</Layout>
