---
import Layout from '../../layouts/Layout.astro';
import kwData from '../../data/international/kw.json';

interface KwVendor {
  slug: string; name: string; category: string; vendor_url: string;
  tagline: string; market_position: string; kw_specific_note?: string | null;
  tier: 'S' | 'A' | 'F'; reputation_flag: string | null;
  pros: string[]; cons: string[]; typical_pricing: string;
  is_cross_market: boolean; cross_market_link: string | null;
}

const vendors = (kwData as { vendors: KwVendor[] }).vendors;
const categories = ['software', 'insurance', 'lead-gen', 'certification'];
const categoryMeta: Record<string, { label: string; description: string }> = {
  'insurance': { label: 'Contractor insurance', description: "Contractor & engineering cover from Kuwaiti insurers — market leader GIG Kuwait, Al Ahleia, and Shariah-compliant First Takaful. Quote-based." },
  'lead-gen': { label: 'Lead generation & project intelligence', description: "Construction project intelligence for Kuwait via ProTenders and BNC Network (the government tender portal CAPT sits under licensing & compliance)." },
  'software': { label: 'Construction & trades software', description: 'The enterprise stack for large public EPC work (Oracle, Autodesk via GIC Middle East), the strongest local ERP footprint (Focus Softnet — Kuwait office since 1996), accessible site tools (PlanRadar), regional ERPs (PACT, First Bit), and Kuwait-native/localised options (Octonics, Matiyas, In4Suite).' },
  'certification': { label: 'Licensing & compliance', description: 'CAPT contractor classification (the gate to public tenders), the Ministry of Finance tax regime (no VAT; 15% CIT on foreign entities), Public Authority for Manpower (Kuwaitization), Kuwait Municipality permits, and the mandatory KFSD fire code.' },
};
const vendorsByCategory: Record<string, KwVendor[]> = {};
categories.forEach(c => { vendorsByCategory[c] = vendors.filter(v => v.category === c); });

const pageTitle = 'Kuwait Construction & Trades Software — WrenchStack';
const pageDescription = `Independent directory of ${vendors.length} construction & trades vendors for Kuwait: the enterprise EPC stack, the strongest local ERPs, and site tools — plus CAPT classification, Kuwaitization, the KFSD fire code, and Kuwait’s no-VAT tax landscape.`;
const breadcrumbs = [ { name: 'Home', url: '/' }, { name: 'Kuwait', url: '/kw/' } ];
const enUrl = new URL('/kw/', Astro.site).toString();
const arUrl = new URL('/kw/ar/', Astro.site).toString();
---
<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs} alternateUrls={[{ hreflang: 'en', href: enUrl }, { hreflang: 'ar', href: arUrl }, { hreflang: 'x-default', href: enUrl }]}>
  <article class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-10">
      <div class="mb-3 flex items-center justify-between gap-3">
        <div class="flex items-center gap-2">
          <span class="text-2xl" aria-hidden="true">🇰🇼</span>
          <p class="text-sm font-semibold uppercase tracking-wider text-orange-600">Kuwait · الكويت</p>
        </div>
        <a href="/kw/ar/" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50">العربية</a>
      </div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">Kuwait Construction & Trades Software Directory</h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        Independent reviews of {vendors.length} Kuwait-relevant vendors — built around the New Kuwait 2035 / Silk City public-project pipeline. The enterprise EPC stack (Oracle, Autodesk via GIC Middle East), the strongest local ERP footprint (Focus Softnet, in Kuwait since 1996), accessible site tools (PlanRadar), and Kuwait-localised options — with the local context (CAPT classification, Kuwaitization, the KFSD fire code, and a tax regime with <em>no VAT</em>) that off-the-shelf software ignores.
      </p>
    </header>
    <section class="mb-10 grid gap-3 grid-cols-2 sm:grid-cols-4">
      {categories.map(c => (
        <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
          <div class="text-2xl font-bold text-slate-900">{vendorsByCategory[c].length}</div>
          <div class="mt-1 text-xs text-slate-600 capitalize">{c}</div>
        </div>
      ))}
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center"><div class="text-2xl font-bold text-slate-900">0%</div><div class="mt-1 text-xs text-slate-600">VAT (none)</div></div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center"><div class="text-2xl font-bold text-slate-900">CAPT</div><div class="mt-1 text-xs text-slate-600">classification</div></div>
    </section>
    <section class="mb-10 flex flex-wrap items-center justify-between gap-4 rounded-lg border border-orange-200 bg-orange-50 p-5">
      <div>
        <h2 class="text-base font-bold text-slate-900">Deciding between two options?</h2>
        <p class="mt-1 text-sm text-slate-700">See Kuwait vendors compared side by side — verdict, pros and cons, Kuwait-specific notes, and pricing, head to head.</p>
      </div>
      <a href="/kw/compare/" class="shrink-0 rounded-md bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-700">Compare Kuwait vendors →</a>
    </section>
    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-base font-bold text-slate-900">What’s different about choosing software in Kuwait</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        Like Qatar, Kuwait has <strong>no VAT</strong> (officially ruled out before 2028) and <strong>no e-invoicing mandate</strong> — so "VAT-ready / FTA-compliant" selling points that matter in the UAE and Saudi are irrelevant here. The tax that bites is <strong>15% corporate income tax on foreign-owned entities</strong> (plus a 5% retention on payments to foreign parties), not consumption tax. Public work is gated by a <strong>CAPT classification</strong> (1st–4th category, tied to Kuwaiti ownership and 3+ years of history), labour runs on <strong>Kuwaitization</strong> via PAM (construction sits at the low end, ~1%), fire safety follows the mandatory <strong>KFSD code</strong>, and pricing is in Kuwaiti Dinar — the world’s highest-valued currency. Kuwait’s local software ecosystem is thin, so most options are regional/global with confirmed Kuwait presence, plus a few locally-built ERPs.
      </p>
    </section>
    {categories.map(c => {
      const cat = categoryMeta[c];
      const cv = vendorsByCategory[c];
      if (cv.length === 0) return null;
      return (
        <section class="mb-12">
          <div class="mb-5">
            <h2 class="text-2xl font-bold text-slate-900">{cat.label}</h2>
            <p class="mt-1 text-sm text-slate-600 leading-relaxed">{cat.description}</p>
          </div>
          <div class="space-y-4">
            {cv.map(v => {
              const isCert = v.category === 'certification';
              const tierColor = v.tier === 'S' ? 'border-emerald-300' : v.tier === 'F' ? 'border-rose-300' : 'border-blue-300';
              const tierLabel = isCert ? 'Official body' : v.tier === 'S' ? 'Recommended' : v.tier === 'F' ? 'Reputation warning' : 'Workable';
              const tierBadge = v.tier === 'S' ? 'bg-emerald-100 text-emerald-900' : v.tier === 'F' ? 'bg-rose-100 text-rose-900' : 'bg-blue-100 text-blue-900';
              return (
                <article class={`rounded-lg border-2 ${tierColor} bg-white p-5`}>
                  <div class="mb-3 flex items-start justify-between gap-3">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center gap-2 mb-1 flex-wrap">
                        <h3 class="text-xl font-bold text-slate-900">{v.name}</h3>
                        <span class={`rounded-full px-2 py-0.5 text-xs font-bold ${tierBadge}`}>{isCert ? tierLabel : `Tier ${v.tier} · ${tierLabel}`}</span>
                        {v.is_cross_market && (<span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">Cross-market</span>)}
                      </div>
                      <p class="text-sm italic text-slate-500">{v.tagline}</p>
                    </div>
                  </div>
                  <p class="mb-3 text-sm text-slate-700 leading-relaxed">{v.market_position}</p>
                  {v.kw_specific_note && (
                    <div class="mb-3 rounded-md bg-slate-50 px-4 py-3">
                      <p class="text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">Kuwait-specific note</p>
                      <p class="text-sm text-slate-700 leading-relaxed">{v.kw_specific_note}</p>
                    </div>
                  )}
                  <div class="mb-3 grid gap-3 sm:grid-cols-2">
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider text-emerald-700 mb-1">{isCert ? 'What it covers' : 'Pros'}</p>
                      <ul class="space-y-1 text-sm text-slate-700">{v.pros.slice(0, 4).map(p => <li class="leading-snug">+ {p}</li>)}</ul>
                    </div>
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider text-rose-700 mb-1">{isCert ? 'Watch out for' : 'Cons'}</p>
                      <ul class="space-y-1 text-sm text-slate-700">{v.cons.slice(0, 4).map(con => <li class="leading-snug">− {con}</li>)}</ul>
                    </div>
                  </div>
                  <div class="mb-3 text-xs text-slate-600"><strong class="text-slate-900">{isCert ? 'Cost / access:' : 'Typical Kuwait pricing:'}</strong> {v.typical_pricing}</div>
                  <div class="flex flex-wrap gap-2">
                    <a href={`/kw/${v.slug}/`} class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700">Full Kuwait review →</a>
                    <a href={v.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md bg-orange-500 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600">{isCert ? 'Official site' : `Visit ${v.name}`} →</a>
                    {v.cross_market_link && (<a href={v.cross_market_link} class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Full review (US market context)</a>)}
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      );
    })}
    <section class="mt-12 rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Are you a Kuwait software vendor?</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">If you build construction, ERP, accounting or field-service software for the Kuwait/Gulf market and want to be reviewed or featured, get in touch through our <a href="/for-vendors/" class="underline">vendor program</a>.</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/for-vendors/" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">Work with us →</a>
        <a href="/sa/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">🇸🇦 Saudi directory</a>
        <a href="/methodology/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Methodology</a>
      </div>
    </section>
  </article>
</Layout>
