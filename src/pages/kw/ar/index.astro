---
import Layout from '../../../layouts/Layout.astro';
import kwData from '../../../data/international/kw.json';

interface KwVendor {
  slug: string; name: string; category: string; vendor_url: string;
  tagline: string; tier: 'S' | 'A' | 'F';
  is_cross_market: boolean;
}
const vendors = (kwData as { vendors: KwVendor[] }).vendors;

// Concise Arabic positioning per vendor (detailed reviews remain in English for now).
const ar: Record<string, string> = {
  'oracle-aconex': 'معيار التحكم بالوثائق والتعاون على المشاريع العملاقة متعددة الأطراف.',
  'autodesk-construction-cloud': 'العمود الفقري لنمذجة معلومات البناء (BIM) في المشاريع الكبرى.',
  'planradar': 'أداة فحص الموقع وإدارة الملاحظات الأيسر للمقاولين المتوسطين، بدعم عربي.',
  'focus-softnet': 'نظام تخطيط موارد ومحاسبة مع تكاليف المشاريع، راسخ في المنطقة بمكاتب محلية.',
  'pact-erp': 'نظام تخطيط موارد للمقاولات — جداول كميات ومشتريات ورواتب.',
  'first-bit-erp': 'نظام تخطيط موارد إنشائي — تقدير الكميات والتكاليف والمحاسبة.',
  'in4suite': 'نظام تخطيط موارد للعقارات والإنشاءات.',
  'octonics': 'نظام تخطيط موارد كويتي ثنائي اللغة (حلول مخصصة).',
  'matiyas-kuwait': 'نظام ERPNext مع تخصيص كويتي للإنشاءات والرواتب.',
  'capt': 'الجهاز المركزي للمناقصات العامة — يدير المناقصات ويصنّف المقاولين.',
  'kuwait-tax': 'ضرائب الكويت (وزارة المالية) — ضريبة دخل ١٥٪ على الكيانات الأجنبية، ولا ضريبة قيمة مضافة.',
  'pam-kuwaitization': 'الهيئة العامة للقوى العاملة — قانون العمل والتصاريح ونسب التكويت.',
  'kuwait-municipality': 'بلدية الكويت — رخص البناء والموافقات الإنشائية.',
  'kuwait-fire-force': 'الإطفاء الكويتي — كود الوقاية من الحريق (KFSD) الإلزامي.',
};

const tierAr: Record<string, string> = { S: 'موصى به', A: 'مقبول', F: 'تنبيه' };
const cats = [
  { key: 'software', label: 'برامج المقاولات والإنشاءات', desc: 'من منصات المشاريع العملاقة (أوراكل، أوتوديسك) إلى أنظمة تخطيط الموارد الإقليمية والكويتية المنشأ (أوكتونيكس، ماتياس) للعقارات والإنشاءات.' },
  { key: 'certification', label: 'التراخيص والامتثال', desc: 'الجهات الكويتية التي يتعامل معها كل مقاول — الجهاز المركزي للمناقصات، الضرائب، الهيئة العامة للقوى العاملة (التكويت)، بلدية الكويت، وكود الإطفاء (KFSD).' },
];

const enUrl = new URL('/kw/', Astro.site).toString();
const arUrl = new URL('/kw/ar/', Astro.site).toString();
const pageTitle = 'دليل برامج المقاولات والإنشاءات في الكويت';
const pageDescription = 'دليل مستقل لبرامج المقاولات والإنشاءات في الكويت: منصات إدارة المشاريع وأنظمة تخطيط الموارد — مع جهات الترخيص والامتثال المحلية (المناقصات، الضرائب، التكويت، البلدية، كود الإطفاء KFSD).';
---

<Layout
  title={pageTitle}
  description={pageDescription}
  lang="ar"
  dir="rtl"
  alternateUrls={[{ hreflang: 'en', href: enUrl }, { hreflang: 'ar', href: arUrl }, { hreflang: 'x-default', href: enUrl }]}
>
  <article class="mx-auto max-w-5xl px-4 py-12">

    <div class="mb-6 flex items-center justify-between gap-3">
      <div class="flex items-center gap-2">
        <span class="text-2xl" aria-hidden="true">🇰🇼</span>
        <p class="text-sm font-semibold uppercase tracking-wider text-orange-600">دولة الكويت</p>
      </div>
      <a href="/kw/" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50">English</a>
    </div>

    <header class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">دليل برامج المقاولات والإنشاءات في الكويت</h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        مراجعات مستقلة لـ {vendors.length} منتجاً ذا صلة بالسوق الكويتي — منصات المشاريع العملاقة (أوراكل أكونكس، أوتوديسك)، وأنظمة تخطيط الموارد الإقليمية والكويتية المنشأ (أوكتونيكس، ماتياس) — مع سياق الامتثال المحلي (المناقصات، التكويت، البلدية، كود الإطفاء KFSD) الذي تتجاهله البرامج الأجنبية.
      </p>
    </header>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-base font-bold text-slate-900">ما الذي يميّز اختيار البرامج في الكويت</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        يختلف اختيار برامج الإنشاءات في الكويت عن الأسواق الغربية. أولاً، <strong>لا توجد ضريبة قيمة مضافة</strong> (وضريبة الدخل ١٥٪ تقتصر على الكيانات الأجنبية)، ولا يوجد إلزام بالفوترة الإلكترونية — لكن البرنامج يجب أن يدعم <strong>العربية والدينار الكويتي</strong>. ثانياً، يمر العمل الحكومي عبر <strong>الجهاز المركزي للمناقصات العامة</strong> الذي يصنّف المقاولين، بينما تفرض <strong>الهيئة العامة للقوى العاملة</strong> نسب التكويت على التوظيف. ثالثاً، <strong>كود الإطفاء (KFSD)</strong> إلزامي في تصميم المباني والموافقات. ومحرّك الطلب مشاريع رؤية كويت ٢٠٣٥ والبنية التحتية.
      </p>
    </section>

    {cats.map((cat) => {
      const cv = vendors.filter((v) => v.category === cat.key);
      if (cv.length === 0) return null;
      return (
        <section class="mb-12">
          <div class="mb-5">
            <h2 class="text-2xl font-bold text-slate-900">{cat.label}</h2>
            <p class="mt-1 text-sm text-slate-600 leading-relaxed">{cat.desc}</p>
          </div>
          <div class="grid gap-3 sm:grid-cols-2">
            {cv.map((v) => {
              const isCert = v.category === 'certification';
              const tierColor = v.tier === 'S' ? 'border-emerald-300' : v.tier === 'F' ? 'border-rose-300' : 'border-blue-300';
              const tierBadge = v.tier === 'S' ? 'bg-emerald-100 text-emerald-900' : v.tier === 'F' ? 'bg-rose-100 text-rose-900' : 'bg-blue-100 text-blue-900';
              const label = isCert ? 'جهة رسمية' : tierAr[v.tier];
              return (
                <article class={`rounded-lg border-2 ${tierColor} bg-white p-4`}>
                  <div class="mb-1 flex items-center gap-2 flex-wrap">
                    <h3 class="text-lg font-bold text-slate-900">{v.name}</h3>
                    <span class={`rounded-full px-2 py-0.5 text-xs font-bold ${tierBadge}`}>{label}</span>
                  </div>
                  <p class="text-sm text-slate-700 leading-relaxed">{ar[v.slug] ?? v.tagline}</p>
                  <div class="mt-3 flex flex-wrap gap-2">
                    <a href={`/kw/${v.slug}/`} class="rounded-md bg-slate-900 px-3 py-1.5 text-xs font-semibold text-white hover:bg-slate-700">التفاصيل (بالإنجليزية) ←</a>
                    <a href={v.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md bg-orange-500 px-3 py-1.5 text-xs font-semibold text-white hover:bg-orange-600">{isCert ? 'الموقع الرسمي' : 'زيارة الموقع'} ←</a>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      );
    })}

    <section class="mb-10 rounded-lg border border-slate-200 bg-white p-5 text-sm text-slate-600">
      <p>المراجعات التفصيلية لكل منتج متاحة حالياً <a href="/kw/" class="font-medium text-orange-600 hover:underline">بالإنجليزية</a>، ونعمل على توسيع المحتوى العربي تباعاً.</p>
    </section>

    <section class="rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">هل أنت مزوّد برامج كويتي؟</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">إذا كنت تطوّر برامج للمقاولات أو تخطيط الموارد أو الخدمة الميدانية للسوق الكويتي/الخليجي وترغب في المراجعة أو الإدراج، تواصل معنا عبر <a href="/for-vendors/" class="underline">برنامج المزوّدين</a>.</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/for-vendors/" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">العمل معنا ←</a>
        <a href="/kw/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">English directory</a>
      </div>
    </section>
  </article>
</Layout>
