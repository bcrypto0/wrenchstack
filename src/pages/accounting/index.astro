---
import Layout from '../../layouts/Layout.astro';
import { accountingSoftware, accountingByPosition, ACCOUNTING_POSITION_META } from '../../lib/data';

const grouped = accountingByPosition();

const pageTitle = `Best Accounting Software for Contractors & Trades (2026)`;
const pageDescription = `Independent comparison of accounting software for trades — QuickBooks Online, Xero, FreshBooks, Wave — by positioning (full accounting vs invoicing-first vs free). Real pricing, honest trade-offs, and which one your field-service software actually syncs to.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Accounting', url: '/accounting/' },
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Accounting Software for Trades Contractors',
  numberOfItems: accountingSoftware.length,
  itemListElement: accountingSoftware.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'SoftwareApplication',
      name: a.name,
      description: a.tagline,
      url: `https://wrenchstack.com/accounting/${a.slug}/`,
    },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <article class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-10">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-sky-600">Accounting</p>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">
        Best Accounting Software for Contractors & Trades (2026)
      </h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        Your accounting software is where your books live — and what your field-service tool syncs to. We compare the options trades actually use, organized by how much accounting you really need. Real pricing, honest trade-offs, affiliate-transparent.
      </p>
    </header>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-base font-bold text-slate-900">The headline filter: how much accounting do you need?</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        <strong>Full double-entry accounting</strong> (QuickBooks Online, Xero) is the standard once you have employees, inventory, or an accountant — and it's what nearly every FSM integrates with. <strong>Invoicing-first</strong> (FreshBooks) is ideal for solo and small service businesses that prioritize billing over deep books. <strong>Free</strong> (Wave) fits brand-new or very small operations watching every dollar. The biggest practical factor for trades: <strong>QuickBooks has the deepest field-service integration</strong>, so check what your scheduling tool syncs to before you choose.
      </p>
    </section>

    {grouped.map(({ position, software }) => {
      const meta = ACCOUNTING_POSITION_META[position];
      return (
        <section class="mb-12">
          <div class="mb-5">
            <span class="inline-block rounded-full bg-sky-100 px-3 py-1 text-xs font-bold uppercase tracking-wider text-sky-900 ring-1 ring-sky-300">{meta.label}</span>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">{meta.blurb}</p>
          </div>

          <div class="space-y-4">
            {software.map((a) => (
              <article class="rounded-lg border-2 border-sky-200 bg-white p-5">
                <div class="mb-3 flex items-start justify-between gap-3">
                  <div class="min-w-0 flex-1">
                    <h3 class="text-xl font-bold text-slate-900">
                      <a href={`/accounting/${a.slug}/`} class="hover:text-sky-600">{a.name}</a>
                    </h3>
                    <p class="text-sm italic text-slate-500">{a.tagline}</p>
                  </div>
                  <div class="shrink-0 text-right text-xs">
                    <p class="font-bold text-slate-900">{a.starting_price_usd === 0 ? 'Free' : a.starting_price_usd !== null ? `From $${a.starting_price_usd}/mo` : 'Custom'}</p>
                  </div>
                </div>

                {a.reputation_flag && (
                  <div class="mb-3 rounded-md border-l-4 border-rose-500 bg-rose-50 px-4 py-3 text-sm text-rose-900">
                    <p class="font-bold uppercase tracking-wider text-xs text-rose-700 mb-1">⚠ Heads up</p>
                    <p class="leading-relaxed">{a.reputation_flag.split('.')[0]}.</p>
                  </div>
                )}

                <dl class="mb-3 grid grid-cols-2 gap-2 text-xs sm:grid-cols-4">
                  <div>
                    <dt class="text-slate-500 uppercase tracking-wider">G2 / Capterra</dt>
                    <dd class="font-semibold text-slate-900">{a.ratings.g2 !== null || a.ratings.capterra !== null ? `${a.ratings.g2 !== null ? a.ratings.g2.toFixed(1) : '—'} / ${a.ratings.capterra !== null ? a.ratings.capterra.toFixed(1) : '—'}` : '—'}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500 uppercase tracking-wider">Founded</dt>
                    <dd class="font-semibold text-slate-900">{a.founded ?? '—'}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500 uppercase tracking-wider">Free trial</dt>
                    <dd class="font-semibold text-slate-900">{a.starting_price_usd === 0 ? 'Free plan' : a.free_trial_days > 0 ? `${a.free_trial_days} days` : 'No'}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500 uppercase tracking-wider">Best team size</dt>
                    <dd class="font-semibold text-slate-900">{a.best_team_size}</dd>
                  </div>
                </dl>

                <p class="mb-3 text-sm text-slate-700 leading-relaxed">
                  <strong class="text-slate-900">Best for:</strong> {a.best_for}
                </p>

                <div class="flex flex-wrap gap-2">
                  <a href={`/accounting/${a.slug}/`} class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800">Read full review →</a>
                  <a href={a.affiliate_url.startsWith('http') ? a.affiliate_url : a.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md border border-sky-300 bg-white px-4 py-2 text-sm font-semibold text-sky-700 hover:bg-sky-50">Visit {a.name}</a>
                </div>
              </article>
            ))}
          </div>
        </section>
      );
    })}

    <section class="mt-12 rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Where to start</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">
        Most trades shops default to <strong>QuickBooks Online</strong> because their FSM and accountant both speak it. Want unlimited users and cleaner pricing? <strong>Xero</strong>. Solo operator who mainly needs great invoicing? <strong>FreshBooks</strong>. Brand-new and watching every dollar? <strong>Wave</strong> (free). Before deciding, confirm what your field-service software actually syncs to — that integration matters more than a few dollars of monthly price.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/accounting/quickbooks-online/" class="rounded-md bg-sky-500 px-5 py-3 text-sm font-semibold text-white hover:bg-sky-600">See QuickBooks Online →</a>
        <a href="/payroll/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">Payroll</a>
        <a href="/payments/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Payments</a>
      </div>
    </section>
  </article>
</Layout>
