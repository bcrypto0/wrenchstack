---
import Layout from '../../../layouts/Layout.astro';
import { accountingSoftware, ACCOUNTING_POSITION_META, type AccountingSoftware } from '../../../lib/data';

export async function getStaticPaths() {
  return accountingSoftware.map((a) => ({
    params: { slug: a.slug },
    props: { software: a },
  }));
}

interface Props { software: AccountingSoftware; }
const { software } = Astro.props;
const positionLabel = ACCOUNTING_POSITION_META[software.positioning].label;

const siblings = accountingSoftware.filter((a) => a.slug !== software.slug).slice(0, 6);

const pageTitle = `${software.name} Review (2026): Pricing, Pros & Cons for Contractors`;
const pageDescription = `${software.name} accounting review for trades. ${software.tagline}. Real pricing, FSM integration notes, and honest trade-offs. Updated ${new Date().getFullYear()}.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Accounting', url: '/accounting/' },
  { name: software.name, url: `/accounting/${software.slug}/` },
];

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: software.name,
  description: software.tagline,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Web',
  offers: software.starting_price_usd !== null ? { '@type': 'Offer', price: software.starting_price_usd, priceCurrency: 'USD' } : undefined,
  ...(software.ratings.capterra !== null && {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: software.ratings.capterra.toFixed(1),
      bestRating: '5',
      reviewCount: 300,
    },
  }),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: software.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <article class="mx-auto max-w-4xl px-4 py-12">
    <header class="mb-8">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-sky-600">Accounting · {positionLabel}</p>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">{software.name} Review</h1>
      <p class="mt-3 text-lg italic text-slate-600">{software.tagline}</p>

      <div class="mt-5 flex flex-wrap items-center gap-2">
        <span class="inline-block rounded-full bg-sky-100 px-3 py-1 text-xs font-bold uppercase tracking-wider text-sky-900 ring-1 ring-sky-300">{positionLabel}</span>
        <span class="inline-block rounded-full bg-slate-100 px-3 py-1 text-xs font-bold uppercase tracking-wider text-slate-700">{software.starting_price_usd === 0 ? 'Free plan' : software.starting_price_usd !== null ? `From $${software.starting_price_usd}/mo` : 'Custom'}</span>
      </div>

      <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm text-slate-600">
        {software.founded !== null && <span>Founded {software.founded}</span>}
        {software.headquartered && <span>HQ {software.headquartered}</span>}
        <span>Verified: {software.verified_date}</span>
        {software.ratings.capterra !== null && <span>Capterra {software.ratings.capterra.toFixed(1)} / 5</span>}
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href={software.affiliate_url.startsWith('http') ? software.affiliate_url : software.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md bg-sky-500 px-5 py-3 text-sm font-semibold text-white hover:bg-sky-600">Visit {software.name} →</a>
        <a href="/accounting/" class="rounded-md border border-slate-300 bg-white px-4 py-3 text-sm font-medium text-slate-700 hover:bg-slate-50">See all accounting</a>
      </div>
    </header>

    {software.reputation_flag && (
      <section class="mb-10 rounded-lg border-2 border-rose-300 bg-rose-50 p-6">
        <div class="mb-2 flex items-center gap-2">
          <span class="text-xl">⚠</span>
          <h2 class="text-lg font-bold text-rose-900">Heads up</h2>
        </div>
        <p class="text-sm text-rose-900 leading-relaxed">{software.reputation_flag}</p>
      </section>
    )}

    <nav class="mb-8 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 md:sticky md:top-2 md:z-30 md:bg-white/95 md:backdrop-blur">
      <div class="text-xs font-semibold uppercase tracking-wider text-slate-700">Jump to</div>
      <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-sm">
        <a href="#pricing" class="text-sky-600 hover:underline">Pricing</a>
        <span class="text-slate-300">·</span>
        <a href="#how-it-works" class="text-sky-600 hover:underline">How it works</a>
        <span class="text-slate-300">·</span>
        <a href="#pros-cons" class="text-sky-600 hover:underline">Pros & Cons</a>
        <span class="text-slate-300">·</span>
        <a href="#features" class="text-sky-600 hover:underline">Features</a>
        <span class="text-slate-300">·</span>
        <a href="#faqs" class="text-sky-600 hover:underline">FAQs</a>
      </div>
    </nav>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-lg font-bold text-slate-900">Quick verdict</h2>
      <p class="text-slate-700 leading-relaxed">
        <strong class="text-slate-900">{software.name}</strong> is best for {software.best_for}. {software.weaknesses}.
      </p>
    </section>

    <section id="pricing" class="mb-10 scroll-mt-8">
      <h2 class="mb-3 text-2xl font-bold text-slate-900">Pricing</h2>
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <p class="font-semibold text-slate-900">{software.pricing_summary}.</p>
        <p class="mt-3 text-sm text-slate-700"><strong class="text-slate-900">Affiliate disclosure:</strong> {software.affiliate_payout_note}.</p>
      </div>
    </section>

    <section class="mb-10 prose prose-slate max-w-none">
      <h2>About {software.name}</h2>
      {software.long_description.split('\n\n').map((p) => <p>{p}</p>)}
    </section>

    <section id="how-it-works" class="mb-10 scroll-mt-8">
      <h2 class="mb-3 text-2xl font-bold text-slate-900">How it works</h2>
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <p class="text-slate-700 leading-relaxed">{software.how_it_works}</p>
      </div>
    </section>

    <section id="pros-cons" class="mb-10 scroll-mt-8">
      <h2 class="mb-5 text-2xl font-bold text-slate-900">Pros & cons</h2>
      <div class="mb-6">
        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-emerald-700">What works</h3>
        <ul class="space-y-3">
          {software.pros_detail.map((p) => (
            <li class="rounded-lg border-l-4 border-emerald-400 bg-emerald-50 px-4 py-3">
              <p class="font-semibold text-emerald-900">{p.title}</p>
              <p class="mt-1 text-sm text-emerald-900 leading-relaxed">{p.explanation}</p>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-rose-700">What doesn't</h3>
        <ul class="space-y-3">
          {software.cons_detail.map((c) => (
            <li class="rounded-lg border-l-4 border-rose-400 bg-rose-50 px-4 py-3">
              <p class="font-semibold text-rose-900">{c.title}</p>
              <p class="mt-1 text-sm text-rose-900 leading-relaxed">{c.explanation}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section id="features" class="mb-10 scroll-mt-8">
      <h2 class="mb-3 text-2xl font-bold text-slate-900">Features & integrations</h2>
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <div class="mb-3">
          <p class="mb-1 text-xs font-bold uppercase tracking-wider text-slate-500">Key features</p>
          <div class="flex flex-wrap gap-1">
            {software.key_features.map((f) => (
              <span class="rounded-md bg-sky-50 px-2 py-0.5 text-xs text-sky-800">{f.replace(/_/g, ' ')}</span>
            ))}
          </div>
        </div>
        <div>
          <p class="mb-1 text-xs font-bold uppercase tracking-wider text-slate-500">Integrations</p>
          <div class="flex flex-wrap gap-1">
            {software.integrations.map((i) => (
              <span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs">{i.replace(/_/g, ' ')}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-10 scroll-mt-8">
      <h2 class="mb-5 text-2xl font-bold text-slate-900">Frequently asked</h2>
      <div class="space-y-3">
        {software.faqs.map((f) => (
          <details class="rounded-lg border border-slate-200 bg-white p-4">
            <summary class="cursor-pointer font-semibold text-slate-900">{f.q}</summary>
            <p class="mt-3 text-slate-700 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="mb-10">
      <h2 class="mb-5 text-2xl font-bold text-slate-900">Other accounting software</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {siblings.map((s) => (
          <a href={`/accounting/${s.slug}/`} class="block rounded-lg border border-slate-200 bg-white p-4 no-underline transition hover:border-sky-300 hover:bg-sky-50">
            <p class="mb-1 font-semibold text-slate-900">{s.name}</p>
            <p class="text-xs text-slate-500 line-clamp-2">{s.tagline}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Browse more</h2>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/accounting/" class="rounded-md bg-sky-500 px-5 py-3 text-sm font-semibold text-white hover:bg-sky-600">All accounting software</a>
        <a href="/payroll/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">Payroll</a>
        <a href="/tools/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Software directory</a>
      </div>
    </section>
  </article>
</Layout>
