---
import Layout from '../../../layouts/Layout.astro';
import { awards, getTool, aggregateRating, formatPrice, wrenchStackScore } from '../../../lib/data';
import ToolLogo from '../../../components/ToolLogo.astro';
import WrenchScore from '../../../components/WrenchScore.astro';

const pageTitle = `WrenchStack Awards ${awards.year}: Best Trades Software by Category`;
const pageDescription = `WrenchStack's ${awards.year} editorial awards for trades software — winners in ${awards.categories.length} categories spanning HVAC, plumbing, electrical, roofing, landscaping, cleaning, pest control, pool service, CMMS, and construction PM. No vendor paid for placement.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Awards', url: '/awards/' },
  { name: `${awards.year} Awards`, url: `/awards/${awards.year}/` },
];

// Build a category → tool map for rendering
const categoriesWithTools = awards.categories.map((cat) => {
  const winner = getTool(cat.winner_slug);
  const honorableMentions = cat.honorable_mentions
    .map((slug) => getTool(slug))
    .filter((t): t is NonNullable<typeof t> => !!t);
  return { ...cat, winner, honorableMentions };
});

// Schema.org ItemList for the awards
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `WrenchStack Awards ${awards.year}`,
  numberOfItems: categoriesWithTools.length,
  itemListElement: categoriesWithTools.map((cat, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Thing',
      name: cat.label,
      description: cat.why,
      ...(cat.winner ? { url: `https://wrenchstack.com/tools/${cat.winner.slug}/` } : {}),
    },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <article class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-10">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-orange-600">
        Editorial awards · {awards.year}
      </p>
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        WrenchStack Awards {awards.year}
      </h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        The best trades software in {categoriesWithTools.length} categories, selected by WrenchStack editorial. No vendor paid for placement. No "shortlist" badges sold. The full methodology is published below.
      </p>
      <p class="mt-2 text-sm text-slate-500">
        Published {awards.published_date} · Updates annually
      </p>
    </header>

    <section class="mb-10 rounded-lg border border-amber-200 bg-amber-50 p-6">
      <h2 class="mb-3 text-lg font-bold text-amber-900">How winners are chosen</h2>
      <p class="text-sm text-amber-900 leading-relaxed">
        {awards.methodology_summary}
      </p>
      <p class="mt-3 text-sm text-amber-800">
        Read the full <a href="/methodology/" class="underline hover:text-amber-700">scoring methodology</a> for rubric weights, data sources, and the per-vendor affiliate-disclosure ledger.
      </p>
    </section>

    <nav class="mb-10 rounded-lg bg-slate-50 p-4">
      <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-slate-600">Jump to category</p>
      <div class="flex flex-wrap gap-x-3 gap-y-1 text-sm">
        {categoriesWithTools.map((cat) => (
          <a href={`#${cat.slug}`} class="text-orange-600 hover:underline">{cat.label.replace(/ \d{4}$/, '')}</a>
        ))}
      </div>
    </nav>

    <div class="space-y-12">
      {categoriesWithTools.map((cat) => (
        <section id={cat.slug} class="scroll-mt-8">
          <div class="mb-4 flex items-baseline justify-between gap-4">
            <h2 class="text-2xl font-bold text-slate-900">{cat.label}</h2>
            <a href={`#${cat.slug}`} class="text-xs text-slate-400 hover:text-slate-600">#</a>
          </div>

          <p class="mb-5 text-sm italic text-slate-600">{cat.buyer_signal}</p>

          {cat.winner && (
            <div class="rounded-lg border-2 border-amber-300 bg-gradient-to-br from-amber-50 to-white p-6">
              <div class="mb-3 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 text-amber-600">
                  <path d="M12 2l2.39 4.84L20 7.5l-3.91 3.81.93 5.39L12 14.27l-5.02 2.43.93-5.39L4 7.5l5.61-.66L12 2z" />
                </svg>
                <span class="text-xs font-bold uppercase tracking-wider text-amber-700">Winner</span>
              </div>

              <div class="mb-4 flex items-start gap-4">
                <ToolLogo tool={cat.winner} size={56} />
                <div class="flex-1 min-w-0">
                  <h3 class="text-xl font-bold text-slate-900">
                    <a href={`/tools/${cat.winner.slug}/`} class="hover:text-orange-600">{cat.winner.name}</a>
                  </h3>
                  <p class="text-sm italic text-slate-600">{cat.winner.tagline}</p>
                </div>
                <div class="shrink-0 hidden sm:block">
                  <WrenchScore score={wrenchStackScore(cat.winner)} size="sm" />
                </div>
              </div>

              <p class="mb-4 text-slate-700 leading-relaxed">{cat.why}</p>

              <dl class="mb-5 grid grid-cols-2 gap-3 text-sm md:grid-cols-4">
                <div>
                  <dt class="text-xs uppercase tracking-wider text-slate-500">Starting price</dt>
                  <dd class="font-semibold text-slate-900">{formatPrice(cat.winner)}</dd>
                </div>
                <div>
                  <dt class="text-xs uppercase tracking-wider text-slate-500">User rating</dt>
                  <dd class="font-semibold text-slate-900">
                    {aggregateRating(cat.winner) !== null ? `${aggregateRating(cat.winner)!.toFixed(1)} / 5` : '—'}
                  </dd>
                </div>
                <div>
                  <dt class="text-xs uppercase tracking-wider text-slate-500">Best team size</dt>
                  <dd class="font-semibold text-slate-900">{cat.winner.best_team_size ?? '—'}</dd>
                </div>
                <div>
                  <dt class="text-xs uppercase tracking-wider text-slate-500">Free trial</dt>
                  <dd class="font-semibold text-slate-900">
                    {cat.winner.pricing.free_trial_days && cat.winner.pricing.free_trial_days > 0 ? `${cat.winner.pricing.free_trial_days} days` : 'No'}
                  </dd>
                </div>
              </dl>

              <div class="flex flex-wrap gap-2">
                <a
                  href={`/tools/${cat.winner.slug}/`}
                  class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800"
                >
                  Read full {cat.winner.name} review →
                </a>
                <a
                  href={cat.winner.affiliate_url.startsWith('http') ? cat.winner.affiliate_url : cat.winner.vendor_url}
                  rel="sponsored nofollow noopener"
                  target="_blank"
                  class="rounded-md border border-orange-300 bg-white px-4 py-2 text-sm font-semibold text-orange-700 hover:bg-orange-50"
                >
                  Visit {cat.winner.name} →
                </a>
              </div>
            </div>
          )}

          {cat.honorableMentions.length > 0 && (
            <div class="mt-5">
              <p class="mb-3 text-xs font-bold uppercase tracking-wider text-slate-600">
                Honorable mentions
              </p>
              <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
                {cat.honorableMentions.map((hm) => (
                  <a
                    href={`/tools/${hm.slug}/`}
                    class="flex items-center gap-3 rounded-lg border border-slate-200 bg-white p-3 no-underline hover:border-orange-300 hover:bg-orange-50"
                  >
                    <ToolLogo tool={hm} size={36} />
                    <div class="min-w-0 flex-1">
                      <p class="truncate text-sm font-semibold text-slate-900">{hm.name}</p>
                      <p class="truncate text-xs text-slate-500">{hm.tagline}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </section>
      ))}
    </div>

    <section class="mt-16 rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Not finding your category?</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">
        We add categories each year as new verticals reach the editorial threshold. Take the matching quiz for a personalized recommendation based on your trade, team size, and budget, or browse our full directory of {awards.year === 2026 ? '59' : 'all'} tools.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/quiz/" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">
          Take the matching quiz →
        </a>
        <a href="/tools/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">
          Browse all tools
        </a>
        <a href="/compare-builder/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">
          Build a comparison
        </a>
      </div>
    </section>

    <section class="mt-10 rounded-lg border border-slate-200 bg-slate-50 p-6">
      <h2 class="mb-3 text-base font-bold text-slate-900">Editorial independence disclosure</h2>
      <ul class="space-y-2 text-sm text-slate-700 leading-relaxed">
        <li>
          <strong class="text-slate-900">No paid placements.</strong> Vendors cannot purchase award positions, "shortlist" badges, or featured listings.
        </li>
        <li>
          <strong class="text-slate-900">Affiliate relationships disclosed.</strong> Where WrenchStack earns affiliate commission on a winner, it's disclosed on that tool's review page and in our public per-vendor <a href="/methodology/#affiliate-ledger" class="underline hover:text-slate-900">affiliate ledger</a>. Recommendations are unchanged whether the affiliate is active or pending.
        </li>
        <li>
          <strong class="text-slate-900">Methodology is published.</strong> The rubric, weights, data sources, and verification cadence live on the <a href="/methodology/" class="underline hover:text-slate-900">methodology page</a>.
        </li>
        <li>
          <strong class="text-slate-900">Updated annually.</strong> Next refresh: {awards.year + 1}. We re-evaluate every category each year based on current pricing, ratings, and platform changes.
        </li>
      </ul>
    </section>
  </article>
</Layout>
