---
import Layout from '../../../layouts/Layout.astro';
import joData from '../../../data/international/jo.json';

interface JoVendor {
  slug: string; name: string; category: string; vendor_url: string;
  tagline: string; tier: 'S' | 'A' | 'F';
  is_cross_market: boolean;
}
const vendors = (joData as { vendors: JoVendor[] }).vendors;

// Concise Arabic positioning per vendor (the detailed reviews remain in English for now).
const ar: Record<string, string> = {
  'invoiceq': 'منصة فوترة إلكترونية متخصصة بـ«الفوترة الوطنية» تتكامل مع أنظمتك الحالية — بأسعار معلنة بالدينار.',
  'mozon': 'بيت برمجيات عمّاني مع وحدة مقاولات مخصّصة وموصّلات جاهزة للفوترة الوطنية — الأنسب للمقاولين الأردنيين.',
  'odoo': 'نظام تخطيط موارد عالمي مفتوح المصدر مع توطين أردني أصلي ووحدة فوترة وطنية (l10n_jo_edi)، عبر شركاء محليين.',
  'daftra': 'منصة محاسبة وفوترة عربية أولاً بتكامل مباشر مع الفوترة الوطنية، وملف لقطاع العقارات والإنشاءات.',
  'fawtraplus': 'تطبيق فوترة أردني منخفض التكلفة معتمد للفوترة الوطنية (~٥٠ ديناراً/سنة) — مثالي للمنشآت الصغيرة جداً.',
  'fatwarti': 'محاسبة ونقاط بيع أردنية بربط مباشر مع الفوترة الوطنية عبر الواجهة الرسمية (API).',
  'stride-bs': 'شريك تطبيق Odoo في عمّان يتولّى التكامل مع الفوترة الوطنية والدعم باللغة العربية.',
  'tax2gov': 'وسيط برمجي يربط أنظمتك الحالية بمنصة الفوترة الوطنية للأحجام الكبيرة — مع إضافة لـ Odoo.',
  'eskadenia': 'شركة برمجيات أردنية عريقة بنظام موارد واسع — لكن دون وحدة إنشاءات مخصّصة أو تأكيد للفوترة الوطنية (تحقّق أولاً).',
  'zoho-books': 'محاسبة سحابية عالمية رخيصة — لكن دون دعم أصلي للفوترة الوطنية؛ تتطلّب موصّلاً خارجياً للامتثال.',
  'quickbooks': 'محاسبة عالمية للمنشآت الصغيرة — غير متوافقة مع الفوترة الوطنية إلا عبر وسيط (مثل InvoiceQ).',
  'joneps': 'منصة الشراء الإلكتروني الحكومية الأردنية (JONEPS) — حيث تُطرح وتُرسى عطاءات الإنشاءات العامة.',
  'jordantenders': 'خدمة اشتراك تجمّع عطاءات الأردن (بما فيها الإنشاءات) في تنبيهات قابلة للتصفية — مُجمِّع أجنبي، تحقّق من حداثته.',
  'jofico': 'الشركة الأردنية الفرنسية للتأمين (جوفيكو، منذ ١٩٧٦) — تأمين هندسي شامل و«مخاطر المقاولين» مذكورة على موقعها.',
  'arabia-insurance-jordan': 'العربية للتأمين – الأردن — خط هندسي كامل (مخاطر المقاولين والتركيب) موضّح بالإنجليزية على موقعها.',
  'gig-jordan': 'gig – الأردن (الشرق العربي، ضمن مجموعة الخليج) — الشركة الرائدة بقدرة اكتتاب عالية للمشاريع الكبرى.',
  'jordan-insurance-company': 'الشركة الأردنية للتأمين — أعرق شركة تأمين في الأردن (منذ ١٩٥١) مع خط هندسي وتأمين مسؤولية مهنية.',
  'meico-jordan': 'الشرق الأوسط للتأمين (منذ ١٩٦٢) — قوية في التأمين الهندسي والبحري؛ التفاصيل عبر الوسيط.',
  'zenhr': 'نظام رواتب وموارد بشرية أردني حديث — يذكر صراحةً التوافق مع الضمان الاجتماعي وضريبة الدخل ومكافأة نهاية الخدمة.',
  'menaitech-menapay': 'بيت رواتب عمّاني عريق (منذ ٢٠٠٣) — حزمة موارد بشرية متكاملة مع معالجة اقتطاعات الضمان الاجتماعي.',
  'yomly': 'منصة رواتب وموارد بشرية مؤسسية (دبي) مع عرض مخصّص للأردن — تحقّق من معالجة الضمان الاجتماعي تحديداً.',
  'gts-one-erp': 'رواتب وموارد بشرية أردنية مدمجة مع نظام موارد — لكن دعم الضمان الاجتماعي غير موضّح على الموقع (تحقّق أولاً).',
  'jordan-construction-contractors-association': 'نقابة مقاولي الإنشاءات + التصنيف — البوابة الإلزامية للتقدم على العطاءات الحكومية (درجات حتى الدرجة الأولى).',
  'jordan-engineers-association': 'نقابة المهندسين الأردنيين — التسجيل إلزامي لمزاولة الهندسة، ويُلبّي شرط «المهندس المقيم» في التصنيف.',
  'companies-control-department': 'دائرة مراقبة الشركات — التسجيل التجاري، الخطوة القانونية الأولى وشرط مسبق للتصنيف.',
  'income-and-sales-tax-department': 'دائرة ضريبة الدخل والمبيعات — الملف الضريبي، ضريبة المبيعات ١٦٪، ومنصة الفوترة الوطنية الإلزامية.',
  'social-security-corporation': 'المؤسسة العامة للضمان الاجتماعي — التسجيل إلزامي من أول موظف (~٢١٫٧٥٪ من الأجر).',
};

const tierAr: Record<string, string> = { S: 'موصى به', A: 'مقبول', F: 'تنبيه' };
const cats = [
  { key: 'software', label: 'برامج المحاسبة والفوترة والإنشاءات', desc: 'سوق متخم بأدوات الفوترة الوطنية — منصات وموصّلات (InvoiceQ، فاتورتي، فوترة بلس، Tax2Gov)، محاسبة عربية (دفترة)، وأنظمة موارد عالمية موطّنة (Odoo). الأدوات الإنشائية المتخصّصة قليلة — وحدة مقاولات «موزون» هي الأبرز.' },
  { key: 'lead-gen', label: 'العطاءات وتوليد الفرص', desc: 'قليلة بصدق في الأردن: منصة الشراء الحكومية (JONEPS) حيث تُرسى عطاءات الإنشاءات، ومُجمِّع عطاءات بالاشتراك (JordanTenders). لا توجد منصة سوق إنشائية أردنية، ولن نختلق واحدة.' },
  { key: 'insurance', label: 'تأمين الإنشاءات — مخاطر المقاولين', desc: 'تغطية «مخاطر المقاولين» والتأمين الهندسي من كبرى شركات التأمين الأردنية (جوفيكو، العربية، gig، الأردنية، الشرق الأوسط). عبر الوسطاء فقط، دون عروض أسعار على الإنترنت.' },
  { key: 'payroll', label: 'الرواتب — الضمان وضريبة الدخل', desc: 'الخيار الأردني الحديث ZenHR، والشركة العريقة MenaITech، وكذلك Yomly وGTS One. كل صاحب عمل ملزم بالتسجيل في الضمان من أول موظف.' },
  { key: 'certification', label: 'الامتثال والجهات الرسمية', desc: 'السلسلة القانونية للمقاول الأردني — تسجيل الشركة (مراقبة الشركات)، الملف الضريبي والفوترة الوطنية، عضوية النقابة والتصنيف (بوابة العطاءات)، نقابة المهندسين، والضمان الاجتماعي.' },
];

const enUrl = new URL('/jo/', Astro.site).toString();
const arUrl = new URL('/jo/ar/', Astro.site).toString();
const pageTitle = 'دليل برامج المقاولات والإنشاءات في الأردن — الفوترة الوطنية';
const pageDescription = 'دليل مستقل لبرامج المقاولات والإنشاءات في الأردن: أنظمة محاسبة وفوترة متوافقة مع الفوترة الوطنية، الوصول إلى العطاءات الحكومية، رواتب الضمان الاجتماعي، وتأمين مخاطر المقاولين — مع سياق الامتثال المحلي (الفوترة الوطنية، التصنيف، الضمان).';
---

<Layout
  title={pageTitle}
  description={pageDescription}
  lang="ar"
  dir="rtl"
  alternateUrls={[{ hreflang: 'en', href: enUrl }, { hreflang: 'ar', href: arUrl }, { hreflang: 'x-default', href: enUrl }]}
>
  <article class="mx-auto max-w-5xl px-4 py-12">

    <div class="mb-6 flex items-center justify-between gap-3">
      <div class="flex items-center gap-2">
        <span class="text-2xl" aria-hidden="true">🇯🇴</span>
        <p class="text-sm font-semibold uppercase tracking-wider text-orange-600">المملكة الأردنية الهاشمية</p>
      </div>
      <a href="/jo/" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50">English</a>
    </div>

    <header class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">دليل برامج المقاولات والإنشاءات في الأردن</h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        مراجعات مستقلة لـ {vendors.length} منتجاً ذا صلة بالسوق الأردني — يهيمن عليها عامل واحد: نظام «الفوترة الوطنية» الإلزامي الفعّال. أدوات محاسبة وفوترة جاهزة للفوترة الوطنية (InvoiceQ، موزون، دفترة، Odoo)، والوصول إلى العطاءات الحكومية (JONEPS)، ورواتب الضمان الاجتماعي (ZenHR، MenaITech)، وتأمين «مخاطر المقاولين» (جوفيكو، gig، الأردنية) — مع السياق المحلي (ضريبة المبيعات ١٦٪، التصنيف لدى النقابة، الضمان الاجتماعي من أول موظف، والدينار المربوط بالدولار) الذي تتجاهله البرامج الأجنبية.
      </p>
    </header>

    <section class="mb-10 flex flex-wrap items-center justify-between gap-4 rounded-lg border-2 border-emerald-300 bg-emerald-50 p-5">
      <div>
        <p class="text-xs font-bold tracking-wider text-emerald-700">⏰ دليل امتثال · الفوترة الوطنية فعّالة وإلزامية · المرحلة الثانية منذ ١ أبريل ٢٠٢٥ · بلا إعفاءات</p>
        <h2 class="mt-1 text-base font-bold text-slate-900">الفوترة الوطنية (JoFotara) لشركات المقاولات الأردنية</h2>
        <p class="mt-1 text-sm text-slate-700">نموذج التخليص، ومن يلتزم (الجميع — بلا حدّ أدنى)، ولماذا تُقبل الفواتير المخلّصة فقط للخصم الضريبي، وأي الأنظمة متكاملة فعلاً.</p>
      </div>
      <a href="/jo/ar/guides/jofotara-e-invoicing/" class="shrink-0 rounded-md bg-emerald-700 px-5 py-3 text-sm font-semibold text-white hover:bg-emerald-800">اقرأ الدليل ←</a>
    </section>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-base font-bold text-slate-900">ما الذي يميّز اختيار البرامج في الأردن</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        يهيمن على اختيار البرامج في الأردن عامل واحد: <strong>الفوترة الوطنية فعّالة وملزمة.</strong> منذ ١ أبريل ٢٠٢٥، على كل منشأة — بلا حدّ أدنى وبلا إعفاء — تمرير فواتيرها عبر منصة دائرة ضريبة الدخل والمبيعات، حيث تُخلَّص كل فاتورة قبل إصدارها قانونياً (XML/JSON بمعيار UBL 2.1، وتوقيع رقمي إلزامي، ورمز QR يُعاد عند التخليص). والعقوبات حقيقية: الفاتورة غير المخلّصة <strong>لا تُقبل للخصم الضريبي</strong>، والغرامات تصل إلى ٥٠٠ دينار، والأهم للمقاولين: <strong>عدم الامتثال يُقصيك من العطاءات الحكومية.</strong> ثانياً، <strong>الأدوات الإنشائية المتخصّصة قليلة</strong> — معظم السوق أدوات فوترة، فيقرن المقاول غالباً أداة امتثال بأداة لإدارة المشاريع (وحدة «موزون» وOdoo عبر الشركاء هما الأقرب لحلٍّ شامل). وضريبة المبيعات <strong>١٦٪</strong> (لا ١٥٪ كالسعودية ولا ٥٪ كالإمارات)، والتصنيف لدى نقابة المقاولين يفتح العطاءات، والضمان الاجتماعي إلزامي من أول موظف (~٢١٫٧٥٪). والدينار مربوط بالدولار، فلا مخاطر صرف.
      </p>
    </section>

    {cats.map((cat) => {
      const cv = vendors.filter((v) => v.category === cat.key);
      if (cv.length === 0) return null;
      return (
        <section class="mb-12">
          <div class="mb-5">
            <h2 class="text-2xl font-bold text-slate-900">{cat.label}</h2>
            <p class="mt-1 text-sm text-slate-600 leading-relaxed">{cat.desc}</p>
          </div>
          <div class="grid gap-3 sm:grid-cols-2">
            {cv.map((v) => {
              const isCert = v.category === 'certification';
              const tierColor = v.tier === 'S' ? 'border-emerald-300' : v.tier === 'F' ? 'border-rose-300' : 'border-blue-300';
              const tierBadge = v.tier === 'S' ? 'bg-emerald-100 text-emerald-900' : v.tier === 'F' ? 'bg-rose-100 text-rose-900' : 'bg-blue-100 text-blue-900';
              const label = isCert ? 'جهة رسمية' : tierAr[v.tier];
              return (
                <article class={`rounded-lg border-2 ${tierColor} bg-white p-4`}>
                  <div class="mb-1 flex items-center gap-2 flex-wrap">
                    <h3 class="text-lg font-bold text-slate-900">{v.name}</h3>
                    <span class={`rounded-full px-2 py-0.5 text-xs font-bold ${tierBadge}`}>{label}</span>
                  </div>
                  <p class="text-sm text-slate-700 leading-relaxed">{ar[v.slug] ?? v.tagline}</p>
                  <div class="mt-3 flex flex-wrap gap-2">
                    <a href={`/jo/${v.slug}/`} class="rounded-md bg-slate-900 px-3 py-1.5 text-xs font-semibold text-white hover:bg-slate-700">التفاصيل (بالإنجليزية) ←</a>
                    <a href={v.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md bg-orange-500 px-3 py-1.5 text-xs font-semibold text-white hover:bg-orange-600">{isCert ? 'الموقع الرسمي' : 'زيارة الموقع'} ←</a>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      );
    })}

    <section class="mb-10 rounded-lg border border-slate-200 bg-white p-5 text-sm text-slate-600">
      <p>المراجعات التفصيلية لكل منتج متاحة حالياً <a href="/jo/" class="font-medium text-orange-600 hover:underline">بالإنجليزية</a>، ونعمل على توسيع المحتوى العربي تباعاً.</p>
    </section>

    <section class="rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">هل أنت مزوّد برامج أردني؟</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">إذا كنت تطوّر برامج للمقاولات أو المحاسبة أو الفوترة الوطنية أو الرواتب للسوق الأردني وترغب في المراجعة أو الإدراج، تواصل معنا عبر <a href="/for-vendors/" class="underline">برنامج المزوّدين</a>.</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/for-vendors/" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">العمل معنا ←</a>
        <a href="/jo/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">English directory</a>
      </div>
    </section>
  </article>
</Layout>
