---
import Layout from '../../layouts/Layout.astro';
import maData from '../../data/international/ma.json';

interface MaVendor {
  slug: string; name: string; category: string; vendor_url: string;
  tagline: string; market_position: string; ma_specific_note?: string | null;
  tier: 'S' | 'A' | 'F'; reputation_flag: string | null;
  pros: string[]; cons: string[]; typical_pricing: string;
  is_cross_market: boolean; cross_market_link: string | null;
}

const vendors = (maData as { vendors: MaVendor[] }).vendors;
const categories = ['software', 'lead-gen', 'payroll', 'insurance', 'certification'];
const categoryMeta: Record<string, { label: string; description: string }> = {
  'software': { label: 'BTP software & DGI-compliant invoicing', description: 'Moroccan-native all-in-ones that also do local accounting (Gestion BTP), the imported devis-facture standards bought through local integrators (EBP, Sage Batigest, Odoo), and the new e-invoicing-ready tools racing to be “conforme DGI” (Hisab, Fawatir AI, Aube).' },
  'lead-gen': { label: 'Lead generation & tender intelligence', description: 'Two real channels in Morocco: public-tender intelligence for the BTP marchés-publics pipeline (Datao, Aljady), and consumer artisan marketplaces (Sabab, Bricole, Allopro, Bricoul). There is no Western-style B2B contractor marketplace here — we don’t pretend otherwise.' },
  'payroll': { label: 'Payroll (paie) — CNSS / IR / AMO', description: 'The localized Sage 100 standard, the Moroccan-native OJRA with native Damancom EDI, and Humantal — built specifically for BTP crews with GPS pointage and multi-chantier rules.' },
  'insurance': { label: 'Construction insurance — TRC & décennale', description: 'Mandatory cover under Loi 59-13 (Tous Risques Chantier + responsabilité civile décennale) from Morocco’s major insurers — Wafa, RMA, AtlantaSanad, AXA (BATISSUR) and Allianz. Broker-placed; no instant online quotes.' },
  'certification': { label: 'Compliance & official bodies', description: 'What a Moroccan contractor must navigate — the DGI e-invoicing mandate and SIMPL portal, the Qualification & Classification passport for public tenders, CNSS registration, the ICE required on every invoice, and the Registre de Commerce.' },
};
const vendorsByCategory: Record<string, MaVendor[]> = {};
categories.forEach(c => { vendorsByCategory[c] = vendors.filter(v => v.category === c); });

const pageTitle = 'Morocco Construction & Trades Software (BTP) — WrenchStack';
const pageDescription = `Independent directory of ${vendors.length} vendors for Moroccan building trades (BTP): devis-facture & DGI-compliant software, public-tender lead-gen, CNSS payroll, and mandatory Loi 59-13 construction insurance — plus the e-invoicing mandate, Qualification & Classification and ICE compliance every contractor must handle.`;
const breadcrumbs = [ { name: 'Home', url: '/' }, { name: 'Morocco', url: '/ma/' } ];
const enUrl = new URL('/ma/', Astro.site).toString();
const frUrl = new URL('/ma/fr/', Astro.site).toString();
---
<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs} alternateUrls={[{ hreflang: 'en', href: enUrl }, { hreflang: 'fr', href: frUrl }, { hreflang: 'x-default', href: enUrl }]}>
  <article class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-10">
      <div class="mb-3 flex items-center justify-between gap-3">
        <div class="flex items-center gap-2">
          <span class="text-2xl" aria-hidden="true">🇲🇦</span>
          <p class="text-sm font-semibold uppercase tracking-wider text-orange-600">Morocco · Maroc · BTP</p>
        </div>
        <a href="/ma/fr/" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50">Français</a>
      </div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">Morocco Construction & Trades Software Directory</h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        Independent reviews of {vendors.length} Morocco-relevant vendors for the building trades (BTP) — Moroccan-native and imported devis-facture software, public-tender intelligence (Datao, Aljady), CNSS payroll (Sage, OJRA, Humantal) and mandatory construction insurance (Wafa, RMA, AXA) — built around the local realities: the incoming DGI e-invoicing mandate, Loi 59-13 décennale cover, the Qualification & Classification passport for public work, and a pipeline lifted by World Cup 2030.
      </p>
    </header>

    <section class="mb-10 grid gap-3 grid-cols-2 sm:grid-cols-4">
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">{vendors.length}</div>
        <div class="mt-1 text-xs text-slate-600">vendors reviewed</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">~$41B</div>
        <div class="mt-1 text-xs text-slate-600">World Cup 2030 pipeline</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">120bn MAD</div>
        <div class="mt-1 text-xs text-slate-600">Al Haouz reconstruction</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">20%</div>
        <div class="mt-1 text-xs text-slate-600">standard TVA</div>
      </div>
    </section>

    <section class="mb-10 flex flex-wrap items-center justify-between gap-4 rounded-lg border-2 border-emerald-300 bg-emerald-50 p-5">
      <div>
        <p class="text-xs font-bold uppercase tracking-wider text-emerald-700">⏰ Compliance guide · Clearance model · 2026, large firms first · exact date pending the decree</p>
        <h2 class="mt-1 text-base font-bold text-slate-900">Facturation électronique (DGI e-invoicing) for Moroccan contractors</h2>
        <p class="mt-1 text-sm text-slate-700">The verified legal basis (Article 145-IX du CGI), the clearance model, who is affected first, and which tools already generate compliant UBL — without inventing a deadline the decree hasn’t fixed.</p>
      </div>
      <a href="/ma/guides/facturation-electronique-maroc/" class="shrink-0 rounded-md bg-emerald-700 px-5 py-3 text-sm font-semibold text-white hover:bg-emerald-800">Read the guide →</a>
    </section>

    <section class="mb-10 flex flex-wrap items-center justify-between gap-4 rounded-lg border border-orange-200 bg-orange-50 p-5">
      <div>
        <h2 class="text-base font-bold text-slate-900">Deciding between two options?</h2>
        <p class="mt-1 text-sm text-slate-700">See Moroccan vendors compared side by side — a clear verdict, pros and cons, Morocco-specific notes, and pricing, head to head.</p>
      </div>
      <a href="/ma/compare/" class="shrink-0 rounded-md bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-700">Compare Moroccan vendors →</a>
    </section>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-base font-bold text-slate-900">What’s different about choosing software in Morocco</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        Moroccan BTP software selection has structural differences from Europe. First, <strong>mandatory e-invoicing is coming</strong> — the DGI is rolling out a <strong>clearance model</strong> (every invoice validated by the tax platform before it reaches the client, in structured UBL) under Article 145-IX of the CGI, starting in 2026 with large B2B firms; the exact start date is still <em>pending the implementing decree</em>, so don’t trust any source that quotes a firm month. Second, the biggest practical trap: <strong>imported tools don’t do Moroccan accounting or payroll.</strong> EBP and Sage Batigest handle devis and situations de travaux beautifully but not PCGE comptabilité, TVA marocaine or CNSS — so you either pair them with a local tool or pick a Moroccan-native all-in-one (Gestion BTP) or a localized Odoo. Third, <strong>construction insurance is now mandatory</strong> — Loi 59-13 (in force since end-2024) requires Tous Risques Chantier and responsabilité civile décennale, gated on a prior contrôle technique and placed through a broker, not bought online. Fourth, public work is gated by the <strong>Qualification & Classification</strong> certificate, and your <strong>ICE</strong> must appear on every invoice. Pricing is in dirham, B2B runs in French, and the <strong>MOWAKABA</strong> program can subsidise up to 90% (TPE) of the cost of going digital.
      </p>
    </section>

    {categories.map(c => {
      const cat = categoryMeta[c];
      const cv = vendorsByCategory[c];
      if (cv.length === 0) return null;
      return (
        <section class="mb-12">
          <div class="mb-5">
            <h2 class="text-2xl font-bold text-slate-900">{cat.label}</h2>
            <p class="mt-1 text-sm text-slate-600 leading-relaxed">{cat.description}</p>
          </div>
          <div class="space-y-4">
            {cv.map(v => {
              const isCert = v.category === 'certification';
              const tierColor = v.tier === 'S' ? 'border-emerald-300' : v.tier === 'F' ? 'border-rose-300' : 'border-blue-300';
              const tierLabel = isCert ? 'Official body / regime' : v.tier === 'S' ? 'Recommended' : v.tier === 'F' ? 'Reputation warning' : 'Workable';
              const tierBadge = v.tier === 'S' ? 'bg-emerald-100 text-emerald-900' : v.tier === 'F' ? 'bg-rose-100 text-rose-900' : 'bg-blue-100 text-blue-900';
              return (
                <article class={`rounded-lg border-2 ${tierColor} bg-white p-5`}>
                  <div class="mb-3 flex items-start justify-between gap-3">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center gap-2 mb-1 flex-wrap">
                        <h3 class="text-xl font-bold text-slate-900">{v.name}</h3>
                        <span class={`rounded-full px-2 py-0.5 text-xs font-bold ${tierBadge}`}>{isCert ? tierLabel : `Tier ${v.tier} · ${tierLabel}`}</span>
                        {v.is_cross_market && (<span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">Cross-market</span>)}
                      </div>
                      <p class="text-sm italic text-slate-500">{v.tagline}</p>
                    </div>
                  </div>
                  <p class="mb-3 text-sm text-slate-700 leading-relaxed">{v.market_position}</p>
                  {v.ma_specific_note && (
                    <div class="mb-3 rounded-md bg-slate-50 px-4 py-3">
                      <p class="text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">Morocco-specific note</p>
                      <p class="text-sm text-slate-700 leading-relaxed">{v.ma_specific_note}</p>
                    </div>
                  )}
                  <div class="mb-3 grid gap-3 sm:grid-cols-2">
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider text-emerald-700 mb-1">{isCert ? 'What it covers' : 'Pros'}</p>
                      <ul class="space-y-1 text-sm text-slate-700">{v.pros.slice(0, 4).map(p => <li class="leading-snug">+ {p}</li>)}</ul>
                    </div>
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider text-rose-700 mb-1">{isCert ? 'Watch out for' : 'Cons'}</p>
                      <ul class="space-y-1 text-sm text-slate-700">{v.cons.slice(0, 4).map(con => <li class="leading-snug">− {con}</li>)}</ul>
                    </div>
                  </div>
                  <div class="mb-3 text-xs text-slate-600"><strong class="text-slate-900">{isCert ? 'Cost / access:' : 'Typical Morocco pricing:'}</strong> {v.typical_pricing}</div>
                  <div class="flex flex-wrap gap-2">
                    <a href={`/ma/${v.slug}/`} class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700">Full Morocco review →</a>
                    <a href={v.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md bg-orange-500 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600">{isCert ? 'Official site' : `Visit ${v.name}`} →</a>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      );
    })}

    <section class="mt-12 rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Are you a Moroccan software vendor?</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">If you build software or services for Moroccan contractors and the building trades and want to be reviewed or featured, get in touch through our <a href="/for-vendors/" class="underline">vendor program</a>.</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/for-vendors/" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">Work with us →</a>
        <a href="/sa/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">🇸🇦 Saudi directory</a>
        <a href="/methodology/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Methodology</a>
      </div>
    </section>
  </article>
</Layout>
