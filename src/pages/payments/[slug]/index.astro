---
import Layout from '../../../layouts/Layout.astro';
import { paymentProcessors, PAYMENT_MODEL_META, type PaymentProcessor } from '../../../lib/data';

export async function getStaticPaths() {
  return paymentProcessors.map((p) => ({
    params: { slug: p.slug },
    props: { processor: p },
  }));
}

interface Props { processor: PaymentProcessor; }
const { processor } = Astro.props;
const modelLabel = PAYMENT_MODEL_META[processor.pricing_model].label;

const siblings = paymentProcessors.filter((p) => p.slug !== processor.slug).slice(0, 6);

const pageTitle = `${processor.name} Review (2026): Rates, Pros & Cons for Contractors`;
const pageDescription = `${processor.name} payment processing review for trades. ${processor.tagline}. ${processor.reputation_flag ? 'Includes documented reputation context. ' : ''}Real rates, honest trade-offs. Updated ${new Date().getFullYear()}.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Payments', url: '/payments/' },
  { name: processor.name, url: `/payments/${processor.slug}/` },
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'FinancialProduct',
  name: processor.name,
  description: processor.tagline,
  ...(processor.ratings.capterra !== null && {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: processor.ratings.capterra.toFixed(1),
      bestRating: '5',
      reviewCount: 40,
    },
  }),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: processor.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <article class="mx-auto max-w-4xl px-4 py-12">
    <header class="mb-8">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-teal-600">Payments · {modelLabel}</p>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">{processor.name} Review</h1>
      <p class="mt-3 text-lg italic text-slate-600">{processor.tagline}</p>

      <div class="mt-5 flex flex-wrap items-center gap-2">
        <span class="inline-block rounded-full bg-teal-100 px-3 py-1 text-xs font-bold uppercase tracking-wider text-teal-900 ring-1 ring-teal-300">{modelLabel}</span>
        <span class="inline-block rounded-full bg-slate-100 px-3 py-1 text-xs font-bold uppercase tracking-wider text-slate-700">{processor.monthly_fee} monthly</span>
      </div>

      <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm text-slate-600">
        {processor.founded !== null && <span>Founded {processor.founded}</span>}
        {processor.headquartered && <span>HQ {processor.headquartered}</span>}
        <span>Verified: {processor.verified_date}</span>
        {processor.ratings.capterra !== null && <span>Capterra {processor.ratings.capterra.toFixed(1)} / 5</span>}
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href={processor.affiliate_url.startsWith('http') ? processor.affiliate_url : processor.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md bg-teal-500 px-5 py-3 text-sm font-semibold text-white hover:bg-teal-600">Visit {processor.name} →</a>
        <a href="/payments/" class="rounded-md border border-slate-300 bg-white px-4 py-3 text-sm font-medium text-slate-700 hover:bg-slate-50">See all processors</a>
      </div>
    </header>

    {processor.reputation_flag && (
      <section class="mb-10 rounded-lg border-2 border-rose-300 bg-rose-50 p-6">
        <div class="mb-2 flex items-center gap-2">
          <span class="text-xl">⚠</span>
          <h2 class="text-lg font-bold text-rose-900">Reputation warning</h2>
        </div>
        <p class="text-sm text-rose-900 leading-relaxed">{processor.reputation_flag}</p>
      </section>
    )}

    <nav class="mb-8 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 md:sticky md:top-2 md:z-30 md:bg-white/95 md:backdrop-blur">
      <div class="text-xs font-semibold uppercase tracking-wider text-slate-700">Jump to</div>
      <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-sm">
        <a href="#rates" class="text-teal-600 hover:underline">Rates</a>
        <span class="text-slate-300">·</span>
        <a href="#how-it-works" class="text-teal-600 hover:underline">How it works</a>
        <span class="text-slate-300">·</span>
        <a href="#pros-cons" class="text-teal-600 hover:underline">Pros & Cons</a>
        <span class="text-slate-300">·</span>
        <a href="#features" class="text-teal-600 hover:underline">Features</a>
        <span class="text-slate-300">·</span>
        <a href="#faqs" class="text-teal-600 hover:underline">FAQs</a>
      </div>
    </nav>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-lg font-bold text-slate-900">Quick verdict</h2>
      <p class="text-slate-700 leading-relaxed">
        <strong class="text-slate-900">{processor.name}</strong> is best for {processor.best_for}. {processor.weaknesses}.
      </p>
    </section>

    <section id="rates" class="mb-10 scroll-mt-8">
      <h2 class="mb-3 text-2xl font-bold text-slate-900">Rates & pricing</h2>
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <p class="font-semibold text-slate-900">{processor.pricing_summary}.</p>
        <p class="mt-2 text-sm text-slate-600">Pricing model: <span class="capitalize">{processor.pricing_model.replace(/-/g, ' ')}</span> · Monthly fee: {processor.monthly_fee}</p>
        <p class="mt-3 text-sm text-slate-700"><strong class="text-slate-900">Affiliate disclosure:</strong> {processor.affiliate_payout_note}.</p>
      </div>
    </section>

    <section class="mb-10 prose prose-slate max-w-none">
      <h2>About {processor.name}</h2>
      {processor.long_description.split('\n\n').map((p) => <p>{p}</p>)}
    </section>

    <section id="how-it-works" class="mb-10 scroll-mt-8">
      <h2 class="mb-3 text-2xl font-bold text-slate-900">How it works</h2>
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <p class="text-slate-700 leading-relaxed">{processor.how_it_works}</p>
      </div>
    </section>

    <section id="pros-cons" class="mb-10 scroll-mt-8">
      <h2 class="mb-5 text-2xl font-bold text-slate-900">Pros & cons</h2>
      <div class="mb-6">
        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-emerald-700">What works</h3>
        <ul class="space-y-3">
          {processor.pros_detail.map((p) => (
            <li class="rounded-lg border-l-4 border-emerald-400 bg-emerald-50 px-4 py-3">
              <p class="font-semibold text-emerald-900">{p.title}</p>
              <p class="mt-1 text-sm text-emerald-900 leading-relaxed">{p.explanation}</p>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-rose-700">What doesn't</h3>
        <ul class="space-y-3">
          {processor.cons_detail.map((c) => (
            <li class="rounded-lg border-l-4 border-rose-400 bg-rose-50 px-4 py-3">
              <p class="font-semibold text-rose-900">{c.title}</p>
              <p class="mt-1 text-sm text-rose-900 leading-relaxed">{c.explanation}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section id="features" class="mb-10 scroll-mt-8">
      <h2 class="mb-3 text-2xl font-bold text-slate-900">Features & integrations</h2>
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <div class="mb-3">
          <p class="mb-1 text-xs font-bold uppercase tracking-wider text-slate-500">Key features</p>
          <div class="flex flex-wrap gap-1">
            {processor.key_features.map((f) => (
              <span class="rounded-md bg-teal-50 px-2 py-0.5 text-xs text-teal-800">{f.replace(/_/g, ' ')}</span>
            ))}
          </div>
        </div>
        <div>
          <p class="mb-1 text-xs font-bold uppercase tracking-wider text-slate-500">Integrations</p>
          <div class="flex flex-wrap gap-1">
            {processor.integrations.map((i) => (
              <span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs">{i.replace(/_/g, ' ')}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="faqs" class="mb-10 scroll-mt-8">
      <h2 class="mb-5 text-2xl font-bold text-slate-900">Frequently asked</h2>
      <div class="space-y-3">
        {processor.faqs.map((f) => (
          <details class="rounded-lg border border-slate-200 bg-white p-4">
            <summary class="cursor-pointer font-semibold text-slate-900">{f.q}</summary>
            <p class="mt-3 text-slate-700 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="mb-10">
      <h2 class="mb-5 text-2xl font-bold text-slate-900">Other payment processors</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {siblings.map((s) => (
          <a href={`/payments/${s.slug}/`} class="block rounded-lg border border-slate-200 bg-white p-4 no-underline transition hover:border-teal-300 hover:bg-teal-50">
            <p class="mb-1 font-semibold text-slate-900">{s.name}</p>
            <p class="text-xs text-slate-500 line-clamp-2">{s.tagline}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Browse more</h2>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/payments/" class="rounded-md bg-teal-500 px-5 py-3 text-sm font-semibold text-white hover:bg-teal-600">All payment processors</a>
        <a href="/payroll/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">Payroll</a>
        <a href="/tools/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Software directory</a>
      </div>
    </section>
  </article>
</Layout>
