---
import Layout from '../../layouts/Layout.astro';
import { tools, aggregateRating, formatPrice } from '../../lib/data';

const sorted = [...tools].sort((a, b) => (aggregateRating(b) ?? 0) - (aggregateRating(a) ?? 0));
---

<Layout
  title="All field service software tools — WrenchStack"
  description={`Compare ${tools.length}+ field service and trades software tools side-by-side. Pricing, features, integrations, and ratings — all in one place.`}
>
  <section class="mx-auto max-w-6xl px-4 py-12">
    <header class="mb-8">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900">All tools we track</h1>
      <p class="mt-3 max-w-2xl text-lg text-slate-600">
        Every field service and trades software tool in our database, sorted by aggregated G2 +
        Capterra ratings. Click any tool for our full review.
      </p>
    </header>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {sorted.map((t) => {
        const r = aggregateRating(t);
        return (
          <a
            href={`/tools/${t.slug}/`}
            class="group rounded-lg border border-slate-200 bg-white p-5 transition hover:border-slate-400 hover:shadow-sm"
          >
            <div class="flex items-baseline justify-between">
              <h3 class="text-lg font-semibold text-slate-900 group-hover:text-orange-600">
                {t.name}
              </h3>
              {r !== null && (
                <span class="text-sm font-semibold text-slate-700">{r.toFixed(1)}</span>
              )}
            </div>
            <p class="mt-1 text-sm text-slate-500">{t.tagline}</p>
            <p class="mt-3 text-sm font-medium text-slate-700">{formatPrice(t)}</p>
            <p class="mt-1 text-xs text-slate-500">{t.best_team_size ?? '—'} techs · {t.verticals.length} trades</p>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
