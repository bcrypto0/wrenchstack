---
import Layout from '../../../layouts/Layout.astro';
import {
  tools,
  aggregateRating,
  formatPrice,
  verticalToUrl,
  verticals,
  verticalFitScore,
  type Tool,
} from '../../../lib/data';

export async function getStaticPaths() {
  return tools.map((t) => ({
    params: { slug: t.slug },
    props: { tool: t },
  }));
}

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;

const alternatives: Tool[] = tools
  .filter((t) => t.slug !== tool.slug)
  .filter((t) => t.verticals.some((v) => tool.verticals.includes(v)))
  .sort((a, b) => {
    const overlapA = a.verticals.filter((v) => tool.verticals.includes(v)).length;
    const overlapB = b.verticals.filter((v) => tool.verticals.includes(v)).length;
    if (overlapB !== overlapA) return overlapB - overlapA;
    return (aggregateRating(b) ?? 0) - (aggregateRating(a) ?? 0);
  })
  .slice(0, 8);

const primaryVertical = tool.verticals[0];
const primaryVerticalLabel = verticals.find((v) => v.slug === primaryVertical)?.name ?? primaryVertical;

const cheapestAlt = alternatives.length > 0
  ? alternatives.slice().sort((a, b) => (a.pricing.starting_at_usd ?? 999) - (b.pricing.starting_at_usd ?? 999))[0]
  : null;

const fitScore = tool.vertical_fit?.[primaryVertical] ?? 5;
const fitLine =
  fitScore >= 9
    ? `${tool.name} scores ${fitScore}/10 on our ${primaryVerticalLabel} fit assessment and is one of the top picks for the category.`
    : `${tool.name} is a solid mid-tier choice but not our top-ranked option for ${primaryVerticalLabel}.`;

const faqs = [
  {
    q: `What is the best alternative to ${tool.name}?`,
    a: alternatives.length > 0 && cheapestAlt
      ? `The closest alternative depends on your reason for switching. ${alternatives[0].name} is the most-recommended overall (highest aggregated rating). If price is the driver, ${cheapestAlt.name} starts lower. See the full breakdown below.`
      : 'No direct alternatives are in our database yet. Check our /tools/ directory for the full list.',
  },
  {
    q: `Is ${tool.name} the best option for ${primaryVerticalLabel.toLowerCase()} businesses?`,
    a: `${fitLine} See our ${primaryVerticalLabel} comparison page for the full ranking.`,
  },
  {
    q: `What should I look for when switching from ${tool.name}?`,
    a: 'When switching, audit four things: data export support (can you take your customer list with you?), integration parity (will your QuickBooks/Stripe/Zapier setup still work?), pricing changes at your team size (per-user vs. per-company structures change the math), and implementation cost (most enterprise tools charge for migration).',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const pageTitle = `${tool.name} Alternatives (2026): 8 Best Options Compared`;
const pageDescription = `The best alternatives to ${tool.name} in 2026, ranked by vertical fit and user ratings. Pricing, features, and use-case fit for each option.`;
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <article class="mx-auto max-w-4xl px-4 py-12">
    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:text-slate-900">Home</a>
      <span class="mx-2">/</span>
      <a href="/tools/" class="hover:text-slate-900">Tools</a>
      <span class="mx-2">/</span>
      <a href={`/tools/${tool.slug}/`} class="hover:text-slate-900">{tool.name}</a>
      <span class="mx-2">/</span>
      <span class="text-slate-900">Alternatives</span>
    </nav>

    <header class="mb-10">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        {tool.name} Alternatives
      </h1>
      <p class="mt-4 text-lg text-slate-600">
        {alternatives.length} alternatives to {tool.name}, ranked by vertical fit overlap and
        aggregated G2 + Capterra ratings. Each option includes pricing, key differences, and
        when to pick it.
      </p>
    </header>

    <section class="mb-12 rounded-lg border border-slate-200 bg-slate-50 p-6">
      <h2 class="mb-3 text-lg font-bold text-slate-900">Why switch from {tool.name}?</h2>
      <p class="text-slate-700">
        Common reasons we hear: <strong>{tool.weaknesses.split(';')[0].trim()}.</strong>
        If that matches your gripe, alternatives ranked below address it.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href={`/tools/${tool.slug}/`} class="text-sm font-semibold text-orange-600 hover:underline">
          ← Full {tool.name} review
        </a>
      </div>
    </section>

    <section class="space-y-8">
      {alternatives.map((alt, i) => {
        const overlap = alt.verticals.filter((v) => tool.verticals.includes(v));
        const rating = aggregateRating(alt);
        return (
          <div class="rounded-lg border border-slate-200 bg-white p-6">
            <div class="mb-3 flex flex-wrap items-baseline justify-between gap-3">
              <h2 class="text-2xl font-bold text-slate-900">
                <span class="text-orange-500">#{i + 1}</span>{' '}
                <a href={`/tools/${alt.slug}/`} class="hover:text-orange-600">{alt.name}</a>
              </h2>
              <div class="text-sm text-slate-500">
                {rating !== null && <span class="font-semibold text-slate-700">{rating.toFixed(1)} / 5</span>}
                <span> · {overlap.length} shared trades</span>
              </div>
            </div>
            <p class="mb-4 italic text-slate-600">{alt.tagline}</p>

            <dl class="grid gap-3 text-sm md:grid-cols-2">
              <div>
                <dt class="font-semibold text-slate-900">Starting price</dt>
                <dd class="text-slate-700">{formatPrice(alt)}</dd>
              </div>
              <div>
                <dt class="font-semibold text-slate-900">Best for</dt>
                <dd class="text-slate-700">{alt.best_for}</dd>
              </div>
              <div class="md:col-span-2">
                <dt class="font-semibold text-slate-900">Pick over {tool.name} if</dt>
                <dd class="text-slate-700">
                  {(alt.pricing.starting_at_usd ?? 999) < (tool.pricing.starting_at_usd ?? 999)
                    ? `you want a lower entry price (${formatPrice(alt)} vs ${formatPrice(tool)})`
                    : `you want ${alt.key_features.find((f) => !tool.key_features.includes(f))?.replace(/_/g, ' ') ?? 'different feature focus'}`}
                </dd>
              </div>
            </dl>

            <div class="mt-5 flex flex-wrap gap-3">
              <a
                href={alt.affiliate_url.startsWith('http') ? alt.affiliate_url : alt.vendor_url}
                rel="sponsored nofollow noopener"
                target="_blank"
                class="rounded-md bg-orange-500 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600"
              >
                Visit {alt.name} →
              </a>
              <a
                href={`/compare/${[tool.slug, alt.slug].sort()[0]}-vs-${[tool.slug, alt.slug].sort()[1]}/`}
                class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-900 hover:border-slate-400"
              >
                vs {tool.name} →
              </a>
            </div>
          </div>
        );
      })}
    </section>

    <section class="mt-12">
      <h2 class="mb-6 text-2xl font-bold text-slate-900">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map((f) => (
          <details class="rounded-lg border border-slate-200 bg-white p-4">
            <summary class="cursor-pointer font-semibold text-slate-900">{f.q}</summary>
            <p class="mt-3 text-slate-700">{f.a}</p>
          </details>
        ))}
      </div>
    </section>
  </article>
</Layout>
