  <script>
    // Scroll-spy: highlight the current section's link in the jump-to nav
    // as the user scrolls. Uses IntersectionObserver to detect which
    // section is most in viewport.
    (() => {
      const jumpLinks = document.querySelectorAll<HTMLAnchorElement>('.jump-link');
      if (jumpLinks.length === 0) return;
      const linkBySection = new Map<string, HTMLAnchorElement>();
      const sections: HTMLElement[] = [];
      for (const link of jumpLinks) {
        const sectionId = link.dataset.jumpLink;
        if (!sectionId) continue;
        linkBySection.set(sectionId, link);
        const section = document.getElementById(sectionId);
        if (section) sections.push(section);
      }
      if (sections.length === 0) return;

      const ACTIVE_CLASSES = ['font-bold', 'text-orange-700'];
      const INACTIVE_CLASSES = ['text-orange-600'];

      let currentActive: string | null = null;

      function setActive(sectionId: string | null) {
        if (sectionId === currentActive) return;
        currentActive = sectionId;
        for (const [id, link] of linkBySection.entries()) {
          if (id === sectionId) {
            link.classList.add(...ACTIVE_CLASSES);
            link.classList.remove(...INACTIVE_CLASSES);
          } else {
            link.classList.remove(...ACTIVE_CLASSES);
            link.classList.add(...INACTIVE_CLASSES);
          }
        }
      }

      // Track which sections are currently intersecting; the topmost one wins.
      const intersecting = new Set<string>();

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            const id = entry.target.id;
            if (entry.isIntersecting) intersecting.add(id);
            else intersecting.delete(id);
          }
          if (intersecting.size === 0) {
            // No section in viewport — default to nothing or first if scrolled past everything
            return;
          }
          // Pick the topmost intersecting section in source order
          for (const s of sections) {
            if (intersecting.has(s.id)) {
              setActive(s.id);
              return;
            }
          }
        },
        {
          // Trigger when section's top crosses the 20%-from-top line
          rootMargin: '0px 0px -75% 0px',
          threshold: 0,
        },
      );

      for (const s of sections) observer.observe(s);
    })();

    // Per-tool pricing widget: takes team size input, shows live monthly +
    // annual cost. Detects per-user vs per-company pricing from the
    // pricing_note hint.
    (() => {
      const widget = document.querySelector<HTMLElement>('[data-pricing-widget]');
      if (!widget) return;
      const techsInput = document.getElementById('pw-techs') as HTMLInputElement | null;
      const monthlyEl = document.getElementById('pw-monthly');
      const annualEl = document.getElementById('pw-annual');
      const noteEl = document.getElementById('pw-note');
      if (!techsInput || !monthlyEl || !annualEl || !noteEl) return;

      const startingPriceRaw = widget.dataset.startingPrice;
      const pricingNote = (widget.dataset.pricingNote ?? '').toLowerCase();
      const toolName = widget.dataset.toolName ?? 'this tool';

      // Custom-quoted (no published starting price) — use $400/user/mo as
      // mid-case fallback for enterprise tools.
      const isCustomQuoted = !startingPriceRaw || startingPriceRaw === '';
      const startingPrice = isCustomQuoted ? 400 : parseFloat(startingPriceRaw);
      const isFree = startingPrice === 0;
      const isFlat = pricingNote.includes('per company') ||
                     (pricingNote.includes('per month') && !pricingNote.includes('per user'));

      function format(n: number): string {
        return '$' + Math.round(n).toLocaleString('en-US');
      }

      function update() {
        const techs = parseInt(techsInput!.value, 10) || 1;
        if (isFree) {
          monthlyEl!.textContent = 'Free';
          annualEl!.textContent = 'Free';
          noteEl!.innerHTML = `${toolName} has a free tier — usable indefinitely for solo or 1-2 person operations. Paid tiers unlock advanced features once your team grows. For an exact quote at your size and feature mix, request pricing from ${toolName}.`;
          return;
        }
        const monthly = isFlat ? startingPrice : startingPrice * techs;
        const annual = monthly * 12;
        monthlyEl!.textContent = format(monthly);
        annualEl!.textContent = format(annual);
        if (isCustomQuoted) {
          noteEl!.innerHTML = `${toolName} uses custom-quoted pricing. We model it at <strong>$400/user/mo</strong> as the mid-case (range: $250-$800/user/mo). Actual quotes vary significantly by team size and modules. Request a real quote from ${toolName} for precision.`;
        } else if (isFlat) {
          noteEl!.innerHTML = `${toolName} uses <strong>per-company</strong> pricing — the monthly cost doesn't scale with team size. Unlimited techs included.`;
        } else {
          noteEl!.innerHTML = `${toolName} uses <strong>per-user</strong> pricing at $${startingPrice}/user/mo on the entry tier. Cost scales linearly with team size. Higher tiers add features at higher per-user rates.`;
        }
      }

      techsInput.addEventListener('input', update);
      update();
    })();
  </script>
</Layout>
