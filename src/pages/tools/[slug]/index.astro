---
import Layout from '../../../layouts/Layout.astro';
import {
  tools,
  toolsForVertical,
  aggregateRating,
  formatPrice,
  verticalToUrl,
  verticals,
  type Tool,
} from '../../../lib/data';

export async function getStaticPaths() {
  return tools.map((t) => ({
    params: { slug: t.slug },
    props: { tool: t },
  }));
}

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const rating = aggregateRating(tool);

const competitorsInSameVertical: Tool[] = tool.verticals
  .flatMap((v) => toolsForVertical(v))
  .filter((t, i, arr) => t.slug !== tool.slug && arr.findIndex((x) => x.slug === t.slug) === i)
  .sort((a, b) => (aggregateRating(b) ?? 0) - (aggregateRating(a) ?? 0))
  .slice(0, 4);

const verticalsForThisTool = tool.verticals
  .map((v) => verticals.find((x) => x.slug === v))
  .filter((v): v is NonNullable<typeof v> => v !== undefined);

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: tool.name,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web, iOS, Android',
  offers: {
    '@type': 'Offer',
    price: tool.pricing.starting_at_usd ?? undefined,
    priceCurrency: 'USD',
  },
  ...(rating !== null && {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: rating.toFixed(1),
      bestRating: '5',
      reviewCount: 50,
    },
  }),
};

const pageTitle = `${tool.name} Review (2026): Pricing, Features, Pros & Cons`;
const pageDescription = `Independent review of ${tool.name}. ${tool.tagline}. Real pricing tiers, key features, integrations, and honest weaknesses. Updated 2026.`;

const reviewSchema = rating !== null ? {
  '@context': 'https://schema.org',
  '@type': 'Review',
  itemReviewed: {
    '@type': 'SoftwareApplication',
    name: tool.name,
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Web, iOS, Android',
  },
  reviewRating: {
    '@type': 'Rating',
    ratingValue: rating.toFixed(1),
    bestRating: '5',
  },
  author: {
    '@type': 'Organization',
    name: 'WrenchStack',
  },
  publisher: {
    '@type': 'Organization',
    name: 'WrenchStack',
  },
  reviewBody: `${tool.tagline}. Best for: ${tool.best_for}. Watch out for: ${tool.weaknesses}`,
} : null;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Tools', url: '/tools/' },
  { name: tool.name, url: `/tools/${tool.slug}/` },
];
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  {reviewSchema && <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />}

  <article class="mx-auto max-w-4xl px-4 py-12">
    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:text-slate-900">Home</a>
      <span class="mx-2">/</span>
      <a href="/tools/" class="hover:text-slate-900">All tools</a>
      <span class="mx-2">/</span>
      <span class="text-slate-900">{tool.name}</span>
    </nav>

    <header class="mb-10">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        {tool.name} Review
      </h1>
      <p class="mt-4 text-lg italic text-slate-600">{tool.tagline}</p>

      <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-slate-600">
        {rating !== null && (
          <span class="flex items-center gap-1">
            <span class="font-bold text-slate-900">{rating.toFixed(1)} / 5</span>
            <span class="text-slate-500">(avg G2 + Capterra)</span>
          </span>
        )}
        {tool.founded && <span>Founded {tool.founded}</span>}
        {tool.headquartered && <span>HQ {tool.headquartered}</span>}
        <span>Best team size: {tool.best_team_size ?? '—'}</span>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href={tool.affiliate_url.startsWith('http') ? tool.affiliate_url : tool.vendor_url}
          rel="sponsored nofollow noopener"
          target="_blank"
          class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600"
        >
          Visit {tool.name} →
        </a>
        {tool.pricing.free_trial_days && tool.pricing.free_trial_days > 0 && (
          <span class="rounded-md border border-slate-300 bg-white px-4 py-3 text-sm font-medium text-slate-700">
            {tool.pricing.free_trial_days}-day free trial
          </span>
        )}
      </div>

    </header>

    <section class="mb-10">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">Pricing</h2>
      <div class="overflow-x-auto rounded-lg border border-slate-200 bg-white">
        <table class="w-full text-sm">
          <thead class="bg-slate-50 text-left text-slate-700">
            <tr>
              <th class="p-3 font-semibold">Tier</th>
              <th class="p-3 font-semibold">Price</th>
              <th class="p-3 font-semibold">Notes</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {tool.pricing.tiers.map((tier, i) => {
              const price = tool.pricing.tier_prices_usd?.[i];
              return (
                <tr>
                  <td class="p-3 font-semibold text-slate-900">{tier}</td>
                  <td class="p-3 text-slate-700">
                    {price === null || price === undefined ? 'Custom quote' : price === 0 ? 'Free' : `$${price}/mo`}
                  </td>
                  <td class="p-3 text-slate-500">{i === 0 ? 'Entry tier' : i === tool.pricing.tiers.length - 1 ? 'Top tier' : ''}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
      {tool.pricing.pricing_note && (
        <p class="mt-3 text-sm italic text-slate-500">{tool.pricing.pricing_note}</p>
      )}
      <p class="mt-2 text-xs text-slate-400">
        Pricing verified {tool.pricing.verified_date}. Vendors change pricing without notice;
        verify with {tool.name} before purchasing.
      </p>
    </section>

    <section class="mb-10">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">Key features</h2>
      <div class="flex flex-wrap gap-2">
        {tool.key_features.map((f) => (
          <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-sm text-slate-700">
            {f.replace(/_/g, ' ')}
          </span>
        ))}
      </div>
    </section>

    <section class="mb-10">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">Integrations</h2>
      <div class="flex flex-wrap gap-2">
        {tool.integrations.map((i) => (
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm text-slate-700">
            {i.replace(/_/g, ' ')}
          </span>
        ))}
      </div>
    </section>

    <section class="mb-10 grid gap-6 md:grid-cols-2">
      <div class="rounded-lg border border-green-200 bg-green-50 p-5">
        <h3 class="mb-2 font-bold text-green-900">Best for</h3>
        <p class="text-sm text-green-900">{tool.best_for}</p>
      </div>
      <div class="rounded-lg border border-orange-200 bg-orange-50 p-5">
        <h3 class="mb-2 font-bold text-orange-900">Watch out for</h3>
        <p class="text-sm text-orange-900">{tool.weaknesses}</p>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">Available for these trades</h2>
      <div class="flex flex-wrap gap-2">
        {verticalsForThisTool.map((v) => (
          <a
            href={`/${verticalToUrl(v.slug)}/`}
            class="rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-900 hover:border-orange-500 hover:text-orange-600"
          >
            Best for {v.name} →
          </a>
        ))}
      </div>
    </section>

    {competitorsInSameVertical.length > 0 && (
      <section class="mb-10">
        <h2 class="mb-4 text-2xl font-bold text-slate-900">Top alternatives to {tool.name}</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {competitorsInSameVertical.map((c) => (
            <a
              href={`/tools/${c.slug}/`}
              class="group rounded-lg border border-slate-200 bg-white p-4 hover:border-slate-400"
            >
              <div class="font-semibold text-slate-900 group-hover:text-orange-600">{c.name}</div>
              <div class="mt-1 text-sm text-slate-500">{formatPrice(c)}</div>
              <div class="mt-2 text-xs text-slate-500">{c.tagline}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Ready to try {tool.name}?</h2>
      <p class="mt-2 text-slate-300">
        {tool.pricing.free_trial_days && tool.pricing.free_trial_days > 0
          ? `${tool.pricing.free_trial_days}-day free trial. No credit card required to start.`
          : 'Get a custom quote — pricing is not public.'}
      </p>
      <a
        href={tool.affiliate_url.startsWith('http') ? tool.affiliate_url : tool.vendor_url}
        rel="sponsored nofollow noopener"
        target="_blank"
        class="mt-4 inline-block rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600"
      >
        Visit {tool.name} →
      </a>
    </section>
  </article>
</Layout>
