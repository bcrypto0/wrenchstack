---
import IntlComparison from '../../../../components/IntlComparison.astro';
import { INTL_MARKETS, type IntlVendor } from '../../../../lib/intl';
import data from '../../../../data/international/ie.json';

export function getStaticPaths() {
  const vendors = (data as { vendors: IntlVendor[] }).vendors.filter((v) => v.category !== 'certification');
  const paths: { params: { pair: string }; props: { a: IntlVendor; b: IntlVendor } }[] = [];
  for (let i = 0; i < vendors.length; i++) {
    for (let j = i + 1; j < vendors.length; j++) {
      const a = vendors[i];
      const b = vendors[j];
      if (a.category !== b.category) continue;
      paths.push({ params: { pair: `${a.slug}-vs-${b.slug}` }, props: { a, b } });
    }
  }
  return paths;
}

const market = INTL_MARKETS.ie;
const { a, b } = Astro.props;
---
<IntlComparison market={market} a={a} b={b} />
