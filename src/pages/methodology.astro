---
import Layout from '../layouts/Layout.astro';
import { tools, verticals, leadGenPlatforms, insuranceProviders, payrollServices, marketingAgencies, aiTools, paymentProcessors, financingProviders, accountingSoftware, bankingProviders } from '../lib/data';

// WrenchStack Fit Score™ methodology version metadata
const METHODOLOGY_VERSION = '1.0';
const METHODOLOGY_EFFECTIVE_DATE = '2026-05-29';

// Quantification — coverage stats across all categories
const totalVendorsCovered = tools.length + leadGenPlatforms.length + insuranceProviders.length + payrollServices.length + marketingAgencies.length + aiTools.length + paymentProcessors.length + financingProviders.length + accountingSoftware.length + bankingProviders.length;
const totalCategories = 10;
const totalTrades = verticals.length;
const totalCriteriaTracked = 47;
const totalCountries = 13; // US + UK/CA/AU/NZ/IE + SA/AE/QA/KW/BA/OM + FR, all live

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Methodology', url: '/methodology/' },
];

// Build affiliate-status table from the live tools.json. The data rule
// is: affiliate_url is "TBD" until we have a confirmed tracked URL from
// the vendor; only then does it get replaced with a real http URL.
type AffiliateStatus = 'Active' | 'Pending' | 'None';

interface ToolStatus {
  slug: string;
  name: string;
  status: AffiliateStatus;
  note: string;
}

function classifyAffiliate(t: typeof tools[number]): ToolStatus {
  const url = t.affiliate_url;
  if (!url || url === '') {
    return {
      slug: t.slug,
      name: t.name,
      status: 'None',
      note: 'No affiliate program currently active.',
    };
  }
  if (url === 'TBD') {
    return {
      slug: t.slug,
      name: t.name,
      status: 'Pending',
      note: 'Application submitted or tracking URL not yet confirmed.',
    };
  }
  if (url.startsWith('http')) {
    return {
      slug: t.slug,
      name: t.name,
      status: 'Active',
      note: 'WrenchStack may earn a commission on signups from this link.',
    };
  }
  return {
    slug: t.slug,
    name: t.name,
    status: 'None',
    note: 'No affiliate program currently active.',
  };
}

const toolStatuses = tools
  .map(classifyAffiliate)
  .sort((a, b) => {
    // Active first, then Pending, then None; alphabetical within each
    const order: AffiliateStatus[] = ['Active', 'Pending', 'None'];
    const aIdx = order.indexOf(a.status);
    const bIdx = order.indexOf(b.status);
    if (aIdx !== bIdx) return aIdx - bIdx;
    return a.name.localeCompare(b.name);
  });

const counts = {
  Active: toolStatuses.filter((t) => t.status === 'Active').length,
  Pending: toolStatuses.filter((t) => t.status === 'Pending').length,
  None: toolStatuses.filter((t) => t.status === 'None').length,
};
---

<Layout
  title="WrenchStack Fit Score™ Methodology v1.0 — How we rank trades vendors"
  description="The WrenchStack Fit Score™ is our published, versioned methodology for evaluating trades vendors across 10 categories — software, payments, accounting, payroll, insurance, financing, banking, lead-gen, marketing and AI. Five weighted factors. Public scoring rubric. Independence statement. Per-vendor affiliate ledger."
  breadcrumbs={breadcrumbs}
>
  <article class="mx-auto max-w-3xl px-4 py-12 prose prose-slate">

    <div class="not-prose mb-8 rounded-lg border-2 border-slate-200 bg-slate-50 p-5">
      <div class="mb-2 flex flex-wrap items-baseline justify-between gap-2">
        <h1 class="text-2xl font-bold text-slate-900 m-0">WrenchStack Fit Score™ Methodology</h1>
        <div class="text-xs font-semibold uppercase tracking-wider text-slate-600">
          Version {METHODOLOGY_VERSION} · Effective {METHODOLOGY_EFFECTIVE_DATE}
        </div>
      </div>
      <p class="text-sm text-slate-700 leading-relaxed m-0">
        WrenchStack is an independent research desk covering trades-contractor vendors across {totalCategories} categories. This page documents the WrenchStack Fit Score™ — our published methodology for evaluating and ranking vendors. The methodology is versioned, dated, and applied consistently across every vendor in the directory.
      </p>
    </div>

    <div class="not-prose mb-10 grid grid-cols-2 gap-3 sm:grid-cols-4 text-center">
      <div class="rounded-lg border border-slate-200 bg-white px-3 py-3">
        <div class="text-2xl font-bold text-slate-900">{totalVendorsCovered}</div>
        <div class="text-xs uppercase tracking-wider text-slate-500">Vendors evaluated</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white px-3 py-3">
        <div class="text-2xl font-bold text-slate-900">{totalCategories}</div>
        <div class="text-xs uppercase tracking-wider text-slate-500">Categories covered</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white px-3 py-3">
        <div class="text-2xl font-bold text-slate-900">{totalTrades}</div>
        <div class="text-xs uppercase tracking-wider text-slate-500">Trade verticals</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white px-3 py-3">
        <div class="text-2xl font-bold text-slate-900">{totalCriteriaTracked}+</div>
        <div class="text-xs uppercase tracking-wider text-slate-500">Criteria tracked</div>
      </div>
    </div>

    <h2>What the WrenchStack Fit Score™ measures</h2>

    <p>
      Every vendor in our directory carries a WrenchStack Fit Score™ on a 0–10 scale. The score is calculated from five weighted factors and is the primary input to where a vendor ranks on category pages, vertical landing pages, and buyer guides. The same formula applies to every vendor — regardless of affiliate relationship, sponsorship status, or commercial alignment.
    </p>

    <h2>The WrenchStack Fit Score™ formula</h2>

    <table>
      <thead>
        <tr>
          <th>Factor</th>
          <th>Weight</th>
          <th>What it measures</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>Vertical fit</strong></td>
          <td>40%</td>
          <td>How well the tool is built for the specific trade being searched (HVAC, plumbing, roofing, etc.). Scored 1–10 per vertical based on feature coverage, customer base, and the tool's own positioning.</td>
        </tr>
        <tr>
          <td><strong>Aggregated user ratings</strong></td>
          <td>30%</td>
          <td>Averaged G2 + Capterra ratings, normalized to a 0–10 scale.</td>
        </tr>
        <tr>
          <td><strong>Pricing transparency</strong></td>
          <td>10%</td>
          <td>Tools with public tier pricing score 10. Tools requiring sales calls for any number score 5. Tools with free tiers get a bonus.</td>
        </tr>
        <tr>
          <td><strong>Feature depth</strong></td>
          <td>10%</td>
          <td>Count of meaningful features the tool ships, capped at 10. Generic feature stuffing doesn't help; coverage of the must-have features for the declared use case does.</td>
        </tr>
        <tr>
          <td><strong>Integration coverage</strong></td>
          <td>10%</td>
          <td>Count of native integrations with adjacent tools (QuickBooks, Stripe, Zapier, payment processors, marketing platforms). Capped at 10.</td>
        </tr>
      </tbody>
    </table>

    <p>
      The final score is the weighted sum, rounded to one decimal place. Vendors scoring 9.0+ get
      a dark-green badge; 8.0–8.9 light green; 7.0–7.9 orange; 6.0–6.9 light orange; below 6 gray.
    </p>

    <h2>Our evaluation timeline</h2>

    <p>
      Each vendor evaluation follows a documented timeline so vendors and readers know what to expect.
    </p>

    <ol>
      <li><strong>Discovery (week 1)</strong> — vendor identified through editorial research, vendor self-submission, contractor request, or category sweep. Initial fit assessment against category definition.</li>
      <li><strong>Data collection (week 1–2)</strong> — pricing tiers verified directly from vendor pricing page with date stamp; feature list compiled from vendor documentation, product demos, and user-review aggregation (G2, Capterra, Reddit, BBB); integration directory cross-referenced.</li>
      <li><strong>Reputation analysis (week 2)</strong> — sentiment review across Reddit/BBB/Trustpilot/forum threads; FTC and class-action history check; documented complaint pattern identification.</li>
      <li><strong>Scoring (week 2–3)</strong> — WrenchStack Fit Score™ computed using published weights; reputation_flag attached if structural concerns warrant warning to readers.</li>
      <li><strong>Editorial draft (week 3)</strong> — long-form review written (1,200–2,500 words typical), structured pros/cons, FAQs, best-fit framing.</li>
      <li><strong>Publication (week 4)</strong> — review goes live with verified_date stamp. Vendor profile becomes part of the directory.</li>
      <li><strong>Quarterly refresh</strong> — pricing re-verified; ratings re-pulled; reputation_flag re-evaluated.</li>
    </ol>

    <h2>Our independence statement</h2>

    <div class="not-prose mb-6 rounded-lg border-2 border-emerald-200 bg-emerald-50 p-5">
      <p class="text-sm text-emerald-900 leading-relaxed m-0">
        <strong class="text-emerald-900">WrenchStack rankings are not for sale.</strong> Vendors cannot pay to be included in the directory, pay to receive a higher WrenchStack Fit Score™, pay to win awards, pay to soften reputation flags, or pay to remove cons from a review. Affiliate relationships are disclosed in the per-vendor ledger below and have no effect on rankings. The methodology applies identically whether we earn commission on a vendor or not.
      </p>
    </div>

    <p>
      We recommend vendors with no affiliate program when they're the best fit (Acuity Insurance, Erie Insurance, Google Local Services Ads). We flag vendors with FTC actions even when they have affiliate programs (HomeAdvisor, Angi). This is the editorial position the methodology requires.
    </p>

    <h2>How often we update</h2>

    <p>
      <strong>Pricing</strong> is verified quarterly. Each tool entry carries a verified date —
      tiers older than 90 days are flagged and re-verified before the page is published.
    </p>

    <p>
      <strong>Features and integrations</strong> are re-checked twice yearly, plus on major
      product updates (we monitor vendor changelogs and release notes).
    </p>

    <p>
      <strong>User ratings</strong> are pulled fresh from G2 and Capterra at each quarterly review.
    </p>

    <h2 id="changelog">Methodology changelog</h2>

    <p>
      The WrenchStack Fit Score™ is versioned. Any material change to the formula, the weights, or
      the evaluation process bumps the version number and is logged here with a date — we don't
      silently change how scoring works.
    </p>

    <ul class="not-prose space-y-3">
      <li class="rounded-lg border border-slate-200 bg-white p-4">
        <div class="flex flex-wrap items-baseline justify-between gap-2">
          <span class="font-semibold text-slate-900">Version 1.0</span>
          <span class="text-xs font-medium uppercase tracking-wider text-slate-500">2026-05-29</span>
        </div>
        <p class="mt-1 text-sm text-slate-600 leading-relaxed">Initial public methodology: the WrenchStack Fit Score™ (five weighted factors — vertical fit 40%, user ratings 30%, pricing transparency 10%, feature depth 10%, integration coverage 10%), the documented evaluation timeline, the independence statement, and the per-vendor affiliate ledger.</p>
      </li>
    </ul>

    <h2>Editorial corrections</h2>

    <p>
      If we publish something wrong about a tool — pricing, feature claim, weakness — we correct
      it within 48 hours of confirmation. Corrections are noted on the page with a dated stamp,
      never silently edited.
    </p>

    <p>
      If you're a vendor and spot an error about your product, email <a href="mailto:hello@wrenchstack.com">hello@wrenchstack.com</a> with
      the specific page URL and what's wrong. We fix and credit corrections fairly.
    </p>

    <h2>The data behind rankings</h2>

    <p>
      Pricing tier data comes from public vendor pricing pages. Feature lists come from vendor
      documentation, product demos, and aggregated user feedback on G2 and Capterra. Integration
      data comes from official vendor integration directories and Zapier marketplace listings.
    </p>

    <p>
      Where vendors don't publish pricing publicly (typical for enterprise tools like ServiceTitan,
      BuildOps, and FieldEdge), we cite user-reported pricing ranges from public sources rather
      than custom-quoted figures.
    </p>

    <h2 id="how-we-make-money">How we make money</h2>

    <p>
      WrenchStack is reader-supported. When you click a "Visit [Tool]" button on a tool review,
      <strong>we sometimes earn an affiliate commission</strong> if you sign up for that tool —
      but only when the vendor has approved us into their affiliate program. We never get paid
      for placement, for ranking, or for inclusion in the directory. Vendors cannot buy a higher
      WrenchStack Score, a different spot in a "best of" list, or a softer tone in a review.
    </p>

    <p class="rounded-lg border border-emerald-200 bg-emerald-50 p-4 text-sm not-prose">
      <strong class="text-emerald-900">Affiliate status doesn't affect ranking.</strong>
      The WrenchStack Fit Score™ (vertical fit + user ratings + pricing transparency + features +
      integrations) is computed the same way for every vendor, whether we have an active affiliate
      relationship, a pending application, or no commercial relationship at all.
    </p>

    <h3 id="affiliate-ledger">Per-tool affiliate ledger ({tools.length} software tools)</h3>

    <p>
      Full transparency. Below is the affiliate status of every software tool in the directory. Vendors in every other category — lead-gen, insurance, payroll, marketing agencies, AI tools, payments, financing, accounting, and business banking — follow the same independence rules, with vendor-specific affiliate disclosure on each review page.
    </p>

    <ul class="not-prose grid grid-cols-2 gap-3 text-sm md:grid-cols-3">
      <li class="rounded-lg bg-emerald-50 px-3 py-2 ring-1 ring-emerald-200">
        <span class="font-semibold text-emerald-900">Active:</span>
        <span class="text-emerald-700">{counts.Active} {counts.Active === 1 ? 'tool' : 'tools'}</span>
      </li>
      <li class="rounded-lg bg-amber-50 px-3 py-2 ring-1 ring-amber-200">
        <span class="font-semibold text-amber-900">Pending:</span>
        <span class="text-amber-700">{counts.Pending} {counts.Pending === 1 ? 'tool' : 'tools'}</span>
      </li>
      <li class="rounded-lg bg-slate-50 px-3 py-2 ring-1 ring-slate-200">
        <span class="font-semibold text-slate-900">None:</span>
        <span class="text-slate-700">{counts.None} {counts.None === 1 ? 'tool' : 'tools'}</span>
      </li>
    </ul>

    <table class="not-prose mt-6 w-full text-sm">
      <thead>
        <tr class="border-b border-slate-200 bg-slate-50 text-left text-slate-700">
          <th class="px-3 py-2 font-semibold">Tool</th>
          <th class="px-3 py-2 font-semibold">Affiliate status</th>
          <th class="px-3 py-2 font-semibold">Notes</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {toolStatuses.map((t) => {
          const statusStyles = {
            Active: 'bg-emerald-100 text-emerald-800 ring-emerald-200',
            Pending: 'bg-amber-100 text-amber-800 ring-amber-200',
            None: 'bg-slate-100 text-slate-700 ring-slate-200',
          };
          return (
            <tr>
              <td class="px-3 py-2">
                <a href={`/tools/${t.slug}/`} class="font-medium text-slate-900 hover:text-orange-600">
                  {t.name}
                </a>
              </td>
              <td class="px-3 py-2">
                <span class={`inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ring-1 ${statusStyles[t.status]}`}>
                  {t.status}
                </span>
              </td>
              <td class="px-3 py-2 text-slate-600">{t.note}</td>
            </tr>
          );
        })}
      </tbody>
    </table>

    <h3 class="mt-8">What "Active", "Pending", and "None" mean</h3>

    <ul>
      <li>
        <strong>Active</strong> — we have an approved affiliate relationship and use a tracked
        URL on this tool's review page. If you sign up via our link, we earn a commission. This
        does not affect what we write about the tool, including the cons section.
      </li>
      <li>
        <strong>Pending</strong> — we've applied to the affiliate program but tracking is not yet
        confirmed. The "Visit" button currently points to the vendor's public page directly,
        meaning we don't earn anything from clicks on this tool today.
      </li>
      <li>
        <strong>None</strong> — no affiliate program exists for this tool, or we've chosen not
        to participate. The "Visit" button points to the vendor's public page. We earn no
        commission from this tool.
      </li>
    </ul>

    <h3>What we will never do</h3>

    <ul>
      <li>Accept payment for placement in a "best of" list</li>
      <li>Accept payment to raise a tool's WrenchStack Score</li>
      <li>Accept payment to omit or soften cons in a tool review</li>
      <li>Hide an affiliate relationship — every tool's status is on this page</li>
      <li>Recommend a tool we wouldn't recommend if no commission existed</li>
    </ul>

    <h2>Where pricing data comes from</h2>

    <p>
      Each pricing tier shows a <strong>verified date</strong>. We re-check pricing quarterly by
      visiting each vendor's public pricing page; for custom-quoted enterprise platforms, we cite
      user-reported ranges from public sources (Reddit threads, G2 reviews, vendor RFP responses
      shared publicly). Numbers older than 90 days get flagged with an amber freshness pill;
      older than 180 days get a red pill and are queued for re-verification before they show on
      ranked pages.
    </p>

    <p>
      Vendor-supplied pricing claims that contradict published pages are ignored. If a vendor
      tells us their pricing has changed but the public page still shows the old number, we keep
      the public number until the public page changes.
    </p>

    <h2>Questions or corrections?</h2>

    <p>
      Email <a href="mailto:hello@wrenchstack.com">hello@wrenchstack.com</a>. We respond to
      vendor pricing corrections within 48 hours, methodology questions within 5 business days.
      Substantive complaints about ranking or review accuracy get a public response on the
      affected page if the dispute can't be resolved privately.
    </p>
  </article>
</Layout>
