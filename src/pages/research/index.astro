---
import Layout from '../../layouts/Layout.astro';
import { tools, verticals, leadGenPlatforms, insuranceProviders, payrollServices, marketingAgencies } from '../../lib/data';

const totalVendorCount = tools.length + leadGenPlatforms.length + insuranceProviders.length + payrollServices.length + marketingAgencies.length;

const pageTitle = 'Research & Data — WrenchStack';
const pageDescription = 'WrenchStack research products: industry reports, market data, vendor analysis, and the WrenchStack Index of trades-vendor benchmarks. Citable, dated, methodology-backed.';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Research', url: '/research/' },
];

// Current research products
const research = [
  {
    slug: 'state-of-trades-software-2026',
    legacyUrl: '/trends-2026/',
    title: 'Trades Software Market Report 2026',
    pubDate: '2026-05-26',
    description: '15+ data findings from analysis of 120 platforms. Pricing distribution, the custom-quote opacity tax, integration prevalence, founded-year cohorts, vertical density. Cite as: WrenchStack Trades Software Market Report 2026.',
    tags: ['Industry report', 'Annual', 'Software'],
  },
  {
    slug: 'wrenchstack-index-q2-2026',
    legacyUrl: '/research/index/',
    title: 'WrenchStack Index — Q2 2026',
    pubDate: '2026-05-29',
    description: 'Quarterly benchmark stats across all 5 categories: software, lead-gen, insurance, payroll, marketing agencies. Headline metrics designed for citation.',
    tags: ['Quarterly index', 'Cross-category'],
  },
  {
    slug: 'wrenchstack-awards-2026',
    legacyUrl: '/awards/2026/',
    title: 'WrenchStack Awards 2026',
    pubDate: '2026-05-28',
    description: '18 editorial categories of vendor recognition across software, with full methodology and per-category winner rationale.',
    tags: ['Annual awards', 'Software'],
  },
];
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <article class="mx-auto max-w-4xl px-4 py-12">

    <header class="mb-10">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-orange-600">Research & Data</p>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">
        WrenchStack Research
      </h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        Original research on the trades-contractor vendor market: industry reports, quarterly benchmarks, awards, and editorial analysis. Every report is methodology-backed, dated, and structured for citation.
      </p>
    </header>

    <section class="mb-10 grid gap-3 grid-cols-2 sm:grid-cols-4">
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">{totalVendorCount}+</div>
        <div class="mt-1 text-xs text-slate-600">Vendors in dataset</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">5</div>
        <div class="mt-1 text-xs text-slate-600">Categories tracked</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">{verticals.length}</div>
        <div class="mt-1 text-xs text-slate-600">Trade verticals</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">Q2 '26</div>
        <div class="mt-1 text-xs text-slate-600">Latest index</div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="mb-5 text-2xl font-bold text-slate-900">Published research</h2>
      <div class="space-y-4">
        {research.map((r) => (
          <article class="rounded-lg border-2 border-slate-200 bg-white p-5 hover:border-orange-300">
            <div class="mb-2 flex flex-wrap items-baseline justify-between gap-2">
              <h3 class="text-xl font-bold text-slate-900">
                <a href={r.legacyUrl} class="hover:text-orange-600">{r.title}</a>
              </h3>
              <span class="text-xs text-slate-500">Published {r.pubDate}</span>
            </div>
            <p class="mb-3 text-slate-700 leading-relaxed">{r.description}</p>
            <div class="flex flex-wrap items-center gap-2 mb-3">
              {r.tags.map(t => (
                <span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">{t}</span>
              ))}
            </div>
            <a href={r.legacyUrl} class="text-sm font-semibold text-orange-600 hover:underline">Read the full report →</a>
          </article>
        ))}
      </div>
    </section>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-lg font-bold text-slate-900">Upcoming research (2026 roadmap)</h2>
      <ul class="space-y-2 text-sm text-slate-700">
        <li>• <strong>Q3 2026:</strong> Lead-Gen Platform Reputation Index — quantified contractor sentiment across 13 platforms</li>
        <li>• <strong>Q3 2026:</strong> Trades Insurance Market Report 2026 — direct-vs-agent + reputation flag analysis</li>
        <li>• <strong>Q4 2026:</strong> WrenchStack Index Q4 2026 — annual rollup with year-over-year deltas</li>
        <li>• <strong>Q4 2026:</strong> International expansion data drop — UK, CA, AU, NZ, IE vendor landscape</li>
        <li>• <strong>Q1 2027:</strong> State of Trades Software 2027 — flagship annual report</li>
        <li>• <strong>Q1 2027:</strong> WrenchStack Awards 2027</li>
      </ul>
    </section>

    <section class="mb-10 rounded-lg border-2 border-slate-200 bg-white p-6">
      <h2 class="mb-3 text-lg font-bold text-slate-900">Citation guidance</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        When citing WrenchStack research in publications, please use this format:
      </p>
      <div class="mt-3 rounded-md bg-slate-50 px-4 py-3 font-mono text-sm text-slate-800">
        WrenchStack [Year] [Report Title]. WrenchStack Research. https://wrenchstack.com/research/[slug]/
      </div>
      <p class="mt-3 text-sm text-slate-700">
        For exclusive data, custom segments, or pre-publication review, email <a href="mailto:press@wrenchstack.com" class="text-orange-600 hover:underline">press@wrenchstack.com</a>. Visit the <a href="/press/" class="text-orange-600 hover:underline">press room</a> for boilerplate, brand assets, and contact information.
      </p>
    </section>

    <section class="rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Want exclusive data or expert commentary?</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">
        WrenchStack has proprietary data on vendor pricing, ratings, integration patterns, and reputation signals across {totalVendorCount}+ trades-vendor profiles. Custom segments, exclusive numbers, and expert interview availability for qualified journalists and industry analysts.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="mailto:press@wrenchstack.com" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">Email research desk</a>
        <a href="/press/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">Press room</a>
        <a href="/methodology/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Methodology</a>
      </div>
    </section>
  </article>
</Layout>
