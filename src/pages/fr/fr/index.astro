---
import Layout from '../../../layouts/Layout.astro';
import frData from '../../../data/international/fr.json';

interface FrVendor {
  slug: string; name: string; category: string; vendor_url: string;
  tagline: string; tier: 'S' | 'A' | 'F';
  is_cross_market: boolean;
}
const vendors = (frData as { vendors: FrVendor[] }).vendors;

// Concise French positioning per vendor (the detailed reviews remain in English for now).
const fr: Record<string, string> = {
  'obat': 'Logiciel français de devis-facture et suivi de chantier, pensé pour le bâtiment — avec une offre micro-entreprise.',
  'tolteck': 'Devis et factures simples, conçus avec des artisans, fonctionnant hors-ligne sur le chantier.',
  'ebp-batiment': 'L’édition Bâtiment d’EBP : devis, facture et chantier d’un éditeur français établi.',
  'batappli': 'Logiciel BTP tout-en-un avec la bibliothèque de prix Batichiffrage intégrée.',
  'mediabat': 'Devis, facturation et suivi de chantier pour le BTP, à tarif abordable.',
  'vertuoza': 'Gestion bâtiment tout-en-un avec saisie vocale par IA (éditeur belge — vérifiez la conformité PDP).',
  'organilog': 'Gestion d’interventions et de maintenance sur le terrain (idéal pour le SAV récurrent).',
  'axonaut': 'Gestion d’entreprise tout-en-un (facturation, CRM, trésorerie) — généraliste, non spécifique BTP.',
  'habitatpresto': 'Mise en relation particuliers ↔ artisans vérifiés, par abonnement et sans commission.',
  'quotatis': 'Mise en relation travaux adossée au groupe ADEO (Leroy Merlin).',
  'travaux-com': 'Place de marché travaux à forte audience (propriété américaine — groupe Angi).',
  'starofservice': 'Place de marché de services locaux française (la rénovation y est une catégorie parmi d’autres).',
  'allotravaux': 'Mise en relation travaux avec un angle rénovation énergétique / RGE.',
  'payfit': 'Paie et RH en ligne pour TPE/PME — la seule avec une tarification publique en libre-service.',
  'silae': 'Moteur de paie dominant, distribué via les experts-comptables (couvre les conventions BTP).',
  'ebp-paie': 'Paie et déclarations sociales — pertinent si vous utilisez déjà la suite EBP.',
  'sage-paie-fr': 'Paie en ligne pour petites entreprises, d’une marque mondiale (non française à l’origine).',
  'smabtp': 'L’assureur mutualiste historique du BTP (depuis 1859) — la référence pour la décennale artisan.',
  'april-construction': 'RC décennale sur mesure par métier, avec des prix « à partir de » publiés.',
  'orus': 'Décennale 100 % en ligne, attestation sous 24 h, prix de départ public.',
  'axa-batissur': 'Décennale et multirisque BTP (offre BATISSUR) d’un grand assureur mondial.',
  'maaf-pro': 'Mutuelle généraliste française avec des solutions décennale pour artisans.',
  'facturation-electronique': 'Facturation électronique obligatoire via plateforme agréée (PDP) — réception pour tous au 1ᵉʳ sept. 2026, émission TPE/PME au 1ᵉʳ sept. 2027.',
  'assurance-decennale': 'Assurance décennale obligatoire (loi Spinetta) avant tout chantier — sanction pénale en cas de défaut.',
  'rge': 'Label RGE — indispensable pour que vos clients accèdent à MaPrimeRénov’ et aux aides.',
  'tva-batiment': 'TVA à taux multiples : 20 % standard, 10 % rénovation, 5,5 % rénovation énergétique.',
  'urssaf-micro': 'Cotisations URSSAF et régime micro-entrepreneur (franchise de TVA sous le seuil).',
  'cma-immatriculation': 'Immatriculation de l’entreprise via le guichet unique / RNE (SIRET), validée par la CMA.',
  'qualification-professionnelle': 'Métiers réglementés : diplôme (CAP/BP) ou 3 ans d’expérience requis (Code de l’artisanat).',
  'qualibat': 'Qualification volontaire de référence — et organisme majeur de délivrance du label RGE.',
};

const tierFr: Record<string, string> = { S: 'Recommandé', A: 'Convenable', F: 'Alerte' };
const cats = [
  { key: 'software', label: 'Logiciels devis-facture & gestion', desc: 'Outils français pour les devis, la facturation et le suivi de chantier — Obat et Tolteck pour les artisans, EBP et Batappli pour une couverture complète, Organilog pour la maintenance — avec la TVA à taux multiples (20/10/5,5).' },
  { key: 'lead-gen', label: 'Génération de prospects', desc: 'Places de marché françaises reliant les particuliers aux artisans — Habitatpresto (abonnement, sans commission), Quotatis (groupe Leroy Merlin), Allotravaux (angle rénovation énergétique/RGE).' },
  { key: 'payroll', label: 'Paie', desc: 'Paie conforme URSSAF pour les petites entreprises — PayFit en direct, Silae via votre expert-comptable, EBP et Sage. Vérifiez les spécificités BTP (caisses CIBTP) pour les équipes du bâtiment.' },
  { key: 'insurance', label: 'Assurance — décennale & RC Pro', desc: 'Décennale obligatoire et responsabilité civile pro — SMABTP (la mutuelle BTP historique), le spécialiste April par métier, l’assurtech Orus en ligne, ainsi qu’AXA et MAAF.' },
  { key: 'certification', label: 'Conformité & qualifications', desc: 'Ce que tout artisan doit gérer — la facturation électronique, l’assurance décennale obligatoire, le RGE pour les travaux aidés, la TVA à taux multiples, l’URSSAF/micro-entrepreneur, l’immatriculation CMA et les qualifications.' },
];

const enUrl = new URL('/fr/', Astro.site).toString();
const frUrl = new URL('/fr/fr/', Astro.site).toString();
const pageTitle = 'Annuaire des logiciels et services pour artisans du bâtiment — WrenchStack';
const pageDescription = `Avis indépendants sur ${vendors.length} solutions pour les artisans du bâtiment français : logiciels de devis-facture, génération de prospects, paie URSSAF et assurance décennale obligatoire — avec la facturation électronique, le RGE et la TVA à taux multiples.`;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  lang="fr"
  alternateUrls={[{ hreflang: 'en', href: enUrl }, { hreflang: 'fr', href: frUrl }, { hreflang: 'x-default', href: enUrl }]}
>
  <article class="mx-auto max-w-5xl px-4 py-12">

    <div class="mb-6 flex items-center justify-between gap-3">
      <div class="flex items-center gap-2">
        <span class="text-2xl" aria-hidden="true">🇫🇷</span>
        <p class="text-sm font-semibold uppercase tracking-wider text-orange-600">France · Artisans du bâtiment</p>
      </div>
      <a href="/fr/" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50">English</a>
    </div>

    <header class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">Annuaire des logiciels et services pour artisans du bâtiment</h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        Avis indépendants sur {vendors.length} solutions pertinentes pour les artisans du bâtiment français — logiciels de devis-facture (Obat, Tolteck, EBP), génération de prospects (Habitatpresto, Quotatis), paie (PayFit, Silae) et assurance décennale obligatoire (SMABTP, April, Orus) — au regard des réalités locales : la facturation électronique, la TVA à taux multiples, le RGE et le régime micro-entrepreneur.
      </p>
    </header>

    <section class="mb-10 flex flex-wrap items-center justify-between gap-4 rounded-lg border-2 border-emerald-300 bg-emerald-50 p-5">
      <div>
        <p class="text-xs font-bold tracking-wider text-emerald-700">⏰ Guide de conformité · Réception pour tous au 1ᵉʳ sept. 2026 · Émission TPE/PME au 1ᵉʳ sept. 2027</p>
        <h2 class="mt-1 text-base font-bold text-slate-900">La facturation électronique pour les artisans</h2>
        <p class="mt-1 text-sm text-slate-700">Le calendrier par étapes, le modèle de plateforme agréée (PDP) qui remplace le portail public gratuit abandonné, et quels logiciels sont des plateformes agréées.</p>
      </div>
      <a href="/fr/fr/guides/facturation-electronique-artisans/" class="shrink-0 rounded-md bg-emerald-700 px-5 py-3 text-sm font-semibold text-white hover:bg-emerald-800">Lire le guide →</a>
    </section>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-base font-bold text-slate-900">Ce qui distingue la gestion d’une entreprise artisanale en France</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        Le choix d’un logiciel pour artisan en France diffère structurellement des États-Unis ou du Royaume-Uni. D’abord, <strong>la facturation électronique devient obligatoire</strong> — dès le 1ᵉʳ septembre 2026 toute entreprise doit pouvoir recevoir des factures électroniques, et à partir du 1ᵉʳ septembre 2027 les TPE/PME et micro-entreprises devront les émettre via une plateforme agréée (PDP) ; le portail public gratuit prévu ayant été abandonné, le choix du logiciel a désormais un poids de conformité. Ensuite, <strong>l’assurance décennale est obligatoire</strong> — responsabilité de dix ans au titre de la loi Spinetta, souscrite avant l’ouverture du chantier, avec une sanction pénale en cas de défaut — et les clients attendent votre assureur et votre numéro de police sur le devis. De plus, <strong>la TVA est à taux multiples</strong> (20 % standard, 10 % rénovation, 5,5 % rénovation énergétique), donc le logiciel doit appliquer le bon taux par ligne. Le <strong>label RGE</strong> est commercialement essentiel : seuls les artisans RGE permettent à leurs clients de bénéficier de MaPrimeRénov’ et des aides. Enfin, la plupart des artisans solos sont <strong>micro-entrepreneurs</strong>, avec la franchise de TVA et la mention « TVA non applicable, art. 293 B du CGI ».
      </p>
    </section>

    {cats.map((cat) => {
      const cv = vendors.filter((v) => v.category === cat.key);
      if (cv.length === 0) return null;
      return (
        <section class="mb-12">
          <div class="mb-5">
            <h2 class="text-2xl font-bold text-slate-900">{cat.label}</h2>
            <p class="mt-1 text-sm text-slate-600 leading-relaxed">{cat.desc}</p>
          </div>
          <div class="grid gap-3 sm:grid-cols-2">
            {cv.map((v) => {
              const isCert = v.category === 'certification';
              const tierColor = v.tier === 'S' ? 'border-emerald-300' : v.tier === 'F' ? 'border-rose-300' : 'border-blue-300';
              const tierBadge = v.tier === 'S' ? 'bg-emerald-100 text-emerald-900' : v.tier === 'F' ? 'bg-rose-100 text-rose-900' : 'bg-blue-100 text-blue-900';
              const label = isCert ? 'Organisme officiel' : tierFr[v.tier];
              return (
                <article class={`rounded-lg border-2 ${tierColor} bg-white p-4`}>
                  <div class="mb-1 flex items-center gap-2 flex-wrap">
                    <h3 class="text-lg font-bold text-slate-900">{v.name}</h3>
                    <span class={`rounded-full px-2 py-0.5 text-xs font-bold ${tierBadge}`}>{label}</span>
                  </div>
                  <p class="text-sm text-slate-700 leading-relaxed">{fr[v.slug] ?? v.tagline}</p>
                  <div class="mt-3 flex flex-wrap gap-2">
                    <a href={`/fr/${v.slug}/`} class="rounded-md bg-slate-900 px-3 py-1.5 text-xs font-semibold text-white hover:bg-slate-700">Détails (en anglais) →</a>
                    <a href={v.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md bg-orange-500 px-3 py-1.5 text-xs font-semibold text-white hover:bg-orange-600">{isCert ? 'Site officiel' : 'Visiter le site'} →</a>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      );
    })}

    <section class="mb-10 rounded-lg border border-slate-200 bg-white p-5 text-sm text-slate-600">
      <p>Les avis détaillés par solution sont actuellement disponibles <a href="/fr/" class="font-medium text-orange-600 hover:underline">en anglais</a>, et nous étendons progressivement le contenu en français.</p>
    </section>

    <section class="rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Vous êtes éditeur ou prestataire français ?</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">Si vous proposez un logiciel ou un service pour les artisans français et souhaitez être évalué ou mis en avant, contactez-nous via notre <a href="/for-vendors/" class="underline">programme prestataires</a>.</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/for-vendors/" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">Travailler avec nous →</a>
        <a href="/fr/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">English directory</a>
      </div>
    </section>
  </article>
</Layout>
