---
import Layout from '../../layouts/Layout.astro';
import { verticals, toolsForVertical, verticalToUrl } from '../../lib/data';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Pricing', url: '/pricing/' },
];
---

<Layout
  title="Trades software pricing — every tool, every tier, verified"
  description="Real pricing for field service and trades software across all 13 verticals. Every tier verified quarterly. No vendor-supplied numbers."
  breadcrumbs={breadcrumbs}
>
  <section class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-8">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900">Pricing comparison hub</h1>
      <p class="mt-3 max-w-2xl text-lg text-slate-600">
        Pricing breakdown for every field service software platform across {verticals.length} trades verticals.
        Each tier verified independently. Sorted cheapest first.
      </p>
    </header>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {verticals.map((v) => {
        const count = toolsForVertical(v.slug).length;
        return (
          <a
            href={`/pricing/${verticalToUrl(v.slug)}/`}
            class="group rounded-lg border border-slate-200 bg-white p-5 transition hover:border-slate-400 hover:shadow-sm"
          >
            <h3 class="text-lg font-semibold text-slate-900 group-hover:text-orange-600">
              {v.name} software pricing
            </h3>
            <p class="mt-1 text-sm text-slate-500">{count} platform{count === 1 ? '' : 's'} compared</p>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
