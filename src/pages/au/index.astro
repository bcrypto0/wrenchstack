---
import Layout from '../../layouts/Layout.astro';
import auData from '../../data/international/au.json';

interface AuVendor {
  slug: string;
  name: string;
  category: string;
  vendor_url: string;
  tagline: string;
  market_position: string;
  au_specific_note?: string | null;
  uk_specific_note?: string | null;
  tier: 'S' | 'A' | 'F';
  reputation_flag: string | null;
  pros: string[];
  cons: string[];
  typical_pricing: string;
  is_cross_market: boolean;
  cross_market_link: string | null;
}

const vendors = (auData as { vendors: AuVendor[] }).vendors;

const categories = ['software', 'lead-gen', 'insurance', 'payroll', 'certification'];
const categoryMeta: Record<string, { label: string; description: string }> = {
  'software': { label: 'Field service software', description: 'AU-built FSM (AroFlo, ServiceM8, Simpro) and cross-market vendors with strong AU presence (Tradify AU, Fergus AU). Native STP Phase 2 + AU supply-house integrations (Reece/Tradelink/Coventry).' },
  'lead-gen': { label: 'Lead-generation platforms', description: 'AU trades marketplaces — Hipages dominates metros, Oneflare for second-tier categories, ServiceSeeking for regional/outer-metro coverage.' },
  'insurance': { label: 'Business insurance', description: 'AU-licensed business insurance — BizCover comparison + Trade Risk specialty + NRMA direct. AU$5M+ Public Liability options standard.' },
  'payroll': { label: 'Payroll software', description: 'AU payroll with STP Phase 2 + Fair Work award-interpretation compliance — MYOB heritage, KeyPay (Employment Hero) for award complexity, Xero AU for SMB.' },
  'certification': { label: 'State licensing bodies', description: 'Fragmented per-state licensing in AU — NSW Fair Trading, QBCC (QLD), VBA (VIC). No national body for residential trades. Multi-state contractors need separate licensing per state.' },
};

const vendorsByCategory: Record<string, AuVendor[]> = {};
categories.forEach(c => { vendorsByCategory[c] = vendors.filter(v => v.category === c); });

const pageTitle = 'AU Trades Vendor Directory — WrenchStack Australia';
const pageDescription = `WrenchStack's Australia trades vendor directory: ${vendors.length} platforms across software, lead-gen, insurance, payroll, and state licensing. Built for Australian contractors with native AU compliance (STP Phase 2, Fair Work awards, state-by-state licensing, AU supply-house integrations).`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Australia', url: '/au/' },
];
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <article class="mx-auto max-w-5xl px-4 py-12">

    <header class="mb-10">
      <div class="mb-3 flex items-center gap-2">
        <span class="text-2xl" aria-hidden="true">🇦🇺</span>
        <p class="text-sm font-semibold uppercase tracking-wider text-orange-600">Australia</p>
      </div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">
        Australia Trades Vendor Directory
      </h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        Independent reviews of {vendors.length} Australia-relevant vendors across 5 categories — built for AU contractors with native AU compliance context. STP Phase 2 payroll, Fair Work award interpretation, AU supply-house integrations (Reece/Tradelink/Coventry), state-specific licensing (NSW Fair Trading, QBCC, VBA), and the Hipages-dominant lead-gen market structure.
      </p>
    </header>

    <section class="mb-10 grid gap-3 grid-cols-2 sm:grid-cols-5">
      {categories.map(c => (
        <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
          <div class="text-2xl font-bold text-slate-900">{vendorsByCategory[c].length}</div>
          <div class="mt-1 text-xs text-slate-600 capitalize">{c.replace('-', ' ')}</div>
        </div>
      ))}
    </section>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-base font-bold text-slate-900">What's different about AU trades vendor selection</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        AU trades vendor selection is structurally different from US in three important ways. First, <strong>state licensing fragmentation</strong> — there's no national body for plumbing/electrical/building, each state has its own (NSW Fair Trading, QBCC, VBA), and cross-state work requires separate per-state licensing. Second, <strong>payroll compliance is complex</strong> — STP Phase 2 reporting + Fair Work award interpretation (100+ penalty/allowance rules) make award-interpretation engines like KeyPay a structural requirement, not a luxury. Third, <strong>Hipages dominates lead-gen</strong> in a way no single US platform does — AU homeowners search Hipages by name the way US homeowners search Google.
      </p>
    </section>

    {categories.map(c => {
      const cat = categoryMeta[c];
      const cv = vendorsByCategory[c];
      if (cv.length === 0) return null;
      return (
        <section class="mb-12">
          <div class="mb-5">
            <h2 class="text-2xl font-bold text-slate-900 capitalize">{cat.label}</h2>
            <p class="mt-1 text-sm text-slate-600 leading-relaxed">{cat.description}</p>
          </div>
          <div class="space-y-4">
            {cv.map(v => {
              const tierColor = v.tier === 'S' ? 'border-emerald-300' : v.tier === 'F' ? 'border-rose-300' : 'border-blue-300';
              const tierLabel = v.tier === 'S' ? 'Recommended' : v.tier === 'F' ? 'Reputation warning' : 'Workable';
              const tierBadge = v.tier === 'S' ? 'bg-emerald-100 text-emerald-900' : v.tier === 'F' ? 'bg-rose-100 text-rose-900' : 'bg-blue-100 text-blue-900';
              return (
                <article class={`rounded-lg border-2 ${tierColor} bg-white p-5`}>
                  <div class="mb-3 flex items-start justify-between gap-3">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center gap-2 mb-1 flex-wrap">
                        <h3 class="text-xl font-bold text-slate-900">{v.name}</h3>
                        <span class={`rounded-full px-2 py-0.5 text-xs font-bold ${tierBadge}`}>Tier {v.tier} · {tierLabel}</span>
                        {v.is_cross_market && (
                          <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">Cross-market</span>
                        )}
                      </div>
                      <p class="text-sm italic text-slate-500">{v.tagline}</p>
                    </div>
                  </div>

                  {v.reputation_flag && (
                    <div class="mb-3 rounded-md border-l-4 border-rose-500 bg-rose-50 px-4 py-3 text-sm text-rose-900">
                      <p class="font-bold uppercase tracking-wider text-xs text-rose-700 mb-1">⚠ Reputation warning</p>
                      <p class="leading-relaxed">{v.reputation_flag}</p>
                    </div>
                  )}

                  <p class="mb-3 text-sm text-slate-700 leading-relaxed">{v.market_position}</p>

                  {v.au_specific_note && (
                    <div class="mb-3 rounded-md bg-slate-50 px-4 py-3">
                      <p class="text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">AU-specific note</p>
                      <p class="text-sm text-slate-700 leading-relaxed">{v.au_specific_note}</p>
                    </div>
                  )}

                  <div class="mb-3 grid gap-3 sm:grid-cols-2">
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider text-emerald-700 mb-1">Pros</p>
                      <ul class="space-y-1 text-sm text-slate-700">
                        {v.pros.slice(0, 4).map(p => <li class="leading-snug">+ {p}</li>)}
                      </ul>
                    </div>
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider text-rose-700 mb-1">Cons</p>
                      <ul class="space-y-1 text-sm text-slate-700">
                        {v.cons.slice(0, 4).map(con => <li class="leading-snug">− {con}</li>)}
                      </ul>
                    </div>
                  </div>

                  <div class="mb-3 text-xs text-slate-600">
                    <strong class="text-slate-900">Typical AU pricing:</strong> {v.typical_pricing}
                  </div>

                  <div class="flex flex-wrap gap-2">
                    <a href={`/au/${v.slug}/`} class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700">Full AU review →</a>
                    <a href={v.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md bg-orange-500 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600">Visit {v.name} →</a>
                    {v.cross_market_link && (
                      <a href={v.cross_market_link} class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Full review (US market context)</a>
                    )}
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      );
    })}

    <section class="mt-12 rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">AU research is an active expansion</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">
        {vendors.length} AU vendors covered today across {categories.length} categories. We're actively expanding AU depth — full editorial reviews of AU-only vendors (Hipages, AroFlo, KeyPay) at the same depth as our US software reviews are in the editorial queue. Want an AU vendor reviewed? Submit them via our <a href="/for-vendors/" class="underline">vendor program</a>.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">Back to US directory →</a>
        <a href="/for-vendors/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">Submit an AU vendor</a>
        <a href="/methodology/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Methodology</a>
      </div>
    </section>
  </article>
</Layout>
