---
import Layout from '../layouts/Layout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Partners', url: '/affiliate-programs/' },
];

interface Program {
  tool: string;
  toolSlug?: string;
  type: 'direct' | 'partnerstack' | 'impact' | 'cj' | 'referral_rock' | 'other';
  best_for: string;
  // Internal status — `not_viable` entries are tracked in source but filtered before render.
  status: 'live_on_wrenchstack' | 'applying' | 'not_viable';
  // Internal-only notes (not rendered) — kept here so the page stays the
  // single source of truth for partner state. See MEMORY.md for full audit.
  notes?: string;
}

const programs: Program[] = [
  // LIVE — tracking wired into tools.json
  {
    tool: 'ServiceTitan',
    toolSlug: 'servicetitan',
    type: 'direct',
    best_for: 'Enterprise residential trades — $1M+ revenue contractors with 10+ techs',
    status: 'live_on_wrenchstack',
  },
  {
    tool: 'Workiz',
    toolSlug: 'workiz',
    type: 'direct',
    best_for: 'Locksmith, garage door, appliance repair, junk removal — on-demand service businesses',
    status: 'live_on_wrenchstack',
  },
  {
    tool: 'Service Fusion',
    toolSlug: 'servicefusion',
    type: 'referral_rock',
    best_for: 'Mid-size service shops wanting unlimited-user flat pricing',
    status: 'live_on_wrenchstack',
  },

  // IN REVIEW — applied, awaiting approval
  {
    tool: 'Jobber',
    toolSlug: 'jobber',
    type: 'partnerstack',
    best_for: 'Small-to-mid trades businesses (1–30 employees) across HVAC, plumbing, electrical, landscaping, cleaning',
    status: 'applying',
  },
  {
    tool: 'Connecteam',
    toolSlug: 'connecteam',
    type: 'partnerstack',
    best_for: 'Deskless workforce management for 10–100 employee trades teams',
    status: 'applying',
  },
  {
    tool: 'FieldEdge',
    toolSlug: 'fieldedge',
    type: 'direct',
    best_for: 'Mid-size HVAC/plumbing/electrical with deep QuickBooks integration needs',
    status: 'applying',
  },
  {
    tool: 'Tradify',
    toolSlug: 'tradify',
    type: 'direct',
    best_for: 'Small trade businesses (1–10 employees), UK/AU/NZ markets',
    status: 'applying',
    notes: 'Application submitted 2026-05-23. Awaiting confirmation email + partner portal access.',
  },
  {
    tool: 'Synchroteam',
    toolSlug: 'synchroteam',
    type: 'direct',
    best_for: 'International or multi-language field service businesses',
    status: 'applying',
    notes: 'Application submitted 2026-05-23. Awaiting reseller contract.',
  },
  {
    tool: 'WorkWave (FieldRoutes, PestPac, ServMan)',
    type: 'direct',
    best_for: 'Pest control, lawn care, multi-route field service businesses',
    status: 'applying',
    notes: 'Applied to Referral tier 2026-05-23.',
  },
  {
    tool: 'Skimmer',
    toolSlug: 'skimmer',
    type: 'direct',
    best_for: 'Pool service businesses (1–50 routes)',
    status: 'applying',
    notes: 'Cold email sent to niki@getskimmer.com 2026-05-24.',
  },

  // NOT VIABLE — tracked internally, filtered out before render.
  // Reasons kept here so we don't waste time re-investigating.
  {
    tool: 'Buildertrend',
    toolSlug: 'buildertrend',
    type: 'direct',
    best_for: 'Custom home builders, remodelers, specialty contractors',
    status: 'not_viable',
    notes: 'Customer-only ("Share your love for Buildertrend with fellow builders"). Email submission via hello@wrenchstack.com returned "You are not eligible to participate." Verified 2026-05-23.',
  },
  {
    tool: 'JobNimbus',
    toolSlug: 'jobnimbus',
    type: 'referral_rock',
    best_for: 'Roofing, restoration, and small construction CRM',
    status: 'not_viable',
    notes: 'Program explicitly restricted to "active JobNimbus users." Verified 2026-05-23.',
  },
  {
    tool: 'ServiceM8',
    toolSlug: 'servicem8',
    type: 'direct',
    best_for: 'Small Apple-using trade businesses (1–15 employees)',
    status: 'not_viable',
    notes: 'Implementation/consultant partner program requiring $99/yr membership + certification course. Consultant model, not affiliate. Verified 2026-05-24.',
  },
  {
    tool: 'BuildOps',
    type: 'direct',
    best_for: 'Commercial mechanical/electrical/plumbing contractors $5M+ revenue',
    status: 'not_viable',
    notes: 'Customer-referral form only. Direct partnerships outreach to partners@buildops.com bounced. Verified 2026-05-22.',
  },
  {
    tool: 'Knowify',
    toolSlug: 'knowify',
    type: 'direct',
    best_for: 'QuickBooks-heavy small-to-mid contractors needing AIA billing',
    status: 'not_viable',
    notes: 'Customer-only referral program. Direct outreach to info@knowify.com produced no partnership track. Verified 2026-05-22.',
  },
  {
    tool: 'Housecall Pro',
    toolSlug: 'housecall-pro',
    type: 'partnerstack',
    best_for: 'Residential home service businesses (HVAC, plumbing, electrical, cleaning)',
    status: 'not_viable',
    notes: 'PartnerStack application explicitly rejected May 2026. Plan to reapply with traffic data after 90 days of organic traffic.',
  },
  {
    tool: 'Houzz Pro',
    toolSlug: 'houzz-pro',
    type: 'direct',
    best_for: 'Remodelers, designers, home professionals needing marketing + project management',
    status: 'not_viable',
    notes: 'Public affiliate program page redirects to Pro-customer login wall. Effectively requires existing Houzz Pro subscription. Verified 2026-05-23.',
  },
];

// Only render live + in-review programs. `not_viable` entries are kept in
// source above for internal tracking but never shown publicly.
const visiblePrograms = programs.filter(p => p.status !== 'not_viable');
---

<Layout
  title="Software partners we work with"
  description="The software vendors WrenchStack earns commissions through when readers sign up via tracked links on our pages."
  breadcrumbs={breadcrumbs}
>
  <article class="mx-auto max-w-4xl px-4 py-12">

    <header class="mb-10">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        Software partners we work with
      </h1>
      <p class="mt-4 text-lg text-slate-600">
        Software vendors we earn commissions through when readers sign up via tracked links on our pages. The vendor pays the commission from their customer acquisition budget — readers pay the same price as buying direct.
      </p>
    </header>

    <section class="mb-12 overflow-x-auto rounded-lg border border-slate-200 bg-white">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 text-left text-slate-700">
          <tr>
            <th class="p-3 font-semibold">Partner</th>
            <th class="p-3 font-semibold">Status</th>
            <th class="p-3 font-semibold">Best fit for</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {visiblePrograms.map(p => (
            <tr class="hover:bg-slate-50">
              <td class="p-3 align-top">
                {p.toolSlug ? (
                  <a href={`/tools/${p.toolSlug}/`} class="font-semibold text-slate-900 hover:text-orange-600">{p.tool}</a>
                ) : (
                  <span class="font-semibold text-slate-900">{p.tool}</span>
                )}
              </td>
              <td class="p-3 align-top">
                {p.status === 'live_on_wrenchstack' && (
                  <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-700">Live</span>
                )}
                {p.status === 'applying' && (
                  <span class="rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-700">In review</span>
                )}
              </td>
              <td class="p-3 align-top text-slate-600">{p.best_for}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="prose prose-slate max-w-none">

      <h2>How affiliate relationships affect rankings</h2>

      <p>
        Rankings on WrenchStack are produced by the <a href="/methodology/">WrenchStack Score</a> — a weighted formula across vertical fit, user ratings, pricing transparency, feature depth, and integration coverage. The scoring algorithm has no input field for affiliate commission rate. Tools we earn nothing from can rank above tools we have partnerships with, and regularly do.
      </p>

      <p>
        See the <a href="/disclosure/">full affiliate disclosure</a> for FTC compliance details and the relationship between commissions and editorial coverage.
      </p>

      <hr />

      <p class="text-sm text-slate-500">
        <strong>Last updated:</strong> {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
    </section>
  </article>
</Layout>
