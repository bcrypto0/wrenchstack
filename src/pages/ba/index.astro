---
import Layout from '../../layouts/Layout.astro';
import baData from '../../data/international/ba.json';

interface BaVendor {
  slug: string; name: string; category: string; vendor_url: string;
  tagline: string; market_position: string; ba_specific_note?: string | null;
  tier: 'S' | 'A' | 'F'; reputation_flag: string | null;
  pros: string[]; cons: string[]; typical_pricing: string;
  is_cross_market: boolean; cross_market_link: string | null;
}

const vendors = (baData as { vendors: BaVendor[] }).vendors;
const categories = ['software', 'insurance', 'lead-gen', 'certification'];
const categoryMeta: Record<string, { label: string; description: string }> = {
  'insurance': { label: 'Contractor insurance', description: "Contractor & engineering cover from Bahraini insurers — market leader BKIC (GIG), the consolidating Solidarity, and GIG Takaful. Quote-based." },
  'lead-gen': { label: 'Lead generation & project intelligence', description: "Construction lead-gen is thin in Bahrain — ProTenders' pan-GCC project intelligence is the one genuine option; local home-services apps are residential, not construction-contractor." },
  'software': { label: 'Construction & trades software', description: 'From global PM/BIM platforms (Oracle Primavera, Aconex, Autodesk, Bentley) served via Manama resellers, to regional ERPs with a real Bahrain entity (Focus Softnet, PACT), the genuine Bahrain-native option (Diamond/Catalyst), and public-priced accounting (Zoho, Tally) for 10% NBR VAT.' },
  'certification': { label: 'Licensing & compliance', description: 'The Bahrain bodies every contractor deals with — NBR (10% VAT), CRPEP engineering licensing, Ministry of Works contractor classification, the Tender Board, LMRA & Bahrainisation, Benayat building permits, and Civil Defence fire safety.' },
};
const vendorsByCategory: Record<string, BaVendor[]> = {};
categories.forEach(c => { vendorsByCategory[c] = vendors.filter(v => v.category === c); });

const pageTitle = 'Bahrain Construction & Trades Software — WrenchStack';
const pageDescription = `Independent directory of ${vendors.length} construction & trades vendors for Bahrain: global PM/BIM platforms, Bahrain-native and regional ERPs, and 10%-VAT accounting — plus the NBR, CRPEP, contractor-classification, Tender Board, Benayat and Bahrainisation compliance you must handle.`;
const breadcrumbs = [ { name: 'Home', url: '/' }, { name: 'Bahrain', url: '/ba/' } ];
---
<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <article class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-10">
      <div class="mb-3 flex items-center gap-2">
        <span class="text-2xl" aria-hidden="true">🇧🇭</span>
        <p class="text-sm font-semibold uppercase tracking-wider text-orange-600">Bahrain · مملكة البحرين</p>
      </div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">Bahrain Construction & Trades Software Directory</h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        Independent reviews of {vendors.length} Bahrain-relevant vendors — global PM/BIM platforms (Oracle Primavera, Aconex, Autodesk, Bentley) served through Manama resellers, regional and Bahrain-native ERPs (Focus Softnet, PACT, Diamond/Catalyst), and public-priced accounting (Zoho, Tally) — with the local compliance context (NBR 10% VAT, CRPEP, Ministry of Works classification, Tender Board, LMRA, Benayat) that off-the-shelf software ignores.
      </p>
    </header>

    <section class="mb-10 grid gap-3 grid-cols-2 sm:grid-cols-4">
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">{vendors.length}</div>
        <div class="mt-1 text-xs text-slate-600">vendors reviewed</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">10%</div>
        <div class="mt-1 text-xs text-slate-600">VAT — highest in the GCC</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">~$3.3B</div>
        <div class="mt-1 text-xs text-slate-600">construction market (2026)</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">2030</div>
        <div class="mt-1 text-xs text-slate-600">Economic Vision</div>
      </div>
    </section>

    <section class="mb-10 flex flex-wrap items-center justify-between gap-4 rounded-lg border border-orange-200 bg-orange-50 p-5">
      <div>
        <h2 class="text-base font-bold text-slate-900">Deciding between two options?</h2>
        <p class="mt-1 text-sm text-slate-700">See Bahrain vendors compared side by side — a clear verdict, pros and cons, Bahrain-specific notes, and pricing, head to head.</p>
      </div>
      <a href="/ba/compare/" class="shrink-0 rounded-md bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-700">Compare Bahrain vendors →</a>
    </section>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-base font-bold text-slate-900">What's different about choosing software in Bahrain</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        Bahrain has the GCC's smallest construction market, and that shapes the software landscape. First, <strong>most platforms are served remotely</strong> — global PM/BIM tools reach Bahrain through Manama resellers or out of Dubai, so local implementation support is the thing to verify, and the genuinely Bahrain-native options (like Diamond's Catalyst) are few but valuable. Second, <strong>VAT is 10% — the highest in the GCC</strong> (raised from 5% in 2022), so accounting software must be set to Bahrain's rate, not the GCC-typical 5%. Third, <strong>there is no e-invoicing mandate yet</strong> — unlike Saudi (ZATCA) or the UAE — so "e-invoicing certified" isn't a buying requirement here today, though it's worth a forward look. And public-sector work is gated by <strong>Ministry of Works contractor classification</strong> plus <strong>Tender Board</strong> registration, while <strong>CRPEP</strong> licensing controls who can practise engineering and file permits through <strong>Benayat</strong>.
      </p>
    </section>

    {categories.map(c => {
      const cat = categoryMeta[c];
      const cv = vendorsByCategory[c];
      if (cv.length === 0) return null;
      return (
        <section class="mb-12">
          <div class="mb-5">
            <h2 class="text-2xl font-bold text-slate-900">{cat.label}</h2>
            <p class="mt-1 text-sm text-slate-600 leading-relaxed">{cat.description}</p>
          </div>
          <div class="space-y-4">
            {cv.map(v => {
              const isCert = v.category === 'certification';
              const tierColor = v.tier === 'S' ? 'border-emerald-300' : v.tier === 'F' ? 'border-rose-300' : 'border-blue-300';
              const tierLabel = isCert ? 'Official body / regime' : v.tier === 'S' ? 'Recommended' : v.tier === 'F' ? 'Reputation warning' : 'Workable';
              const tierBadge = v.tier === 'S' ? 'bg-emerald-100 text-emerald-900' : v.tier === 'F' ? 'bg-rose-100 text-rose-900' : 'bg-blue-100 text-blue-900';
              return (
                <article class={`rounded-lg border-2 ${tierColor} bg-white p-5`}>
                  <div class="mb-3 flex items-start justify-between gap-3">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center gap-2 mb-1 flex-wrap">
                        <h3 class="text-xl font-bold text-slate-900">{v.name}</h3>
                        <span class={`rounded-full px-2 py-0.5 text-xs font-bold ${tierBadge}`}>{isCert ? tierLabel : `Tier ${v.tier} · ${tierLabel}`}</span>
                        {v.is_cross_market && (<span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">Cross-market</span>)}
                      </div>
                      <p class="text-sm italic text-slate-500">{v.tagline}</p>
                    </div>
                  </div>
                  <p class="mb-3 text-sm text-slate-700 leading-relaxed">{v.market_position}</p>
                  {v.ba_specific_note && (
                    <div class="mb-3 rounded-md bg-slate-50 px-4 py-3">
                      <p class="text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">Bahrain-specific note</p>
                      <p class="text-sm text-slate-700 leading-relaxed">{v.ba_specific_note}</p>
                    </div>
                  )}
                  <div class="mb-3 grid gap-3 sm:grid-cols-2">
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider text-emerald-700 mb-1">{isCert ? 'What it covers' : 'Pros'}</p>
                      <ul class="space-y-1 text-sm text-slate-700">{v.pros.slice(0, 4).map(p => <li class="leading-snug">+ {p}</li>)}</ul>
                    </div>
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider text-rose-700 mb-1">{isCert ? 'Watch out for' : 'Cons'}</p>
                      <ul class="space-y-1 text-sm text-slate-700">{v.cons.slice(0, 4).map(con => <li class="leading-snug">− {con}</li>)}</ul>
                    </div>
                  </div>
                  <div class="mb-3 text-xs text-slate-600"><strong class="text-slate-900">{isCert ? 'Cost / access:' : 'Typical Bahrain pricing:'}</strong> {v.typical_pricing}</div>
                  <div class="flex flex-wrap gap-2">
                    <a href={`/ba/${v.slug}/`} class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700">Full Bahrain review →</a>
                    <a href={v.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md bg-orange-500 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600">{isCert ? 'Official site' : `Visit ${v.name}`} →</a>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      );
    })}

    <section class="mt-12 rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Are you a Bahrain vendor?</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">If you build software or services for Bahrain construction and trades businesses and want to be reviewed or featured, get in touch through our <a href="/for-vendors/" class="underline">vendor program</a>.</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/for-vendors/" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">Work with us →</a>
        <a href="/software-by-country/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">🌍 Software by country</a>
        <a href="/methodology/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Methodology</a>
      </div>
    </section>
  </article>
</Layout>
