---
import Layout from '../../layouts/Layout.astro';
import zaData from '../../data/international/za.json';

interface ZaVendor {
  slug: string; name: string; category: string; vendor_url: string;
  tagline: string; market_position: string; za_specific_note?: string | null;
  tier: 'S' | 'A' | 'F'; reputation_flag: string | null;
  pros: string[]; cons: string[]; typical_pricing: string;
  is_cross_market: boolean; cross_market_link: string | null;
}

const vendors = (zaData as { vendors: ZaVendor[] }).vendors;
const categories = ['software', 'lead-gen', 'payroll', 'insurance', 'certification'];
const categoryMeta: Record<string, { label: string; description: string }> = {
  'software': { label: 'Job management & trades software', description: 'SA-native platforms (ServCraft — with solar & electrical editions, Field Service Cloud, Odyssey) alongside globals with real ZAR pricing (Tradify, ServiceM8) and offline-capable options (Eworks Manager) — plus free solar design tooling (OpenSolar) for the installer boom.' },
  'lead-gen': { label: 'Lead generation', description: 'Kandua (SA’s biggest home-services marketplace, Santam-owned), pay-per-lead platforms with published pricing (ProCompare, R40–R150/lead), high-volume Snupit, and free-listing Uptasker.' },
  'payroll': { label: 'Payroll', description: 'SARS-compliance-first payroll: SimplePay (auto EMP201/UIF, e@syFile), PaySpace by Deel (EMP501/COIDA depth) and Sage Payroll SA (one-click submissions, published entry pricing).' },
  'insurance': { label: 'Business insurance', description: 'Contractor-grade cover: Santam (Contractors’ All Risks, defective-workmanship liability), direct SME options (MiWay, Old Mutual iWYZE — which explicitly targets tradespeople), King Price and Hollard via brokers.' },
  'certification': { label: 'Licensing & compliance', description: 'What’s legally required vs voluntary: DoEL electrical registration + CoCs, SAQCC Gas, PIRB plumbing CoCs, CIDB grading (the gate to public work), NHBRC for home builders, SARS (VAT/EMP201), and the COIDA Letter of Good Standing sites demand.' },
};
const vendorsByCategory: Record<string, ZaVendor[]> = {};
categories.forEach(c => { vendorsByCategory[c] = vendors.filter(v => v.category === c); });

const pageTitle = 'South Africa Trades Software & Services — WrenchStack';
const pageDescription = `Independent directory of ${vendors.length} South African trades vendors: job-management software (incl. the solar-installer boom), lead-gen marketplaces, SARS-compliant payroll, contractor insurance — plus the PIRB, DoEL, SAQCC Gas, CIDB, NHBRC and COIDA compliance every SA trades business navigates.`;
const breadcrumbs = [ { name: 'Home', url: '/' }, { name: 'South Africa', url: '/za/' } ];
---
<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <article class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-10">
      <div class="mb-3 flex items-center gap-2">
        <span class="text-2xl" aria-hidden="true">🇿🇦</span>
        <p class="text-sm font-semibold uppercase tracking-wider text-orange-600">South Africa</p>
      </div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">South Africa Trades Software & Services Directory</h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        Independent reviews of {vendors.length} South Africa-relevant vendors — job management (with SA-native options like ServCraft and real ZAR pricing from the globals), lead-gen marketplaces, SARS-compliant payroll and contractor insurance — built around the local realities: Certificates of Compliance, CIDB grading, EMP201 deadlines, and the solar-installation industry the load-shedding era created.
      </p>
    </header>

    <section class="mb-10 grid gap-3 grid-cols-2 sm:grid-cols-4">
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">{vendors.length}</div>
        <div class="mt-1 text-xs text-slate-600">vendors reviewed</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">+215%</div>
        <div class="mt-1 text-xs text-slate-600">rooftop solar growth since 2022 (~7.5 GW)</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">15%</div>
        <div class="mt-1 text-xs text-slate-600">VAT (registration above R2.3m turnover)</div>
      </div>
      <div class="rounded-lg border border-slate-200 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-slate-900">1–9</div>
        <div class="mt-1 text-xs text-slate-600">CIDB grades gate public work</div>
      </div>
    </section>

    <section class="mb-10 flex flex-wrap items-center justify-between gap-4 rounded-lg border border-orange-200 bg-orange-50 p-5">
      <div>
        <h2 class="text-base font-bold text-slate-900">Deciding between two options?</h2>
        <p class="mt-1 text-sm text-slate-700">See SA vendors compared side by side — a clear verdict, pros and cons, SA-specific notes, and pricing, head to head.</p>
      </div>
      <a href="/za/compare/" class="shrink-0 rounded-md bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-700">Compare SA vendors →</a>
    </section>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-base font-bold text-slate-900">What's different about running a trades business in South Africa</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        Three structural differences shape SA vendor selection. First, <strong>Certificates of Compliance run the trades</strong>: electrical CoCs (DoEL-registered persons only — required on every installation and property transfer), gas CoCs (SAQCC Gas practitioners; unregistered work voids home insurance) and PIRB plumbing CoCs for geysers and solar water heaters — software that numbers and tracks CoCs per job is a genuinely local need. Second, <strong>compliance documents gate the work</strong>: a CIDB grade (1–9) caps the public tenders you can bid, NHBRC registration is criminal-sanction-mandatory for home builders, and an annually renewed COIDA Letter of Good Standing is a de-facto site-access pass. Third, <strong>SARS sets the rhythm</strong> — 15% VAT (compulsory only above R2.3m turnover from April 2026), monthly EMP201 within 7 days of month-end, and a Peppol-based e-invoicing mandate phasing in around 2026–2028. And the market's big structural story: the load-shedding era built a <strong>solar-installation industry</strong> — rooftop PV up ~215% since 2022 to ~7.5 GW, 18,000+ jobs — that now buys trades software like any other vertical.
      </p>
    </section>

    {categories.map(c => {
      const cat = categoryMeta[c];
      const cv = vendorsByCategory[c];
      if (cv.length === 0) return null;
      return (
        <section class="mb-12">
          <div class="mb-5">
            <h2 class="text-2xl font-bold text-slate-900">{cat.label}</h2>
            <p class="mt-1 text-sm text-slate-600 leading-relaxed">{cat.description}</p>
          </div>
          <div class="space-y-4">
            {cv.map(v => {
              const isCert = v.category === 'certification';
              const tierColor = v.tier === 'S' ? 'border-emerald-300' : v.tier === 'F' ? 'border-rose-300' : 'border-blue-300';
              const tierLabel = isCert ? 'Official body / regime' : v.tier === 'S' ? 'Recommended' : v.tier === 'F' ? 'Reputation warning' : 'Workable';
              const tierBadge = v.tier === 'S' ? 'bg-emerald-100 text-emerald-900' : v.tier === 'F' ? 'bg-rose-100 text-rose-900' : 'bg-blue-100 text-blue-900';
              return (
                <article class={`rounded-lg border-2 ${tierColor} bg-white p-5`}>
                  <div class="mb-3 flex items-start justify-between gap-3">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center gap-2 mb-1 flex-wrap">
                        <h3 class="text-xl font-bold text-slate-900">{v.name}</h3>
                        <span class={`rounded-full px-2 py-0.5 text-xs font-bold ${tierBadge}`}>{isCert ? tierLabel : `Tier ${v.tier} · ${tierLabel}`}</span>
                        {v.is_cross_market && (<span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">Cross-market</span>)}
                      </div>
                      <p class="text-sm italic text-slate-500">{v.tagline}</p>
                    </div>
                  </div>
                  <p class="mb-3 text-sm text-slate-700 leading-relaxed">{v.market_position}</p>
                  {v.za_specific_note && (
                    <div class="mb-3 rounded-md bg-slate-50 px-4 py-3">
                      <p class="text-xs font-bold uppercase tracking-wider text-slate-700 mb-1">SA-specific note</p>
                      <p class="text-sm text-slate-700 leading-relaxed">{v.za_specific_note}</p>
                    </div>
                  )}
                  <div class="mb-3 grid gap-3 sm:grid-cols-2">
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider text-emerald-700 mb-1">{isCert ? 'What it covers' : 'Pros'}</p>
                      <ul class="space-y-1 text-sm text-slate-700">{v.pros.slice(0, 4).map(p => <li class="leading-snug">+ {p}</li>)}</ul>
                    </div>
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider text-rose-700 mb-1">{isCert ? 'Watch out for' : 'Cons'}</p>
                      <ul class="space-y-1 text-sm text-slate-700">{v.cons.slice(0, 4).map(con => <li class="leading-snug">− {con}</li>)}</ul>
                    </div>
                  </div>
                  <div class="mb-3 text-xs text-slate-600"><strong class="text-slate-900">{isCert ? 'Cost / access:' : 'Typical SA pricing:'}</strong> {v.typical_pricing}</div>
                  <div class="flex flex-wrap gap-2">
                    <a href={`/za/${v.slug}/`} class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700">Full SA review →</a>
                    <a href={v.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md bg-orange-500 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600">{isCert ? 'Official site' : `Visit ${v.name}`} →</a>
                    {v.cross_market_link && (<a href={v.cross_market_link} class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Full review (US market context)</a>)}
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      );
    })}

    <section class="mt-12 rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Are you a South African vendor?</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">If you build software or services for SA trades businesses and want to be reviewed or featured, get in touch through our <a href="/for-vendors/" class="underline">vendor program</a>.</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/for-vendors/" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">Work with us →</a>
        <a href="/software-by-country/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">🌍 Software by country</a>
        <a href="/methodology/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Methodology</a>
      </div>
    </section>
  </article>
</Layout>
