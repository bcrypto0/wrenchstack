---
import Layout from '../../../layouts/Layout.astro';
import statesData from '../../../data/states.json';
import { getVertical, verticalToUrl, rankToolsForVertical } from '../../../lib/data';

interface State {
  slug: string;
  name: string;
  abbr: string;
  region: string;
  population: number;
  licensing_note: string;
}

const TARGET_VERTICALS = ['hvac', 'plumbing', 'electrical', 'roofing', 'general_contractor'];

export async function getStaticPaths() {
  const states = (statesData as { states: State[] }).states;
  return states.map((state) => ({
    params: { state: state.slug },
    props: { state },
  }));
}

interface Props {
  state: State;
}

const { state } = Astro.props;

const verticalsForState = TARGET_VERTICALS
  .map((slug) => {
    const v = getVertical(slug);
    if (!v) return null;
    const top = rankToolsForVertical(slug).slice(0, 3);
    return { vertical: v, slug, topTools: top };
  })
  .filter((v): v is NonNullable<typeof v> => !!v);

const pageTitle = `Best Trades Software for ${state.name} Contractors (2026)`;
const pageDescription = `Top field service and trades software for ${state.name} contractors: HVAC, plumbing, electrical, roofing, and general contractor platforms. Pricing, ratings, and ${state.abbr}-specific licensing context.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'States', url: '/state/' },
  { name: state.name, url: `/state/${state.slug}/` },
];

const popMillions = (state.population / 1_000_000).toFixed(1);
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <article class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-10">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-orange-600">
        {state.region} · Population {popMillions}M
      </p>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">
        Best Trades Software for {state.name} Contractors
      </h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        Field service software recommendations for {state.name} ({state.abbr}) contractors across {verticalsForState.length} major trades — HVAC, plumbing, electrical, roofing, and general contracting. All platforms work nationwide; the editorial filtering here surfaces what fits {state.name}'s licensing landscape and shop sizes.
      </p>
    </header>

    <section class="mb-10 rounded-lg border border-blue-200 bg-blue-50 p-6">
      <h2 class="mb-2 text-base font-bold text-blue-900">{state.name} contractor licensing snapshot</h2>
      <p class="text-sm text-blue-900 leading-relaxed">{state.licensing_note}</p>
      <p class="mt-3 text-xs text-blue-700">
        License requirements change — always verify with your state board before signing contracts. We update this snapshot annually.
      </p>
    </section>

    <section class="mb-10">
      <h2 class="mb-5 text-2xl font-bold text-slate-900">Pick your trade</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {verticalsForState.map(({ vertical, slug, topTools }) => (
          <a
            href={`/state/${state.slug}/${verticalToUrl(slug)}/`}
            class="block rounded-lg border border-slate-200 bg-white p-5 no-underline transition hover:border-orange-300 hover:bg-orange-50"
          >
            <h3 class="mb-2 text-lg font-bold text-slate-900">{vertical.name}</h3>
            <p class="mb-3 text-sm text-slate-600">
              Top picks for {vertical.name.toLowerCase()} contractors in {state.abbr}:
            </p>
            <ul class="space-y-1 text-sm text-slate-700">
              {topTools.map((t) => (
                <li>• {t.name}</li>
              ))}
            </ul>
            <p class="mt-4 text-xs font-semibold text-orange-600">
              See full ranking →
            </p>
          </a>
        ))}
      </div>
    </section>

    <section class="rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Not finding your trade?</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">
        We cover {verticalsForState.length} trades per state. Browse the full directory by trade or take the matching quiz for a personalized recommendation.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/quiz/" class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">
          Matching quiz →
        </a>
        <a href="/tools/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">
          Browse all tools
        </a>
        <a href="/state/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">
          All states
        </a>
      </div>
    </section>
  </article>
</Layout>
