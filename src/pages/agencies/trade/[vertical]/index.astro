---
import Layout from '../../../../layouts/Layout.astro';
import { marketingAgencies, agencyTier, verticalToUrl, getVertical, type MarketingAgency } from '../../../../lib/data';

export async function getStaticPaths() {
  const TARGET_VERTICALS = ['hvac', 'plumbing', 'roofing'];
  return TARGET_VERTICALS.map((slug) => {
    const v = getVertical(slug);
    if (!v) return null;
    return { params: { vertical: verticalToUrl(slug) }, props: { verticalSlug: slug } };
  }).filter((p): p is NonNullable<typeof p> => !!p);
}

interface Props { verticalSlug: string; }
const { verticalSlug } = Astro.props;
const vertical = getVertical(verticalSlug)!;

// Match agencies to this vertical — specialty agencies first, then home-services generalists
const matched = marketingAgencies.filter(
  (a) => a.verticals_specialty.includes(verticalSlug) || a.agency_type === 'home-services-focus' || a.agency_type === 'generalist'
);

const byTier: Record<'S' | 'A' | 'F', MarketingAgency[]> = { S: [], A: [], F: [] };
for (const a of matched) byTier[agencyTier(a)].push(a);

const pageTitle = `Best Marketing Agencies for ${vertical.name} Contractors (2026)`;
const pageDescription = `Independent reviews of marketing agencies serving ${vertical.name.toLowerCase()} contractors specifically — trade specialists, home-services generalists, and honest reputation warnings on Townsquare Interactive and Marketing 360.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Marketing agencies', url: '/agencies/' },
  { name: vertical.name, url: `/agencies/trade/${verticalToUrl(verticalSlug)}/` },
];

const tierMeta = {
  S: { label: 'Recommended', color: 'bg-emerald-100 text-emerald-900 ring-emerald-300', cardBorder: 'border-emerald-300' },
  A: { label: 'Context-specific fit', color: 'bg-blue-100 text-blue-900 ring-blue-300', cardBorder: 'border-blue-300' },
  F: { label: 'Reputation warning applies', color: 'bg-rose-100 text-rose-900 ring-rose-300', cardBorder: 'border-rose-300' },
};

function tradeIntro(slug: string): string {
  switch (slug) {
    case 'hvac':
      return 'HVAC has one of the highest competition + highest CPC dynamics in residential trades marketing. Peak summer + peak winter create seasonal demand spikes; emergency-service intent drives intent-stage searches. The right agency understands this dynamic and adjusts campaign pacing accordingly.';
    case 'plumbing':
      return 'Plumbing marketing splits between emergency-service capture (intent-stage, willing-to-pay-now) and remodel-project capture (shopping, comparing, slow decision). The right agency segments PPC + content for both customer types rather than treating plumbing as a single audience.';
    case 'roofing':
      return 'Roofing marketing is uniquely seasonal (storm events drive demand spikes), insurance-claim-heavy (restoration work), and locality-sensitive (storm-recovery markets matter more than competitive density). The right agency understands the storm-event + insurance-restoration dynamics that drive roofing revenue.';
    default:
      return `Marketing agency recommendations for ${vertical.name.toLowerCase()} contractors.`;
  }
}

const faqs = [
  {
    q: `Which marketing agency is best for ${vertical.name.toLowerCase()} contractors?`,
    a: byTier.S.length > 0
      ? `Based on trade expertise + reputation, ${byTier.S[0].name} is the top recommendation for ${vertical.name.toLowerCase()} marketing. ${byTier.S[0].best_for}.${byTier.S.length > 1 ? ` ${byTier.S[1].name} is a strong alternative.` : ''} For established shops, the trade specialist usually delivers higher ROI than generalist alternatives.`
      : `Most ${vertical.name.toLowerCase()} contractors should consider trade-specific specialists first, then home-services generalists (Adapt Digital Solutions, Lemonade Stand) if a trade-specific option doesn't fit.`,
  },
  {
    q: `What does a typical marketing retainer cost for ${vertical.name.toLowerCase()}?`,
    a: 'Most trade-specific specialists run $1,500-$8,000/mo retainer ranges. Home-services generalists run similar pricing. Enterprise agencies (Scorpion, Blue Corona full-service) run $5,000-$25,000/mo. Cost-to-acquired-customer math typically lands at $200-$600 per closed job for shops in the recommended-agency tier — far better than DIY marketing for most operators.',
  },
  {
    q: `Should I avoid Townsquare Interactive and Marketing 360?`,
    a: 'Yes for both. Townsquare Interactive has a documented complaint pattern serious enough that former customers operate the FrownSquare.com complaint-aggregation site. Marketing 360 has documented lock-in contracts and ROI underperformance complaints. Both lock customers into 6-12 month minimum contracts. Better alternatives exist at comparable or moderately higher pricing.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <article class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-10">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-orange-600">
        Marketing agencies · {vertical.name}
      </p>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">
        Best Marketing Agencies for {vertical.name} Contractors (2026)
      </h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">{tradeIntro(verticalSlug)}</p>
    </header>

    {(['S', 'A', 'F'] as const).map((tier) => {
      const agencies = byTier[tier];
      if (agencies.length === 0) return null;
      const meta = tierMeta[tier];
      return (
        <section class="mb-12">
          <div class="mb-5 flex items-baseline gap-3">
            <h2 class="text-2xl font-bold text-slate-900">{meta.label}</h2>
            <span class={`inline-block rounded-full px-2 py-0.5 text-xs font-bold ring-1 ${meta.color}`}>{agencies.length}</span>
          </div>

          <div class="space-y-4">
            {agencies.map((a) => (
              <article class={`rounded-lg border-2 ${meta.cardBorder} bg-white p-5`}>
                <div class="mb-3 flex items-start justify-between gap-3">
                  <div class="min-w-0 flex-1">
                    <h3 class="text-xl font-bold text-slate-900">
                      <a href={`/agencies/${a.slug}/`} class="hover:text-orange-600">{a.name}</a>
                    </h3>
                    <p class="text-sm italic text-slate-500">{a.tagline}</p>
                  </div>
                  <div class="shrink-0 text-right text-xs">
                    <p class="font-bold text-slate-900 uppercase tracking-wider">{a.agency_type.replace(/-/g, ' ')}</p>
                    <p class="text-slate-500">{a.typical_retainer_usd}</p>
                  </div>
                </div>

                {a.reputation_flag && (
                  <div class="mb-3 rounded-md border-l-4 border-rose-500 bg-rose-50 px-4 py-3 text-sm text-rose-900">
                    <p class="font-bold uppercase tracking-wider text-xs text-rose-700 mb-1">⚠ Reputation warning</p>
                    <p class="leading-relaxed">{a.reputation_flag.split('.')[0]}.</p>
                  </div>
                )}

                <p class="mb-3 text-sm text-slate-700 leading-relaxed">
                  <strong class="text-slate-900">Best for {vertical.name.toLowerCase()}:</strong> {a.best_for}
                </p>

                <div class="flex flex-wrap gap-2">
                  <a href={`/agencies/${a.slug}/`} class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800">Read full review →</a>
                  <a href={a.affiliate_url.startsWith('http') ? a.affiliate_url : a.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md border border-orange-300 bg-white px-4 py-2 text-sm font-semibold text-orange-700 hover:bg-orange-50">Visit {a.name.split(' ')[0]}</a>
                </div>
              </article>
            ))}
          </div>
        </section>
      );
    })}

    <section class="mb-10">
      <h2 class="mb-5 text-2xl font-bold text-slate-900">Frequently asked for {vertical.name.toLowerCase()} contractors</h2>
      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="rounded-lg border border-slate-200 bg-white p-4">
            <summary class="cursor-pointer font-semibold text-slate-900">{f.q}</summary>
            <p class="mt-3 text-slate-700 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">More for {vertical.name.toLowerCase()} contractors</h2>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href={`/${verticalToUrl(verticalSlug)}/`} class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">{vertical.name} software directory →</a>
        <a href={`/lead-gen/trade/${verticalToUrl(verticalSlug)}/`} class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">Lead-gen for {vertical.name.toLowerCase()}</a>
        <a href={`/insurance/trade/${verticalToUrl(verticalSlug)}/`} class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Insurance for {vertical.name.toLowerCase()}</a>
      </div>
    </section>
  </article>
</Layout>
