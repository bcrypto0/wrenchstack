---
import Layout from '../../layouts/Layout.astro';
import { getTool, type Tool } from '../../lib/data';

const TRIO_LISTINGS = [
  { slugs: ['housecall-pro', 'jobber', 'workiz'], category: 'Residential service businesses' },
  { slugs: ['housecall-pro', 'jobber', 'servicefusion'], category: 'Small-to-mid residential service shops' },
  { slugs: ['housecall-pro', 'jobber', 'servicetitan'], category: 'Entry to enterprise residential' },
  { slugs: ['fieldedge', 'housecall-pro', 'servicetitan'], category: 'QuickBooks-heavy mid-size to enterprise' },
  { slugs: ['jobber', 'servicefusion', 'workiz'], category: 'Small business per-company pricing' },
  { slugs: ['fieldpulse', 'housecall-pro', 'jobber'], category: 'Growing service businesses' },
  { slugs: ['buildops', 'fieldedge', 'servicetitan'], category: 'Enterprise commercial trades' },
  { slugs: ['buildops', 'servicetitan', 'servicetrade'], category: 'Commercial mechanical contractors' },
  { slugs: ['fieldedge', 'servicefusion', 'servicetitan'], category: 'Mid-size with QuickBooks needs' },
  { slugs: ['jobber', 'joist', 'servicem8'], category: 'Solo and 1-2 tech operations' },
  { slugs: ['jobber', 'joist', 'tradify'], category: 'Solo trade businesses' },
  { slugs: ['acculynx', 'jobnimbus', 'servicetitan'], category: 'Roofing and restoration contractors' },
  { slugs: ['acculynx', 'buildertrend', 'jobnimbus'], category: 'Roofing project management' },
  { slugs: ['buildertrend', 'jobnimbus', 'jobtread'], category: 'Construction project management' },
  { slugs: ['fieldroutes', 'gorilladesk', 'pestpac'], category: 'Pest control operators' },
  { slugs: ['fieldroutes', 'gorilladesk', 'servsuite'], category: 'Pest control software platforms' },
  { slugs: ['aspire', 'realgreen', 'service-autopilot'], category: 'Landscaping and lawn care' },
  { slugs: ['jobber', 'service-autopilot', 'servicefusion'], category: 'Landscape companies, multiple sizes' },
  { slugs: ['housecall-pro', 'jobber', 'zenmaid'], category: 'Residential cleaning businesses' },
  { slugs: ['connecteam', 'jobber', 'zenmaid'], category: 'Cleaning operations and team management' },
  { slugs: ['fieldedge', 'knowify', 'method-crm'], category: 'QuickBooks-native contractors' },
  { slugs: ['fieldpulse', 'housecall-pro', 'workiz'], category: 'On-demand service shops' },
  { slugs: ['jobber', 'servicem8', 'tradify'], category: 'Mobile-first small trade businesses' },
  { slugs: ['buildops', 'fieldedge', 'simpro'], category: 'Custom-quoted enterprise platforms' },
  { slugs: ['fieldpulse', 'jobber', 'workiz'], category: 'Multi-trade affordable platforms' },
  { slugs: ['buildops', 'servicetrade', 'simpro'], category: 'Commercial-only trades platforms' },
  { slugs: ['servicem8', 'simpro', 'tradify'], category: 'International / non-US trades software' },
  { slugs: ['housecall-pro', 'vonigo', 'workiz'], category: 'Franchise and multi-location service' },
  { slugs: ['fieldedge', 'housecall-pro', 'servicetitan'], category: 'HVAC residential service businesses' },
];

interface ResolvedTrio {
  tools: Tool[];
  category: string;
  url: string;
  title: string;
}

const resolved: ResolvedTrio[] = TRIO_LISTINGS.map(def => {
  const sorted = [...def.slugs].sort();
  const tools = sorted.map(slug => getTool(slug)).filter((t): t is Tool => !!t);
  if (tools.length !== 3) return null;
  return {
    tools,
    category: def.category,
    url: `/multi-compare/${sorted.join('-vs-')}/`,
    title: tools.map(t => t.name).join(' vs '),
  };
}).filter((r): r is ResolvedTrio => r !== null);

// Group by buyer-segment (residential, commercial, vertical specialty)
function classifyTrio(t: ResolvedTrio): 'residential' | 'commercial' | 'vertical-specialty' | 'small-business' {
  const cat = t.category.toLowerCase();
  if (cat.includes('commercial') || cat.includes('enterprise')) return 'commercial';
  if (cat.includes('solo') || cat.includes('small') || cat.includes('1-2')) return 'small-business';
  if (cat.includes('roofing') || cat.includes('pest') || cat.includes('landscap') || cat.includes('cleaning') || cat.includes('construction')) return 'vertical-specialty';
  return 'residential';
}

const grouped = {
  residential: resolved.filter(t => classifyTrio(t) === 'residential'),
  commercial: resolved.filter(t => classifyTrio(t) === 'commercial'),
  'small-business': resolved.filter(t => classifyTrio(t) === 'small-business'),
  'vertical-specialty': resolved.filter(t => classifyTrio(t) === 'vertical-specialty'),
};

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Multi-tool comparisons', url: '/multi-compare/' },
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '3-way trades software comparisons',
  numberOfItems: resolved.length,
  itemListElement: resolved.map((r, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: r.title,
    url: `https://wrenchstack.com${r.url}`,
  })),
};
---

<Layout
  title={`3-way trades software comparisons — ${resolved.length} matchups`}
  description={`${resolved.length} curated 3-way comparisons of trades software. Each comparison includes decision matrix, per-vertical winner table, unique features per tool, implementation timeline comparison, and 7 FAQs.`}
  breadcrumbs={breadcrumbs}
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <section class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-10">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        Multi-tool comparisons
      </h1>
      <p class="mt-4 max-w-3xl text-lg text-slate-600">
        Three platforms head-to-head — for when a 2-way comparison isn't enough. {resolved.length} curated trios covering residential service, commercial trades, small business operations, and vertical specialty platforms.
      </p>
      <p class="mt-3 text-sm text-slate-500">
        Each comparison includes 3-column decision matrix ("Pick X if…"), per-vertical winner table, unique-features-per-tool breakdown, implementation timeline comparison, and 7 FAQs covering best overall / cheapest / QuickBooks integration / migration / mobile UX / team-size edge cases.
      </p>
    </header>

    {grouped.residential.length > 0 && (
      <section class="mb-12">
        <h2 class="mb-2 text-2xl font-bold tracking-tight text-slate-900">Residential service trios</h2>
        <p class="mb-6 text-slate-600">
          Residential FSM platforms compared head-to-head-to-head. Most-searched buyer combinations.
        </p>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {grouped.residential.map(r => (
            <a
              href={r.url}
              class="group rounded-lg border border-slate-200 bg-white p-5 transition hover:border-orange-400 hover:shadow-sm"
            >
              <div class="font-semibold text-slate-900 group-hover:text-orange-600">{r.title}</div>
              <div class="mt-1 text-xs text-slate-500">{r.category}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    {grouped.commercial.length > 0 && (
      <section class="mb-12">
        <h2 class="mb-2 text-2xl font-bold tracking-tight text-slate-900">Commercial and enterprise trios</h2>
        <p class="mb-6 text-slate-600">
          Commercial mechanical, electrical, plumbing, and general contractor platforms. Custom-quoted enterprise tier comparisons.
        </p>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {grouped.commercial.map(r => (
            <a
              href={r.url}
              class="group rounded-lg border border-slate-200 bg-white p-5 transition hover:border-orange-400 hover:shadow-sm"
            >
              <div class="font-semibold text-slate-900 group-hover:text-orange-600">{r.title}</div>
              <div class="mt-1 text-xs text-slate-500">{r.category}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    {grouped['small-business'].length > 0 && (
      <section class="mb-12">
        <h2 class="mb-2 text-2xl font-bold tracking-tight text-slate-900">Small business and solo operator trios</h2>
        <p class="mb-6 text-slate-600">
          Comparisons for solo contractors and 1-3 person operations. Free-tier and budget-friendly platforms emphasized.
        </p>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {grouped['small-business'].map(r => (
            <a
              href={r.url}
              class="group rounded-lg border border-slate-200 bg-white p-5 transition hover:border-orange-400 hover:shadow-sm"
            >
              <div class="font-semibold text-slate-900 group-hover:text-orange-600">{r.title}</div>
              <div class="mt-1 text-xs text-slate-500">{r.category}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    {grouped['vertical-specialty'].length > 0 && (
      <section class="mb-12">
        <h2 class="mb-2 text-2xl font-bold tracking-tight text-slate-900">Vertical specialty trios</h2>
        <p class="mb-6 text-slate-600">
          Trade-specific platform comparisons — roofing, pest control, landscaping, cleaning, general construction.
        </p>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {grouped['vertical-specialty'].map(r => (
            <a
              href={r.url}
              class="group rounded-lg border border-slate-200 bg-white p-5 transition hover:border-orange-400 hover:shadow-sm"
            >
              <div class="font-semibold text-slate-900 group-hover:text-orange-600">{r.title}</div>
              <div class="mt-1 text-xs text-slate-500">{r.category}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="mt-12 rounded-lg bg-slate-50 p-6 text-sm text-slate-600">
      <p>
        Looking for a 2-way comparison instead? See <a href="/compare/" class="text-orange-600 hover:underline">all 1,100+ head-to-head pairings</a>, take the <a href="/quiz/" class="text-orange-600 hover:underline">matching quiz</a> for personalized picks, or run the <a href="/roi-calculator/" class="text-orange-600 hover:underline">ROI calculator</a> for cost-benefit estimates at your team size.
      </p>
    </section>
  </section>
</Layout>
