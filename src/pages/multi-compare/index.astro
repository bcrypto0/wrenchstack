---
import Layout from '../../layouts/Layout.astro';
import { getTool, type Tool } from '../../lib/data';

const TRIO_LISTINGS = [
  { slugs: ['housecall-pro', 'jobber', 'workiz'], category: 'Residential service businesses' },
  { slugs: ['housecall-pro', 'jobber', 'servicefusion'], category: 'Small-to-mid residential service shops' },
  { slugs: ['housecall-pro', 'jobber', 'servicetitan'], category: 'Entry to enterprise residential' },
  { slugs: ['fieldedge', 'housecall-pro', 'servicetitan'], category: 'QuickBooks-heavy mid-size to enterprise' },
  { slugs: ['jobber', 'servicefusion', 'workiz'], category: 'Small business per-company pricing' },
  { slugs: ['fieldpulse', 'housecall-pro', 'jobber'], category: 'Growing service businesses' },
  { slugs: ['buildops', 'fieldedge', 'servicetitan'], category: 'Enterprise commercial trades' },
  { slugs: ['buildops', 'servicetitan', 'servicetrade'], category: 'Commercial mechanical contractors' },
  { slugs: ['fieldedge', 'servicefusion', 'servicetitan'], category: 'Mid-size with QuickBooks needs' },
  { slugs: ['jobber', 'joist', 'servicem8'], category: 'Solo and 1-2 tech operations' },
  { slugs: ['jobber', 'joist', 'tradify'], category: 'Solo trade businesses' },
  { slugs: ['acculynx', 'jobnimbus', 'servicetitan'], category: 'Roofing and restoration contractors' },
  { slugs: ['acculynx', 'buildertrend', 'jobnimbus'], category: 'Roofing project management' },
  { slugs: ['buildertrend', 'jobnimbus', 'jobtread'], category: 'Construction project management' },
  { slugs: ['fieldroutes', 'gorilladesk', 'pestpac'], category: 'Pest control operators' },
  { slugs: ['fieldroutes', 'gorilladesk', 'servsuite'], category: 'Pest control software platforms' },
  { slugs: ['aspire', 'realgreen', 'service-autopilot'], category: 'Landscaping and lawn care' },
  { slugs: ['jobber', 'service-autopilot', 'servicefusion'], category: 'Landscape companies, multiple sizes' },
  { slugs: ['housecall-pro', 'jobber', 'zenmaid'], category: 'Residential cleaning businesses' },
  { slugs: ['connecteam', 'jobber', 'zenmaid'], category: 'Cleaning operations and team management' },
  { slugs: ['fieldedge', 'knowify', 'method-crm'], category: 'QuickBooks-native contractors' },
  { slugs: ['fieldpulse', 'housecall-pro', 'workiz'], category: 'On-demand service shops' },
  { slugs: ['jobber', 'servicem8', 'tradify'], category: 'Mobile-first small trade businesses' },
  { slugs: ['buildops', 'fieldedge', 'simpro'], category: 'Custom-quoted enterprise platforms' },
  { slugs: ['fieldpulse', 'jobber', 'workiz'], category: 'Multi-trade affordable platforms' },
  { slugs: ['buildops', 'servicetrade', 'simpro'], category: 'Commercial-only trades platforms' },
  { slugs: ['servicem8', 'simpro', 'tradify'], category: 'International / non-US trades software' },
  { slugs: ['housecall-pro', 'vonigo', 'workiz'], category: 'Franchise and multi-location service' },
  { slugs: ['fieldedge', 'housecall-pro', 'servicetitan'], category: 'HVAC residential service businesses' },
];

interface ResolvedTrio {
  tools: Tool[];
  category: string;
  url: string;
  title: string;
}

const resolved: ResolvedTrio[] = TRIO_LISTINGS.map(def => {
  const sorted = [...def.slugs].sort();
  const tools = sorted.map(slug => getTool(slug)).filter((t): t is Tool => !!t);
  if (tools.length !== 3) return null;
  return {
    tools,
    category: def.category,
    url: `/multi-compare/${sorted.join('-vs-')}/`,
    title: tools.map(t => t.name).join(' vs '),
  };
}).filter((r): r is ResolvedTrio => r !== null);

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Multi-tool comparisons', url: '/multi-compare/' },
];
---

<Layout
  title="Multi-tool comparisons — 3-way trades software matchups"
  description={`Compare three trades software platforms side-by-side. ${resolved.length} curated 3-way comparisons covering HVAC, plumbing, electrical, roofing, pest control, landscaping, and more.`}
  breadcrumbs={breadcrumbs}
>
  <section class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-8">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900">Multi-tool comparisons</h1>
      <p class="mt-3 max-w-2xl text-lg text-slate-600">
        Three platforms head-to-head — for when a 2-way comparison isn't enough. {resolved.length} curated trios across {new Set(resolved.map(r => r.category)).size}+ buyer profiles.
      </p>
    </header>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {resolved.map(r => (
        <a
          href={r.url}
          class="group rounded-lg border border-slate-200 bg-white p-5 transition hover:border-slate-400 hover:shadow-sm"
        >
          <div class="font-semibold text-slate-900 group-hover:text-orange-600">
            {r.title}
          </div>
          <div class="mt-1 text-xs text-slate-500">{r.category}</div>
        </a>
      ))}
    </div>

    <section class="mt-12 rounded-lg bg-slate-50 p-6 text-sm text-slate-600">
      <p>
        Looking for a 2-way comparison instead? See <a href="/compare/" class="text-orange-600 hover:underline">all ~480 head-to-head pairings</a>, or take the <a href="/quiz/" class="text-orange-600 hover:underline">matching quiz</a> for personalized picks.
      </p>
    </section>
  </section>
</Layout>
