---
import Layout from '../../../layouts/Layout.astro';
import migrationsData from '../../../data/migrations.json';
import {
  getTool,
  aggregateRating,
  formatPrice,
  wrenchStackScore,
  type Tool,
} from '../../../lib/data';
import WrenchScore from '../../../components/WrenchScore.astro';
import ToolLogo from '../../../components/ToolLogo.astro';

export async function getStaticPaths() {
  return migrationsData.migrations.flatMap(m => {
    const fromTool = getTool(m.from);
    const toTool = getTool(m.to);
    if (!fromTool || !toTool) return [];
    return [{
      params: { path: `from-${m.from}-to-${m.to}` },
      props: { fromTool, toTool, intent: m.intent, reason: m.reason },
    }];
  });
}

interface Props {
  fromTool: Tool;
  toTool: Tool;
  intent: string;
  reason: string;
}

const { fromTool, toTool, intent, reason } = Astro.props;

const fromScore = wrenchStackScore(fromTool);
const toScore = wrenchStackScore(toTool);
const fromRating = aggregateRating(fromTool);
const toRating = aggregateRating(toTool);

const onlyInFromFeatures = fromTool.key_features.filter(f => !toTool.key_features.includes(f));
const onlyInToFeatures = toTool.key_features.filter(f => !fromTool.key_features.includes(f));
const sharedIntegrations = fromTool.integrations.filter(i => toTool.integrations.includes(i));
const lostIntegrations = fromTool.integrations.filter(i => !toTool.integrations.includes(i));

const pageTitle = `How to migrate from ${fromTool.name} to ${toTool.name} (2026)`;
const pageDescription = `Practical guide to switching from ${fromTool.name} to ${toTool.name}. Why teams migrate, what to expect, timeline, and what to watch out for.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Migration guides', url: '/migrate/' },
  { name: `${fromTool.name} to ${toTool.name}`, url: `/migrate/from-${fromTool.slug}-to-${toTool.slug}/` },
];

const faqs = [
  {
    q: `How long does it take to migrate from ${fromTool.name} to ${toTool.name}?`,
    a: `Realistic timeline: 4–12 weeks for a full cutover. Week 1–2: account setup + initial config. Week 2–4: data import (customers, recurring service agreements). Week 4–8: team training + parallel run. Week 8–12: full cutover + decommission of ${fromTool.name}. Faster is possible for small teams; enterprise migrations can run 3–6 months.`,
  },
  {
    q: `Will all my ${fromTool.name} data transfer?`,
    a: `Customer records and active job data typically transfer cleanly via CSV export from ${fromTool.name} and import into ${toTool.name}. Historical job data, custom fields, and recurring service agreements often need manual review or rebuilding. Plan to export everything from ${fromTool.name} before terminating your subscription — vendors typically lock out access immediately after cancellation.`,
  },
  {
    q: `What about integrations I rely on?`,
    a: lostIntegrations.length > 0
      ? `Heads up — ${fromTool.name} integrates with ${lostIntegrations.map(i => i.replace(/_/g, ' ')).join(', ')}, but ${toTool.name} doesn't (at least natively). You'll need to find workarounds via Zapier, custom middleware, or rebuilding the workflow internally before cutover.`
      : `${toTool.name} covers the same integrations you're already using on ${fromTool.name} — no major workflow disruptions expected.`,
  },
  {
    q: `Is ${toTool.name} more expensive than ${fromTool.name}?`,
    a: (() => {
      const fp = fromTool.pricing.starting_at_usd;
      const tp = toTool.pricing.starting_at_usd;
      if (fp === null && tp === null) return 'Both use custom-quote pricing — request quotes from both for a real comparison at your team size.';
      if (fp === null) return `${fromTool.name} uses custom pricing; ${toTool.name} starts at ${formatPrice(toTool)}. Compare the actual quote you got from ${fromTool.name} against ${toTool.name}'s public tier closest to your team size.`;
      if (tp === null) return `${toTool.name} uses custom pricing — request a quote at your team size and compare against your current ${fromTool.name} bill.`;
      if (tp > fp) return `${toTool.name} starts at ${formatPrice(toTool)} vs ${fromTool.name}'s ${formatPrice(fromTool)} — about ${Math.round(((tp - fp) / fp) * 100)}% more at the entry tier. Worth it if you're hitting feature ceilings on ${fromTool.name}.`;
      if (tp < fp) return `${toTool.name} starts at ${formatPrice(toTool)} vs ${fromTool.name}'s ${formatPrice(fromTool)} — about ${Math.round(((fp - tp) / fp) * 100)}% cheaper at entry. Read the feature differences below to make sure you're not downgrading capability.`;
      return 'Entry pricing is roughly the same. Compare based on features and integrations rather than price.';
    })(),
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <article class="mx-auto max-w-4xl px-4 py-12">

    <header class="mb-10">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-orange-600">Migration guide</p>
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        Migrating from {fromTool.name} to {toTool.name}
      </h1>
      <p class="mt-4 text-lg text-slate-600">
        For: <strong>{intent}.</strong> Realistic timeline, what to expect, what data transfers cleanly, and what to watch out for.
      </p>
    </header>

    <section class="mb-12 grid gap-4 md:grid-cols-2">
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <div class="mb-3 flex items-center gap-3">
          <ToolLogo tool={fromTool} size={40} />
          <div class="flex-1">
            <div class="text-xs font-bold uppercase tracking-wide text-slate-500">From</div>
            <h2 class="text-lg font-bold text-slate-900">
              <a href={`/tools/${fromTool.slug}/`} class="hover:text-orange-600">{fromTool.name}</a>
            </h2>
          </div>
          <WrenchScore score={fromScore} size="sm" />
        </div>
        <dl class="space-y-1 text-sm">
          <div class="flex justify-between"><dt class="text-slate-500">Price</dt><dd class="font-medium">{formatPrice(fromTool)}</dd></div>
          <div class="flex justify-between"><dt class="text-slate-500">Best for</dt><dd class="font-medium text-right">{fromTool.best_team_size ?? '—'} techs</dd></div>
          <div class="flex justify-between"><dt class="text-slate-500">Rating</dt><dd class="font-medium">{fromRating !== null ? `${fromRating.toFixed(1)} / 5` : '—'}</dd></div>
        </dl>
      </div>

      <div class="rounded-lg border border-orange-200 bg-orange-50 p-5">
        <div class="mb-3 flex items-center gap-3">
          <ToolLogo tool={toTool} size={40} />
          <div class="flex-1">
            <div class="text-xs font-bold uppercase tracking-wide text-orange-700">To</div>
            <h2 class="text-lg font-bold text-slate-900">
              <a href={`/tools/${toTool.slug}/`} class="hover:text-orange-600">{toTool.name}</a>
            </h2>
          </div>
          <WrenchScore score={toScore} size="sm" />
        </div>
        <dl class="space-y-1 text-sm">
          <div class="flex justify-between"><dt class="text-slate-500">Price</dt><dd class="font-medium">{formatPrice(toTool)}</dd></div>
          <div class="flex justify-between"><dt class="text-slate-500">Best for</dt><dd class="font-medium text-right">{toTool.best_team_size ?? '—'} techs</dd></div>
          <div class="flex justify-between"><dt class="text-slate-500">Rating</dt><dd class="font-medium">{toRating !== null ? `${toRating.toFixed(1)} / 5` : '—'}</dd></div>
        </dl>
        <a
          href={toTool.affiliate_url.startsWith('http') ? toTool.affiliate_url : toTool.vendor_url}
          rel="sponsored nofollow noopener"
          target="_blank"
          class="mt-4 block w-full rounded-md bg-orange-500 px-4 py-2 text-center text-sm font-semibold text-white hover:bg-orange-600"
        >
          Visit {toTool.name} →
        </a>
      </div>
    </section>

    <section class="mb-12 prose prose-slate max-w-none">
      <h2>Why teams make this switch</h2>
      <p>{intent}. Specifically:</p>
      <ul>
        <li><strong>What {toTool.name} adds:</strong> {toTool.best_for}</li>
        <li><strong>What {fromTool.name} was limited on:</strong> {fromTool.weaknesses}</li>
      </ul>

      <h2>What you'll GAIN moving to {toTool.name}</h2>
      {onlyInToFeatures.length > 0 ? (
        <ul>
          {onlyInToFeatures.map(f => <li><strong>{f.replace(/_/g, ' ')}</strong></li>)}
        </ul>
      ) : (
        <p>No major new features — the migration would be about something else (pricing structure, integration depth, UX preference, team size scaling).</p>
      )}

      <h2>What you might LOSE leaving {fromTool.name}</h2>
      {onlyInFromFeatures.length > 0 ? (
        <ul>
          {onlyInFromFeatures.map(f => <li>{f.replace(/_/g, ' ')}</li>)}
        </ul>
      ) : (
        <p>{toTool.name} covers everything {fromTool.name} did and more. Migration is a clean upgrade.</p>
      )}

      <h2>Migration timeline (realistic)</h2>

      <h3>Week 1–2: Account setup + initial config</h3>
      <p>Sign up for {toTool.name}, configure company settings, set up users + permissions, build pricebook (if applicable). Don't import anything yet — get the foundation right first.</p>

      <h3>Week 2–4: Data import</h3>
      <p>Export customer list + active jobs from {fromTool.name} via CSV. Import to {toTool.name}. Spot-check 20–30 customers for data integrity. Recurring service agreements often don't transfer cleanly — plan to rebuild these.</p>

      <h3>Week 4–8: Team training + parallel run</h3>
      <p>Train dispatchers and office staff first, then field techs. Run both systems in parallel for 2–4 weeks — new jobs in {toTool.name}, complete pre-cutover jobs in {fromTool.name}.</p>

      <h3>Week 8–12: Full cutover</h3>
      <p>Stop entering new data in {fromTool.name}. Export all historical data before terminating. Cancel {fromTool.name} subscription.</p>

      <h3>Month 3–6: Optimization</h3>
      <p>Build out automation workflows {toTool.name} unlocks that you couldn't do on {fromTool.name}. This is where the ROI of switching actually shows up.</p>

      <h2>Things to verify BEFORE you sign the new contract</h2>
      <ul>
        <li><strong>Data export from {fromTool.name}.</strong> Confirm you can export customers, jobs, invoices in usable CSV format. Some platforms restrict this aggressively at cancellation.</li>
        <li><strong>QuickBooks integration parity.</strong> If you're QuickBooks-heavy, the new tool's QB integration depth + sync direction matters more than any single feature.</li>
        <li><strong>Cancellation terms on {fromTool.name}.</strong> Most field service software is month-to-month — confirm there's no annual lock-in surprise.</li>
        <li><strong>Implementation cost on {toTool.name}.</strong> Enterprise platforms often charge $5–20K+ for implementation services. Ask upfront.</li>
        <li><strong>Team adoption.</strong> Get your 2–3 most software-resistant team members on a {toTool.name} demo. If they push back hard, your migration timeline doubles.</li>
      </ul>

      <h2>When NOT to migrate</h2>
      <ul>
        <li>You're in the middle of a peak season (busy summer for HVAC, winter for snow management). Migrations during peak = chaos.</li>
        <li>Your current pain is a single missing feature that the new tool also doesn't solve. Verify the feature gap closes before signing.</li>
        <li>Your team just adopted {fromTool.name} less than 12 months ago. Change fatigue is real. Make sure the move is worth the team friction.</li>
      </ul>
    </section>

    <section class="mb-12">
      <h2 class="mb-6 text-2xl font-bold text-slate-900">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <details class="rounded-lg border border-slate-200 bg-white p-4">
            <summary class="cursor-pointer font-semibold text-slate-900">{f.q}</summary>
            <p class="mt-3 text-slate-700">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Ready to evaluate {toTool.name}?</h2>
      <p class="mt-2 text-slate-300">
        Read the full review, check pricing, or compare with {fromTool.name} side-by-side.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a
          href={toTool.affiliate_url.startsWith('http') ? toTool.affiliate_url : toTool.vendor_url}
          rel="sponsored nofollow noopener"
          target="_blank"
          class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600"
        >
          Visit {toTool.name} →
        </a>
        <a href={`/tools/${toTool.slug}/`} class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">{toTool.name} review</a>
        <a href={`/compare/${[fromTool.slug, toTool.slug].sort()[0]}-vs-${[fromTool.slug, toTool.slug].sort()[1]}/`} class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">vs {fromTool.name}</a>
      </div>
    </section>
  </article>
</Layout>
