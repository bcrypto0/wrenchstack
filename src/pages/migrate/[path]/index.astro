---
import Layout from '../../../layouts/Layout.astro';
import migrationsData from '../../../data/migrations.json';
import {
  getTool,
  aggregateRating,
  formatPrice,
  wrenchStackScore,
  type Tool,
} from '../../../lib/data';
import WrenchScore from '../../../components/WrenchScore.astro';
import ToolLogo from '../../../components/ToolLogo.astro';

export async function getStaticPaths() {
  return migrationsData.migrations.flatMap(m => {
    const fromTool = getTool(m.from);
    const toTool = getTool(m.to);
    if (!fromTool || !toTool) return [];
    return [{
      params: { path: `from-${m.from}-to-${m.to}` },
      props: { fromTool, toTool, intent: m.intent, reason: m.reason },
    }];
  });
}

interface Props {
  fromTool: Tool;
  toTool: Tool;
  intent: string;
  reason: string;
}

const { fromTool, toTool, intent, reason } = Astro.props;

const fromScore = wrenchStackScore(fromTool);
const toScore = wrenchStackScore(toTool);
const fromRating = aggregateRating(fromTool);
const toRating = aggregateRating(toTool);

const onlyInFromFeatures = fromTool.key_features.filter(f => !toTool.key_features.includes(f));
const onlyInToFeatures = toTool.key_features.filter(f => !fromTool.key_features.includes(f));
const sharedIntegrations = fromTool.integrations.filter(i => toTool.integrations.includes(i));
const lostIntegrations = fromTool.integrations.filter(i => !toTool.integrations.includes(i));
const newIntegrations = toTool.integrations.filter(i => !fromTool.integrations.includes(i));

// Cost-of-switch analysis
const fromPrice = fromTool.pricing.starting_at_usd;
const toPrice = toTool.pricing.starting_at_usd;
const monthlyDelta = (fromPrice !== null && toPrice !== null) ? Math.round(toPrice - fromPrice) : null;
const annualDelta = monthlyDelta !== null ? monthlyDelta * 12 : null;

// Classify TO tool by pricing tier for implementation cost estimate
function implementationCost(t: Tool): { range: string; description: string } {
  const p = t.pricing.starting_at_usd;
  if (p === null) return { range: '$5,000-$50,000+', description: 'Enterprise platforms ($5K-$30K typical; ServiceTitan/Procore $15K-$50K)' };
  if (p >= 200) return { range: '$1,500-$5,000', description: 'Mid-tier platforms often charge for guided onboarding' };
  return { range: '$0-$1,500', description: 'Entry-tier platforms typically offer self-service; optional paid setup $500-$1,500' };
}
const implCost = implementationCost(toTool);

const pageTitle = `How to migrate from ${fromTool.name} to ${toTool.name} (2026)`;
const pageDescription = `Practical guide to switching from ${fromTool.name} to ${toTool.name}. Why teams migrate, what to expect, timeline, and what to watch out for.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Migration guides', url: '/migrate/' },
  { name: `${fromTool.name} to ${toTool.name}`, url: `/migrate/from-${fromTool.slug}-to-${toTool.slug}/` },
];

const faqs = [
  {
    q: `How long does it take to migrate from ${fromTool.name} to ${toTool.name}?`,
    a: `Realistic timeline: 4-12 weeks for a full cutover. Week 1-2: account setup + initial config. Week 2-4: data import (customers, recurring service agreements). Week 4-8: team training + parallel run. Week 8-12: full cutover + decommission of ${fromTool.name}. Faster is possible for small teams; enterprise migrations to ${toTool.name === 'ServiceTitan' || toTool.name === 'Procore' || toTool.name === 'BuildOps' ? toTool.name : 'enterprise platforms'} can run 3-6 months.`,
  },
  {
    q: `Will all my ${fromTool.name} data transfer?`,
    a: `Customer records and active job data typically transfer cleanly via CSV export from ${fromTool.name} and import into ${toTool.name}. Historical job data, custom fields, and recurring service agreements often need manual review or rebuilding. Plan to export everything from ${fromTool.name} before terminating your subscription — vendors typically lock out access immediately after cancellation.`,
  },
  {
    q: `What about integrations I rely on?`,
    a: lostIntegrations.length > 0
      ? `Heads up — ${fromTool.name} integrates with ${lostIntegrations.map(i => i.replace(/_/g, ' ')).join(', ')}, but ${toTool.name} doesn't (at least natively). You'll need to find workarounds via Zapier, custom middleware, or rebuilding the workflow internally before cutover.`
      : `${toTool.name} covers the same integrations you're already using on ${fromTool.name} — no major workflow disruptions expected.`,
  },
  {
    q: `Is ${toTool.name} more expensive than ${fromTool.name}?`,
    a: (() => {
      const fp = fromTool.pricing.starting_at_usd;
      const tp = toTool.pricing.starting_at_usd;
      if (fp === null && tp === null) return 'Both use custom-quote pricing — request quotes from both for a real comparison at your team size.';
      if (fp === null) return `${fromTool.name} uses custom pricing; ${toTool.name} starts at ${formatPrice(toTool)}. Compare the actual quote you got from ${fromTool.name} against ${toTool.name}'s public tier closest to your team size.`;
      if (tp === null) return `${toTool.name} uses custom pricing — request a quote at your team size and compare against your current ${fromTool.name} bill.`;
      if (tp > fp) return `${toTool.name} starts at ${formatPrice(toTool)} vs ${fromTool.name}'s ${formatPrice(fromTool)} — about ${Math.round(((tp - fp) / fp) * 100)}% more at the entry tier. Worth it if you're hitting feature ceilings on ${fromTool.name}.`;
      if (tp < fp) return `${toTool.name} starts at ${formatPrice(toTool)} vs ${fromTool.name}'s ${formatPrice(fromTool)} — about ${Math.round(((fp - tp) / fp) * 100)}% cheaper at entry. Read the feature differences below to make sure you're not downgrading capability.`;
      return 'Entry pricing is roughly the same. Compare based on features and integrations rather than price.';
    })(),
  },
  {
    q: `What's the total cost of switching from ${fromTool.name} to ${toTool.name}?`,
    a: `Three components: (1) software-cost change — ${monthlyDelta !== null ? `${monthlyDelta > 0 ? `~$${monthlyDelta}/month more` : `~$${Math.abs(monthlyDelta)}/month less`} at the entry tier` : 'depends on quoted pricing for both'}. (2) Implementation fees — ${implCost.range} for ${toTool.name} (${implCost.description}). (3) Team time during transition — typically 40-100 hours of office-staff time across the 4-12 week migration, plus 2-4 hours per field technician for training. For most shops, the total switching cost is recovered within 6-18 months if the new platform delivers on its value proposition.`,
  },
  {
    q: `Can I run ${fromTool.name} and ${toTool.name} in parallel during migration?`,
    a: `Yes, and you should. Plan for 2-4 weeks of parallel operation: new jobs entered in ${toTool.name}, in-flight jobs completed in ${fromTool.name}. Both subscriptions active during this window. The parallel period catches data-integrity issues before you've cancelled ${fromTool.name} and lost access. Don't try to cut over in a single day — that's how shops lose customer data and miss appointments during the chaos.`,
  },
  {
    q: `What if my team resists the move from ${fromTool.name}?`,
    a: `Team adoption resistance is the #1 cause of failed migrations. Mitigate by: (1) getting your 2-3 most software-resistant techs and office staff into a ${toTool.name} demo BEFORE signing the contract — if they push back hard, your timeline doubles or the migration fails outright; (2) frame ${toTool.name} as solving specific pain points they complain about (not as "we're switching"); (3) train champions first (tech-comfortable team members) who then peer-train the rest. Skipping team buy-in causes 6-month migration projects to stretch into 18-month disasters.`,
  },
  {
    q: `Should I migrate during peak season or off-season?`,
    a: `Off-season, almost always. HVAC: avoid summer (peak cooling) and winter (peak heating) — best window is March-May or September-October. Plumbing: same pattern. Pest control: avoid spring-summer peak. Landscaping: avoid spring setup and fall cleanup. The reasoning is simple: migration consumes office-staff capacity that you need for customer-facing work during peak demand. Migrate during a quiet period when missed dispatch decisions don't compound into lost revenue.`,
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs} affiliate>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <article class="mx-auto max-w-4xl px-4 py-12">

    <header class="mb-10">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-orange-600">Migration guide</p>
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        Migrating from {fromTool.name} to {toTool.name}
      </h1>
      <p class="mt-4 text-lg text-slate-600">
        For: <strong>{intent}.</strong> Realistic timeline, what to expect, what data transfers cleanly, and what to watch out for.
      </p>

      <div class="mt-6 rounded-lg border border-orange-200 bg-orange-50 p-4">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <div class="font-semibold text-slate-900">Calculate the real 12-month cost</div>
            <div class="text-sm text-slate-700">Subscription delta + implementation + training + parallel run, for your team size.</div>
          </div>
          <a
            href={`/cost-of-switch/?from=${fromTool.slug}&to=${toTool.slug}`}
            class="shrink-0 rounded-md bg-orange-500 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600"
          >
            Calculate switch cost →
          </a>
        </div>
      </div>
    </header>

    <section class="mb-12 grid gap-4 md:grid-cols-2">
      <div class="rounded-lg border border-slate-200 bg-white p-5">
        <div class="mb-3 flex items-center gap-3">
          <ToolLogo tool={fromTool} size={40} />
          <div class="flex-1">
            <div class="text-xs font-bold uppercase tracking-wide text-slate-500">From</div>
            <h2 class="text-lg font-bold text-slate-900">
              <a href={`/tools/${fromTool.slug}/`} class="hover:text-orange-600">{fromTool.name}</a>
            </h2>
          </div>
          <WrenchScore score={fromScore} size="sm" />
        </div>
        <dl class="space-y-1 text-sm">
          <div class="flex justify-between"><dt class="text-slate-500">Price</dt><dd class="font-medium">{formatPrice(fromTool)}</dd></div>
          <div class="flex justify-between"><dt class="text-slate-500">Best for</dt><dd class="font-medium text-right">{fromTool.best_team_size ?? '—'} techs</dd></div>
          <div class="flex justify-between"><dt class="text-slate-500">Rating</dt><dd class="font-medium">{fromRating !== null ? `${fromRating.toFixed(1)} / 5` : '—'}</dd></div>
        </dl>
      </div>

      <div class="rounded-lg border border-orange-200 bg-orange-50 p-5">
        <div class="mb-3 flex items-center gap-3">
          <ToolLogo tool={toTool} size={40} />
          <div class="flex-1">
            <div class="text-xs font-bold uppercase tracking-wide text-orange-700">To</div>
            <h2 class="text-lg font-bold text-slate-900">
              <a href={`/tools/${toTool.slug}/`} class="hover:text-orange-600">{toTool.name}</a>
            </h2>
          </div>
          <WrenchScore score={toScore} size="sm" />
        </div>
        <dl class="space-y-1 text-sm">
          <div class="flex justify-between"><dt class="text-slate-500">Price</dt><dd class="font-medium">{formatPrice(toTool)}</dd></div>
          <div class="flex justify-between"><dt class="text-slate-500">Best for</dt><dd class="font-medium text-right">{toTool.best_team_size ?? '—'} techs</dd></div>
          <div class="flex justify-between"><dt class="text-slate-500">Rating</dt><dd class="font-medium">{toRating !== null ? `${toRating.toFixed(1)} / 5` : '—'}</dd></div>
        </dl>
        <a
          href={toTool.affiliate_url.startsWith('http') ? toTool.affiliate_url : toTool.vendor_url}
          rel="sponsored nofollow noopener"
          target="_blank"
          class="mt-4 block w-full rounded-md bg-orange-500 px-4 py-2 text-center text-sm font-semibold text-white hover:bg-orange-600"
        >
          Visit {toTool.name} →
        </a>
      </div>
    </section>

    <section class="mb-12 prose prose-slate max-w-none">
      <h2>Why teams make this switch</h2>
      <p>{intent}. Specifically:</p>
      <ul>
        <li><strong>What {toTool.name} adds:</strong> {toTool.best_for}</li>
        <li><strong>What {fromTool.name} was limited on:</strong> {fromTool.weaknesses}</li>
      </ul>

      <h2>What you'll GAIN moving to {toTool.name}</h2>
      {onlyInToFeatures.length > 0 ? (
        <ul>
          {onlyInToFeatures.map(f => <li><strong>{f.replace(/_/g, ' ')}</strong></li>)}
        </ul>
      ) : (
        <p>No major new features — the migration would be about something else (pricing structure, integration depth, UX preference, team size scaling).</p>
      )}

      <h2>What you might LOSE leaving {fromTool.name}</h2>
      {onlyInFromFeatures.length > 0 ? (
        <ul>
          {onlyInFromFeatures.map(f => <li>{f.replace(/_/g, ' ')}</li>)}
        </ul>
      ) : (
        <p>{toTool.name} covers everything {fromTool.name} did and more. Migration is a clean upgrade.</p>
      )}

      <h2>Cost-of-switch analysis</h2>
      <p>Three cost components when migrating from {fromTool.name} to {toTool.name}:</p>
      <ul>
        <li>
          <strong>Software-cost change:</strong>{' '}
          {monthlyDelta === null
            ? `${fromPrice === null ? fromTool.name : toTool.name} uses custom-quoted pricing — request actual quotes for both to compare at your team size.`
            : monthlyDelta > 0
              ? `~$${monthlyDelta}/month more on ${toTool.name} (${formatPrice(toTool)} vs ${formatPrice(fromTool)}). Annual delta: ~$${annualDelta} extra.`
              : monthlyDelta < 0
                ? `~$${Math.abs(monthlyDelta)}/month less on ${toTool.name} (${formatPrice(toTool)} vs ${formatPrice(fromTool)}). Annual savings: ~$${Math.abs(annualDelta ?? 0)}.`
                : `Entry pricing is identical. Compare based on features and integrations, not price.`}
        </li>
        <li><strong>Implementation fees:</strong> {implCost.range} for {toTool.name}. {implCost.description}.</li>
        <li><strong>Team time during transition:</strong> 40-100 hours of office-staff time across the 4-12 week migration, plus 2-4 hours per field technician for training. For a 10-tech shop with 2 office staff, total internal labor cost typically runs $5,000-$15,000 at loaded hourly rates.</li>
      </ul>
      <p>For most shops, the total switching cost is recovered within 6-18 months if the new platform delivers on its value proposition. Below 6 months, the math usually doesn't work — make sure your reason for switching justifies the friction.</p>

      <h2>Migration timeline (realistic)</h2>

      <h3>Week 1–2: Account setup + initial config</h3>
      <p>Sign up for {toTool.name}, configure company settings, set up users + permissions, build pricebook (if applicable). Don't import anything yet — get the foundation right first.</p>

      <h3>Week 2–4: Data import</h3>
      <p>Export customer list + active jobs from {fromTool.name} via CSV. Import to {toTool.name}. Spot-check 20–30 customers for data integrity. Recurring service agreements often don't transfer cleanly — plan to rebuild these.</p>

      <h3>Week 4–8: Team training + parallel run</h3>
      <p>Train dispatchers and office staff first, then field techs. Run both systems in parallel for 2–4 weeks — new jobs in {toTool.name}, complete pre-cutover jobs in {fromTool.name}.</p>

      <h3>Week 8–12: Full cutover</h3>
      <p>Stop entering new data in {fromTool.name}. Export all historical data before terminating. Cancel {fromTool.name} subscription.</p>

      <h3>Month 3–6: Optimization</h3>
      <p>Build out automation workflows {toTool.name} unlocks that you couldn't do on {fromTool.name}. This is where the ROI of switching actually shows up.</p>

      <h2>Data export checklist (before cancelling {fromTool.name})</h2>
      <p>Export everything from {fromTool.name} BEFORE you cancel — vendors typically lock out access immediately after subscription termination. Your checklist:</p>
      <ul>
        <li><strong>Customer records</strong> — full export with names, addresses, contact info, custom fields, service notes</li>
        <li><strong>Active job data</strong> — open work orders, scheduled appointments, recurring service agreements</li>
        <li><strong>Historical invoices</strong> — at minimum the last 12 months for accounting reference; ideally everything for tax/audit purposes</li>
        <li><strong>Payment records</strong> — past payments, outstanding balances, payment method history (with tokenization concerns)</li>
        <li><strong>Photo and document attachments</strong> — job site photos, signed agreements, equipment photos — often the hardest to migrate cleanly</li>
        <li><strong>Pricebook / service catalog</strong> — your service offerings with pricing structure (often rebuilt in new platform regardless)</li>
        <li><strong>Membership/maintenance plan data</strong> — recurring billing setups, plan tiers, member status</li>
        <li><strong>Integration configurations</strong> — screenshot/document existing QuickBooks sync, Stripe setup, Zapier workflows for re-creation</li>
        <li><strong>User accounts and permissions</strong> — list of staff with their role assignments (rebuilt in new platform)</li>
        <li><strong>Reports and saved views</strong> — note custom dashboards or reports you'll need to rebuild</li>
      </ul>

      <h2>Integration migration checklist</h2>
      {sharedIntegrations.length > 0 && (
        <>
          <p><strong>Continues to work without disruption:</strong></p>
          <ul>
            {sharedIntegrations.map(i => <li>{i.replace(/_/g, ' ')} — both {fromTool.name} and {toTool.name} support this natively</li>)}
          </ul>
        </>
      )}
      {lostIntegrations.length > 0 && (
        <>
          <p><strong>Need rebuilding or workarounds:</strong></p>
          <ul>
            {lostIntegrations.map(i => <li><strong>{i.replace(/_/g, ' ')}</strong> — {fromTool.name} has this natively, but {toTool.name} doesn't. Bridge via Zapier, custom middleware, or accept the workflow loss.</li>)}
          </ul>
        </>
      )}
      {newIntegrations.length > 0 && (
        <>
          <p><strong>New integration options on {toTool.name}</strong> (worth evaluating during migration):</p>
          <ul>
            {newIntegrations.slice(0, 6).map(i => <li>{i.replace(/_/g, ' ')}</li>)}
          </ul>
        </>
      )}

      <h2>Common migration pitfalls (and how to avoid them)</h2>
      <ul>
        <li><strong>Cancelling {fromTool.name} too early.</strong> Don't terminate until you've verified data exported cleanly and the new platform is operational. Keep both subscriptions active during the 2-4 week parallel run, even though it's painful to pay double.</li>
        <li><strong>Skipping the pricebook rebuild.</strong> Pricebook data rarely migrates cleanly between platforms (different schemas, line-item structures). Rebuild fresh in {toTool.name} during the parallel period — don't try to import.</li>
        <li><strong>Ignoring custom workflows.</strong> If your office staff built custom workflows or automations on {fromTool.name} (specific dispatch rules, custom email templates, automated billing sequences), those won't transfer. List every custom workflow you depend on and rebuild equivalents in {toTool.name} before cutover.</li>
        <li><strong>Underestimating team adoption resistance.</strong> Get tech-resistant team members on a {toTool.name} demo BEFORE signing the contract. If they hate it, your timeline doubles or the migration fails. Train champions first, peer-train resistant team members second.</li>
        <li><strong>Migrating during peak season.</strong> Don't switch HVAC software in July or roofing software during storm season. Migration friction during peak demand cascades into missed customers and lost revenue.</li>
        <li><strong>Not budgeting for parallel-run cost.</strong> 2-4 weeks of running both subscriptions adds ${monthlyDelta !== null && fromPrice !== null && toPrice !== null ? `~$${Math.round((fromPrice + toPrice) / 2)}` : '$200-$1,000'} in subscription overlap. Plan for it; don't surprise yourself.</li>
      </ul>

      <h2>Things to verify BEFORE you sign the new contract</h2>
      <ul>
        <li><strong>Data export from {fromTool.name}.</strong> Confirm you can export customers, jobs, invoices in usable CSV format. Some platforms restrict this aggressively at cancellation.</li>
        <li><strong>QuickBooks integration parity.</strong> If you're QuickBooks-heavy, the new tool's QB integration depth + sync direction matters more than any single feature.</li>
        <li><strong>Cancellation terms on {fromTool.name}.</strong> Most field service software is month-to-month — confirm there's no annual lock-in surprise.</li>
        <li><strong>Implementation cost on {toTool.name}.</strong> Enterprise platforms often charge $5–20K+ for implementation services. Ask upfront.</li>
        <li><strong>Team adoption.</strong> Get your 2–3 most software-resistant team members on a {toTool.name} demo. If they push back hard, your migration timeline doubles.</li>
      </ul>

      <h2>When NOT to migrate</h2>
      <ul>
        <li>You're in the middle of a peak season (busy summer for HVAC, winter for snow management). Migrations during peak = chaos.</li>
        <li>Your current pain is a single missing feature that the new tool also doesn't solve. Verify the feature gap closes before signing.</li>
        <li>Your team just adopted {fromTool.name} less than 12 months ago. Change fatigue is real. Make sure the move is worth the team friction.</li>
      </ul>
    </section>

    <section class="mb-12">
      <h2 class="mb-6 text-2xl font-bold text-slate-900">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <details class="rounded-lg border border-slate-200 bg-white p-4">
            <summary class="cursor-pointer font-semibold text-slate-900">{f.q}</summary>
            <p class="mt-3 text-slate-700">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Ready to evaluate {toTool.name}?</h2>
      <p class="mt-2 text-slate-300">
        Read the full review, check pricing, or compare with {fromTool.name} side-by-side.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a
          href={toTool.affiliate_url.startsWith('http') ? toTool.affiliate_url : toTool.vendor_url}
          rel="sponsored nofollow noopener"
          target="_blank"
          class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600"
        >
          Visit {toTool.name} →
        </a>
        <a href={`/tools/${toTool.slug}/`} class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">{toTool.name} review</a>
        <a href={`/compare/${[fromTool.slug, toTool.slug].sort()[0]}-vs-${[fromTool.slug, toTool.slug].sort()[1]}/`} class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">vs {fromTool.name}</a>
      </div>
    </section>
  </article>
</Layout>
