---
import Layout from '../../layouts/Layout.astro';
import migrationsData from '../../data/migrations.json';
import { getTool, type Tool } from '../../lib/data';

const MIGRATIONS = migrationsData.migrations;

interface Resolved {
  fromTool: Tool;
  toTool: Tool;
  url: string;
  intent: string;
}

const resolved: Resolved[] = MIGRATIONS.map(m => {
  const fromTool = getTool(m.from);
  const toTool = getTool(m.to);
  if (!fromTool || !toTool) return null;
  return {
    fromTool,
    toTool,
    url: `/migrate/from-${m.from}-to-${m.to}/`,
    intent: m.intent,
  };
}).filter((r): r is Resolved => r !== null);

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Migration guides', url: '/migrate/' },
];
---

<Layout
  title="Trades software migration guides — switching tools"
  description={`Practical guides for switching from one trades software to another. ${resolved.length} migration paths covered with timelines, data export tips, and what to watch out for.`}
  breadcrumbs={breadcrumbs}
>
  <section class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-8">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900">Migration guides</h1>
      <p class="mt-3 max-w-2xl text-lg text-slate-600">
        Switching field service software is a 4–12 week project with real risk if you skip steps. {resolved.length} migration paths covered — what transfers cleanly, what doesn't, and the realistic timeline.
      </p>
    </header>

    <div class="grid gap-4 sm:grid-cols-2">
      {resolved.map(r => (
        <a
          href={r.url}
          class="group rounded-lg border border-slate-200 bg-white p-5 transition hover:border-slate-400 hover:shadow-sm"
        >
          <div class="text-lg font-semibold text-slate-900 group-hover:text-orange-600">
            {r.fromTool.name} → {r.toTool.name}
          </div>
          <div class="mt-1 text-sm text-slate-500">{r.intent}</div>
        </a>
      ))}
    </div>

    <section class="mt-12 rounded-lg bg-slate-50 p-6 text-sm text-slate-600">
      <p>
        Don't see your migration path? Email <a href="mailto:hello@wrenchstack.com" class="text-orange-600 hover:underline">hello@wrenchstack.com</a> with your current tool and target — we add new guides based on reader requests.
      </p>
    </section>
  </section>
</Layout>
