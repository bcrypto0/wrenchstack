---
import Layout from '../../layouts/Layout.astro';
import { financingProviders, financingByModel, FINANCING_MODEL_META } from '../../lib/data';

const grouped = financingByModel();

const pageTitle = `Best Contractor Financing for Big-Ticket Jobs (2026)`;
const pageDescription = `Independent comparison of consumer financing for contractors — Wisetack, GreenSky, Hearth, Acorn Finance — by model (embedded point-of-sale vs lender marketplace). Real fees, APRs, and how to close more big-ticket HVAC, roofing, and remodel jobs.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Financing', url: '/financing/' },
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Consumer Financing Providers for Contractors',
  numberOfItems: financingProviders.length,
  itemListElement: financingProviders.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'FinancialProduct',
      name: p.name,
      description: p.tagline,
      url: `https://wrenchstack.com/financing/${p.slug}/`,
    },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <article class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-10">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-amber-600">Financing</p>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">
        Best Contractor Financing for Big-Ticket Jobs (2026)
      </h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        On a $9,000 repair, "that's about $180/month" closes jobs that a lump sum loses. We compare the consumer-financing options contractors actually use to offer monthly payments — organized by how they work, what they cost you, and the honest trade-offs (including the deferred-interest fine print).
      </p>
    </header>

    <section class="mb-10 rounded-lg bg-slate-50 p-6">
      <h2 class="mb-3 text-base font-bold text-slate-900">The headline filter: financing model</h2>
      <p class="text-sm text-slate-700 leading-relaxed">
        <strong>Embedded point-of-sale</strong> financing (Wisetack, GreenSky) lets you offer payments inside your own checkout — you pay a merchant or dealer fee, the customer applies in seconds. <strong>Lender marketplaces</strong> (Hearth, Acorn Finance) send customers a link to compare prequalified offers from many lenders, and you typically get paid upfront. The right pick depends on job size, how much fee you'll absorb, and whether you want financing embedded in your FSM or a free comparison link. For any model, be straight with customers about deferred-interest terms — not just the headline "0%."
      </p>
    </section>

    {grouped.map(({ model, providers }) => {
      const meta = FINANCING_MODEL_META[model];
      return (
        <section class="mb-12">
          <div class="mb-5">
            <span class="inline-block rounded-full bg-amber-100 px-3 py-1 text-xs font-bold uppercase tracking-wider text-amber-900 ring-1 ring-amber-300">{meta.label}</span>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">{meta.blurb}</p>
          </div>

          <div class="space-y-4">
            {providers.map((p) => (
              <article class="rounded-lg border-2 border-amber-200 bg-white p-5">
                <div class="mb-3 flex items-start justify-between gap-3">
                  <div class="min-w-0 flex-1">
                    <h3 class="text-xl font-bold text-slate-900">
                      <a href={`/financing/${p.slug}/`} class="hover:text-amber-600">{p.name}</a>
                    </h3>
                    <p class="text-sm italic text-slate-500">{p.tagline}</p>
                  </div>
                </div>

                {p.reputation_flag && (
                  <div class="mb-3 rounded-md border-l-4 border-rose-500 bg-rose-50 px-4 py-3 text-sm text-rose-900">
                    <p class="font-bold uppercase tracking-wider text-xs text-rose-700 mb-1">⚠ Reputation / consumer-cost warning</p>
                    <p class="leading-relaxed">{p.reputation_flag.split('.')[0]}.</p>
                  </div>
                )}

                <div class="mb-3 grid gap-2 sm:grid-cols-2">
                  <p class="rounded-md bg-slate-50 px-4 py-2 text-sm text-slate-700 leading-snug">
                    <strong class="text-slate-900">Cost to you:</strong> {p.contractor_cost}
                  </p>
                  <p class="rounded-md bg-slate-50 px-4 py-2 text-sm text-slate-700 leading-snug">
                    <strong class="text-slate-900">Loan size:</strong> {p.loan_range}
                  </p>
                </div>

                <dl class="mb-3 grid grid-cols-2 gap-2 text-xs sm:grid-cols-3">
                  <div>
                    <dt class="text-slate-500 uppercase tracking-wider">Model</dt>
                    <dd class="font-semibold text-slate-900 capitalize">{p.financing_model.replace(/-/g, ' ')}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500 uppercase tracking-wider">Founded</dt>
                    <dd class="font-semibold text-slate-900">{p.founded ?? '—'}</dd>
                  </div>
                  <div>
                    <dt class="text-slate-500 uppercase tracking-wider">Customer APR</dt>
                    <dd class="font-semibold text-slate-900">{p.apr_range.split(';')[0].split('(')[0].trim()}</dd>
                  </div>
                </dl>

                <p class="mb-3 text-sm text-slate-700 leading-relaxed">
                  <strong class="text-slate-900">Best for:</strong> {p.best_for}
                </p>

                <div class="flex flex-wrap gap-2">
                  <a href={`/financing/${p.slug}/`} class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800">Read full review →</a>
                  <a href={p.affiliate_url.startsWith('http') ? p.affiliate_url : p.vendor_url} rel="sponsored nofollow noopener" target="_blank" class="rounded-md border border-amber-300 bg-white px-4 py-2 text-sm font-semibold text-amber-700 hover:bg-amber-50">Visit {p.name}</a>
                </div>
              </article>
            ))}
          </div>
        </section>
      );
    })}

    <section class="mt-12 rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Where to start</h2>
      <p class="mt-2 text-slate-300 leading-relaxed">
        Service-ticket shop that wants financing wired into your FSM? <strong>Wisetack</strong> (flat 3.9%, embedded in Housecall Pro/Jobber/FieldPulse). Want a free option with no cost to you? <strong>Acorn Finance</strong> (free marketplace, paid upfront). Financing large $50K–$100K projects? <strong>GreenSky</strong> has the capacity — just price in the dealer fee and disclose deferred-interest terms. Want bundled sales tools and will use them? <strong>Hearth</strong>'s subscription can fit.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/financing/wisetack/" class="rounded-md bg-amber-500 px-5 py-3 text-sm font-semibold text-white hover:bg-amber-600">See Wisetack →</a>
        <a href="/payments/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">Payments</a>
        <a href="/tools/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">Software directory</a>
      </div>
    </section>
  </article>
</Layout>
