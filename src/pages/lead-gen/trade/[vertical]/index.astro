---
import Layout from '../../../../layouts/Layout.astro';
import {
  leadGenPlatforms,
  leadGenTier,
  verticals,
  verticalToUrl,
  getVertical,
  type LeadGenPlatform,
} from '../../../../lib/data';

// Trades we cover with dedicated lead-gen buyer guides
const TARGET_VERTICALS = [
  'hvac',
  'plumbing',
  'electrical',
  'roofing',
  'general_contractor',
  'landscaping',
  'cleaning',
  'pest_control',
];

export async function getStaticPaths() {
  const TARGET_VERTICALS = [
    'hvac', 'plumbing', 'electrical', 'roofing',
    'general_contractor', 'landscaping', 'cleaning', 'pest_control',
  ];
  return TARGET_VERTICALS.map((slug) => {
    const v = getVertical(slug);
    if (!v) return null;
    return {
      params: { vertical: verticalToUrl(slug) },
      props: { verticalSlug: slug },
    };
  }).filter((p): p is NonNullable<typeof p> => !!p);
}

interface Props {
  verticalSlug: string;
}

const { verticalSlug } = Astro.props;
const vertical = getVertical(verticalSlug)!;

// Platforms that serve this vertical, grouped by tier
const platformsForVertical = leadGenPlatforms.filter((p) =>
  p.verticals.includes(verticalSlug)
);

const byTier: Record<'S' | 'A' | 'F', LeadGenPlatform[]> = { S: [], A: [], F: [] };
for (const p of platformsForVertical) {
  byTier[leadGenTier(p)].push(p);
}

const pageTitle = `Best Lead-Gen Platforms for ${vertical.name} Contractors (2026)`;
const pageDescription = `Independent reviews of lead-gen platforms for ${vertical.name.toLowerCase()} contractors — Google LSA, Service Direct, Thumbtack, and others ranked honestly with reputation flags and affiliate disclosure.`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Lead-gen platforms', url: '/lead-gen/' },
  { name: vertical.name, url: `/lead-gen/trade/${verticalToUrl(verticalSlug)}/` },
];

const tierMeta = {
  S: { label: 'Recommended', color: 'bg-emerald-100 text-emerald-900 ring-emerald-300', cardBorder: 'border-emerald-300' },
  A: { label: 'Workable with discipline', color: 'bg-blue-100 text-blue-900 ring-blue-300', cardBorder: 'border-blue-300' },
  F: { label: 'Not recommended', color: 'bg-rose-100 text-rose-900 ring-rose-300', cardBorder: 'border-rose-300' },
};

// Trade-specific intro framing
function tradeIntro(slug: string): string {
  switch (slug) {
    case 'hvac':
      return 'HVAC is one of the highest-competition trades for lead-gen — and one where the choice of platform makes a meaningful difference in cost-per-acquired-customer. Emergency-service intent (no AC in July, no heat in January) makes exclusive-lead platforms (Google LSA, Service Direct) structurally favored over shared-lead bid wars.';
    case 'plumbing':
      return 'Plumbing leads bifurcate sharply between emergency-service (urgent, high-intent, willing to pay) and remodel-project (shopping, comparing, slow). Different lead sources fit each. Exclusive-lead platforms work for emergency; marketplace platforms can work for remodel-side.';
    case 'electrical':
      return 'Electrical contractors face high regulatory scrutiny and licensing barriers — which is actually an advantage on platforms like Google LSA that verify licensing. The verification gauntlet that disqualifies low-quality competitors becomes your moat.';
    case 'roofing':
      return 'Roofing has its own dedicated lead-gen ecosystem — 33 Mile Radius for restoration and insurance-claim work, AccuLynx and Roofr for direct contractor relationships, plus the same generalist platforms (LSA, Service Direct) that work for other trades. Storm-event seasonality matters more here than in any other trade.';
    case 'general_contractor':
      return 'General contractors and remodelers span an unusually wide range — from $5K bathroom refresh to $500K custom-home builds. The right lead-gen platform depends heavily on your project-size sweet spot. Higher-end design-build benefits from Houzz Pro; quick remodels benefit from LSA and Thumbtack.';
    case 'landscaping':
      return 'Landscaping leads split between recurring-maintenance (high lifetime value, slow conversion) and one-off install projects (faster decision, finite revenue). Exclusive-lead platforms favor the install work; marketplace platforms can work for maintenance contracts where review quality matters more than urgency.';
    case 'cleaning':
      return 'Residential cleaning is one of the most price-sensitive trades in lead-gen — customers shop hard on per-visit rates. Shared-lead platforms suffer here because the bid-comparison dynamics push prices down. Exclusive-lead platforms (LSA) and recurring-customer-focused strategies work better.';
    case 'pest_control':
      return 'Pest control benefits from recurring-service contracts — once you convert a lead to a quarterly-treatment customer, lifetime value is significant. Exclusive-lead platforms justify higher per-lead spend because the customer relationship lasts. Shared-lead platforms struggle with the price-comparison dynamics.';
    default:
      return `Lead-gen for ${vertical.name.toLowerCase()} contractors with platform-by-platform recommendations and reputation context.`;
  }
}

const faqs = [
  {
    q: `Which lead-gen platform is best for ${vertical.name.toLowerCase()} contractors?`,
    a: byTier.S.length > 0
      ? `Based on contractor experience, lead model, and reputation, ${byTier.S[0].name} is the top-tier recommendation for ${vertical.name.toLowerCase()} work. ${byTier.S[0].best_for}.${byTier.S.length > 1 ? ` ${byTier.S[1].name} is the next-best option.` : ''} For most shops, a combination of 2-3 channels works better than relying on one.`
      : `For ${vertical.name.toLowerCase()} contractors, we generally recommend a combination of Google LSA (when available in your area), Service Direct, and Google Business Profile / organic SEO. Avoid the FTC-action platforms (HomeAdvisor, Angi) and Bark.`,
  },
  {
    q: `What does a typical lead cost for ${vertical.name.toLowerCase()} work?`,
    a: `Cost-per-lead varies dramatically by platform, geography, and seasonality. Exclusive-lead platforms (Google LSA, Service Direct) tend to cost $25-$150 per lead but convert at 30-50%. Shared-lead platforms tend to cost $10-$80 per lead but convert at 8-15%. The right comparison is cost-per-acquired-customer, not per-lead — and exclusive-lead platforms usually win that math.`,
  },
  {
    q: `Should I use HomeAdvisor or Angi for ${vertical.name.toLowerCase()} leads?`,
    a: `We do not recommend HomeAdvisor or Angi for any contractor profile. Both have documented FTC actions, class-action history, and overwhelmingly negative contractor sentiment. Google LSA, Service Direct, and 33 Mile Radius offer structurally better experiences with comparable or better lead quality. See our full reviews for the documented track record.`,
  },
  {
    q: `How long until lead-gen platforms pay back?`,
    a: `Most exclusive-lead platforms (Google LSA, Service Direct) start delivering positive ROI within the first month for ${vertical.name.toLowerCase()} shops with clean operations and responsive dispatch. Shared-lead platforms take 60-90 days to evaluate fairly — short-term data is too noisy. Always layer call-tracking (CallRail) so you can attribute results to specific channels.`,
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <article class="mx-auto max-w-5xl px-4 py-12">
    <header class="mb-10">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-orange-600">
        Lead-gen · {vertical.name}
      </p>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl">
        Best Lead-Gen Platforms for {vertical.name} Contractors (2026)
      </h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        {tradeIntro(verticalSlug)}
      </p>
    </header>

    {(['S', 'A', 'F'] as const).map((tier) => {
      const platforms = byTier[tier];
      if (platforms.length === 0) return null;
      const meta = tierMeta[tier];
      return (
        <section class="mb-12">
          <div class="mb-5 flex items-baseline gap-3">
            <h2 class="text-2xl font-bold text-slate-900">{meta.label}</h2>
            <span class={`inline-block rounded-full px-2 py-0.5 text-xs font-bold ring-1 ${meta.color}`}>{platforms.length}</span>
          </div>

          <div class="space-y-4">
            {platforms.map((p) => (
              <article class={`rounded-lg border-2 ${meta.cardBorder} bg-white p-5`}>
                <div class="mb-3 flex items-start justify-between gap-3">
                  <div class="min-w-0 flex-1">
                    <h3 class="text-xl font-bold text-slate-900">
                      <a href={`/lead-gen/${p.slug}/`} class="hover:text-orange-600">{p.name}</a>
                    </h3>
                    <p class="text-sm italic text-slate-500">{p.tagline}</p>
                  </div>
                  <div class="shrink-0 text-right text-xs">
                    <p class="font-bold text-slate-900 uppercase tracking-wider">{p.lead_model.replace(/-/g, ' ')}</p>
                    <p class="text-slate-500">{p.typical_cost}</p>
                  </div>
                </div>

                {p.reputation_flag && (
                  <div class="mb-3 rounded-md border-l-4 border-rose-500 bg-rose-50 px-4 py-3 text-sm text-rose-900">
                    <p class="font-bold uppercase tracking-wider text-xs text-rose-700 mb-1">⚠ Reputation warning</p>
                    <p class="leading-relaxed">{p.reputation_flag.split('.')[0]}.</p>
                  </div>
                )}

                <p class="mb-3 text-sm text-slate-700 leading-relaxed">
                  <strong class="text-slate-900">Best for {vertical.name.toLowerCase()}:</strong> {p.best_for}
                </p>

                <div class="flex flex-wrap gap-2">
                  <a
                    href={`/lead-gen/${p.slug}/`}
                    class="rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800"
                  >
                    Read full review →
                  </a>
                  <a
                    href={p.affiliate_url.startsWith('http') ? p.affiliate_url : p.vendor_url}
                    rel="sponsored nofollow noopener"
                    target="_blank"
                    class="rounded-md border border-orange-300 bg-white px-4 py-2 text-sm font-semibold text-orange-700 hover:bg-orange-50"
                  >
                    Visit {p.name}
                  </a>
                </div>
              </article>
            ))}
          </div>
        </section>
      );
    })}

    <section class="mb-10">
      <h2 class="mb-5 text-2xl font-bold text-slate-900">Frequently asked for {vertical.name.toLowerCase()} contractors</h2>
      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="rounded-lg border border-slate-200 bg-white p-4">
            <summary class="cursor-pointer font-semibold text-slate-900">{f.q}</summary>
            <p class="mt-3 text-slate-700 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="rounded-lg bg-slate-900 p-8 text-white">
      <h2 class="text-2xl font-bold">More for {vertical.name.toLowerCase()} contractors</h2>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href={`/${verticalToUrl(verticalSlug)}/`} class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">
          {vertical.name} software directory →
        </a>
        <a href="/lead-gen/" class="rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100">
          All lead-gen platforms
        </a>
        <a href="/quiz/" class="rounded-md border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white hover:bg-white/20">
          Matching quiz
        </a>
      </div>
    </section>
  </article>
</Layout>
