---
import Layout from '../layouts/Layout.astro';
import categories from '../data/categories.json';
import tools from '../data/tools.json';

const verticals = categories.verticals;
const toolCount = tools.tools.length;
---

<Layout
  title="WrenchStack — Trades software comparisons that actually help"
  description="Compare HVAC, plumbing, electrical, roofing, and field service software. Real pricing, real feature matrices, side-by-side."
>
  <section class="bg-gradient-to-b from-white to-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-20 md:py-28">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-6xl">
        The trades software stack,<br />
        picked by data.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-slate-600 md:text-xl">
        Compare {toolCount}+ field service platforms across {verticals.length} trades.
        Real pricing, full feature matrices, head-to-head comparisons.
      </p>

      <div class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm font-medium text-slate-600">
        <span><span class="font-bold text-slate-900">{toolCount}+</span> tools tracked</span>
        <span class="text-slate-300">·</span>
        <span><span class="font-bold text-slate-900">{verticals.length}</span> trades verticals</span>
        <span class="text-slate-300">·</span>
        <span><span class="font-bold text-slate-900">600+</span> comparison pages</span>
        <span class="text-slate-300">·</span>
        <span>Updated weekly</span>
      </div>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/hvac/"
          class="rounded-md bg-slate-900 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800"
        >
          Browse HVAC software →
        </a>
        <a
          href="/tools/"
          class="rounded-md border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:border-slate-400"
        >
          See all tools
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <h2 class="mb-2 text-2xl font-bold tracking-tight text-slate-900">Pick your trade</h2>
    <p class="mb-8 text-slate-600">
      Each vertical has its own ranked picks, pricing comparisons, and feature matrices.
    </p>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {verticals.map((v) => (
        <a
          href={`/${v.slug.replace(/_/g, '-')}/`}
          class="group rounded-lg border border-slate-200 bg-white p-5 transition hover:border-slate-400 hover:shadow-sm"
        >
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-semibold text-slate-900 group-hover:text-orange-600">
              {v.name}
            </h3>
            <span class="text-slate-400 group-hover:text-orange-600">→</span>
          </div>
          <p class="mt-1 text-sm text-slate-500">
            Ranked picks, pricing, and head-to-head comparisons
          </p>
        </a>
      ))}
    </div>
  </section>

  <section class="bg-slate-100">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <h2 class="mb-8 text-2xl font-bold tracking-tight text-slate-900">
        Built for how contractors actually buy software
      </h2>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-lg bg-white p-6">
          <h3 class="mb-1 font-semibold text-slate-900">Verified pricing</h3>
          <p class="text-sm text-slate-600">
            Every tier verified directly from vendor pricing pages. Dates stamped, refreshed quarterly. No guesswork on what tools actually cost.
          </p>
        </div>
        <div class="rounded-lg bg-white p-6">
          <h3 class="mb-1 font-semibold text-slate-900">Head-to-head comparisons</h3>
          <p class="text-sm text-slate-600">
            Any two tools that share a vertical can be compared side-by-side. Pricing, features, integrations — laid out cleanly without sales-pitch language.
          </p>
        </div>
        <div class="rounded-lg bg-white p-6">
          <h3 class="mb-1 font-semibold text-slate-900">Organized by how you buy</h3>
          <p class="text-sm text-slate-600">
            Filtered by team size, vertical, use case, and integration needs — not generic SaaS taxonomy. Find the right pick for your shop in minutes.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
