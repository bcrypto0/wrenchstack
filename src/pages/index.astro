---
import Layout from '../layouts/Layout.astro';
import categories from '../data/categories.json';
import toolsData from '../data/tools.json';
import featuresData from '../data/features.json';
import { tools, toolsForVertical, freshnessStats } from '../lib/data';

const verticals = categories.verticals;
const toolCount = tools.length;

// Compute most-recent pricing-verified date across all tools (for the "Last refreshed" indicator).
const lastVerifiedDate = tools
  .map((t) => t.pricing.verified_date)
  .filter(Boolean)
  .sort()
  .at(-1) ?? new Date().toISOString().slice(0, 10);
const formattedLastVerified = new Date(lastVerifiedDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Live freshness stats — surfacing this on the homepage is our direct
// attack on competitors' staleness (Capterra ServiceTitan profile last
// updated Aug 2025 = 9 months stale at time of this writing).
const freshness = freshnessStats();

// Tool count per vertical (for the "Pick your trade" cards)
const verticalsWithCounts = verticals.map((v) => ({
  ...v,
  toolCount: toolsForVertical(v.slug).length,
}));

// Featured head-to-head comparisons — the highest-search-volume pairings in the trades software space.
// Each pair must share at least one vertical so the comparison page exists.
const featuredComparisons = [
  { a: 'jobber', b: 'housecall-pro', label: 'Jobber vs Housecall Pro', context: 'The most-searched residential FSM comparison' },
  { a: 'jobber', b: 'servicetitan', label: 'Jobber vs ServiceTitan', context: 'Entry-tier vs enterprise — when to upgrade' },
  { a: 'housecall-pro', b: 'servicetitan', label: 'Housecall Pro vs ServiceTitan', context: 'Mid-market vs enterprise residential' },
  { a: 'fieldedge', b: 'servicetitan', label: 'FieldEdge vs ServiceTitan', context: 'QuickBooks Desktop depth vs enterprise reporting' },
  { a: 'buildops', b: 'servicetitan', label: 'BuildOps vs ServiceTitan', context: 'Commercial mechanical vs residential leader' },
  { a: 'buildertrend', b: 'procore', label: 'Buildertrend vs Procore', context: 'Residential builders vs commercial GCs' },
  { a: 'acculynx', b: 'jobnimbus', label: 'AccuLynx vs JobNimbus', context: 'Storm-restoration roofing head-to-head' },
  { a: 'workiz', b: 'jobber', label: 'Workiz vs Jobber', context: 'On-demand specialty vs broad multi-vertical' },
];

// Helper to build comparison URL — slugs must be sorted alphabetically (template convention)
function comparisonUrl(a: string, b: string): string {
  const [first, second] = [a, b].sort();
  return `/compare/${first}-vs-${second}/`;
}

// Featured features — surface the new features axis with highest-value entries
const features = (featuresData as { features: Record<string, { name: string; definition: string }> }).features;
const featuredFeatures = [
  'quickbooks_integration',
  'ai_dispatcher',
  'consumer_financing',
  'membership_management',
  'online_booking',
  'gps_tracking',
];

function featureToUrl(slug: string): string {
  return slug.replace(/_/g, '-');
}
---

<Layout
  title="WrenchStack — Trades software comparisons that actually help"
  description={`Compare ${toolCount}+ field service platforms across ${verticals.length} trades. Real pricing, real feature matrices, side-by-side comparisons.`}
>
  <section class="bg-gradient-to-b from-white to-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-20 md:py-28">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-6xl">
        The trades software stack,<br />
        picked by data.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-slate-600 md:text-xl">
        Compare {toolCount}+ field service platforms across {verticals.length} trades.
        Real pricing, full feature matrices, head-to-head comparisons.
      </p>

      <div class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm font-medium text-slate-600">
        <span><span class="font-bold text-slate-900">{toolCount}+</span> tools tracked</span>
        <span class="text-slate-300">·</span>
        <span><span class="font-bold text-slate-900">{verticals.length}</span> trades verticals</span>
        <span class="text-slate-300">·</span>
        <span><span class="font-bold text-slate-900">2,400+</span> comparison pages</span>
        <span class="text-slate-300">·</span>
        <span class="inline-flex items-center gap-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 ring-2 ring-emerald-200"></span>
          <span class="font-bold text-slate-900">{freshness.verifiedLast30Days}</span> verified in last 30 days
        </span>
      </div>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/quiz/"
          class="rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-orange-600"
        >
          Take the 60-second matching quiz →
        </a>
        <a
          href="/hvac/"
          class="rounded-md bg-slate-900 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800"
        >
          Browse HVAC software
        </a>
        <a
          href="/tools/"
          class="rounded-md border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:border-slate-400"
        >
          See all tools
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <h2 class="mb-2 text-2xl font-bold tracking-tight text-slate-900">Pick your trade</h2>
    <p class="mb-8 text-slate-600">
      Each vertical has its own ranked picks, pricing comparisons, and feature matrices.
    </p>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {verticalsWithCounts.map((v) => (
        <a
          href={`/${v.slug.replace(/_/g, '-')}/`}
          class="group rounded-lg border border-slate-200 bg-white p-5 transition hover:border-slate-400 hover:shadow-sm"
        >
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-semibold text-slate-900 group-hover:text-orange-600">
              {v.name}
            </h3>
            <span class="text-slate-400 group-hover:text-orange-600">→</span>
          </div>
          <p class="mt-1 text-sm text-slate-500">
            {v.toolCount} tools ranked · pricing, features, head-to-head
          </p>
        </a>
      ))}
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <h2 class="mb-2 text-2xl font-bold tracking-tight text-slate-900">Popular head-to-head comparisons</h2>
      <p class="mb-8 text-slate-600">
        The most-searched matchups in the trades software space — decision matrix, pricing side-by-side, pros and cons.
      </p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {featuredComparisons.map((c) => (
          <a
            href={comparisonUrl(c.a, c.b)}
            class="group rounded-lg border border-slate-200 bg-white p-5 transition hover:border-orange-400 hover:shadow-sm"
          >
            <h3 class="text-base font-semibold text-slate-900 group-hover:text-orange-600">
              {c.label}
            </h3>
            <p class="mt-2 text-xs text-slate-500 leading-snug">
              {c.context}
            </p>
          </a>
        ))}
      </div>
      <div class="mt-6 text-center">
        <a href="/compare/" class="text-sm font-semibold text-orange-600 hover:underline">
          See all 1,100+ comparisons →
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <h2 class="mb-2 text-2xl font-bold tracking-tight text-slate-900">Browse by feature</h2>
    <p class="mb-8 text-slate-600">
      Have a specific must-have feature? Jump straight to tools that have it.
    </p>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {featuredFeatures.map((slug) => (
        <a
          href={`/features/${featureToUrl(slug)}/`}
          class="group rounded-lg border border-slate-200 bg-white p-5 transition hover:border-orange-400 hover:shadow-sm"
        >
          <h3 class="font-semibold text-slate-900 group-hover:text-orange-600">
            {features[slug].name}
          </h3>
          <p class="mt-1 text-sm text-slate-500 leading-snug">
            {features[slug].definition}
          </p>
        </a>
      ))}
    </div>
    <div class="mt-6 text-center">
      <a href="/features/" class="text-sm font-semibold text-orange-600 hover:underline">
        All 20 features →
      </a>
    </div>
  </section>

  <section class="bg-slate-100">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <h2 class="mb-8 text-2xl font-bold tracking-tight text-slate-900">
        Built for how contractors actually buy software
      </h2>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-lg bg-white p-6">
          <h3 class="mb-1 font-semibold text-slate-900">Verified pricing</h3>
          <p class="text-sm text-slate-600">
            Every tier verified directly from vendor pricing pages. Dates stamped, refreshed quarterly. No guesswork on what tools actually cost.
          </p>
        </div>
        <div class="rounded-lg bg-white p-6">
          <h3 class="mb-1 font-semibold text-slate-900">Head-to-head comparisons</h3>
          <p class="text-sm text-slate-600">
            Any two tools that share a vertical can be compared side-by-side. Pricing, features, integrations, decision matrix — laid out cleanly without sales-pitch language.
          </p>
        </div>
        <div class="rounded-lg bg-white p-6">
          <h3 class="mb-1 font-semibold text-slate-900">Organized by how you buy</h3>
          <p class="text-sm text-slate-600">
            Filtered by team size, vertical, feature need, and integration requirements — not generic SaaS taxonomy. Find the right pick for your shop in minutes.
          </p>
        </div>
        <div class="rounded-lg bg-white p-6">
          <h3 class="mb-1 font-semibold text-slate-900">Independent scoring</h3>
          <p class="text-sm text-slate-600">
            Every tool ranked by the <a href="/methodology/" class="text-orange-600 hover:underline">WrenchStack Score</a> — vertical fit, user ratings, pricing transparency, feature depth, integration coverage. Same formula for every tool.
          </p>
        </div>
        <div class="rounded-lg bg-white p-6">
          <h3 class="mb-1 font-semibold text-slate-900">ROI calculator</h3>
          <p class="text-sm text-slate-600">
            Plug in your team size and revenue, get payback estimates for different platforms.{' '}
            <a href="/roi-calculator/" class="text-orange-600 hover:underline">Run the calculator →</a>
          </p>
        </div>
        <div class="rounded-lg bg-white p-6">
          <h3 class="mb-1 font-semibold text-slate-900">Buyer guides by situation</h3>
          <p class="text-sm text-slate-600">
            Solo HVAC contractor? Growing roofing team? QuickBooks-heavy plumber? Pre-built picks for{' '}
            <a href="/best-software-for/" class="text-orange-600 hover:underline">specific buyer profiles →</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-900 text-white">
    <div class="mx-auto max-w-4xl px-4 py-20 text-center">
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">
        Not sure which tool fits your shop?
      </h2>
      <p class="mt-4 text-lg text-slate-300">
        Answer 5 quick questions about your team size, vertical, and must-have features.
        Get 3 ranked picks tailored to your situation in 60 seconds.
      </p>
      <a
        href="/quiz/"
        class="mt-8 inline-block rounded-md bg-orange-500 px-6 py-4 text-base font-semibold text-white hover:bg-orange-600"
      >
        Start the matching quiz →
      </a>
      <p class="mt-4 text-xs text-slate-400">
        No email required. No sales calls. Just answers.
      </p>
    </div>
  </section>
</Layout>
